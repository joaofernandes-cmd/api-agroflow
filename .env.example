DATABASE_URL=url
JWT_SECRET=gere-um-segredo-aleatorio-seguro

# URL base usada para montar os links de acesso por QR Code do capataz (opcional).
# Se ausente, o sistema usa http://localhost:<PORT> (PORT padrão 3000).
# Para gerar QR Code apontando para o app publicado, use a URL de produção, ex.:
#   APP_URL=https://agroflow-q58k.onrender.com
APP_URL=http://localhost:3000

# Supabase Storage — onde as evidências (foto/áudio) do capataz são hospedadas.
# A anon key é pública por design do Supabase (pode ir para o navegador).
# Crie um bucket PÚBLICO no painel do Supabase e use o nome dele em SUPABASE_BUCKET.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-publica
SUPABASE_BUCKET=evidencias
# Pasta padrão dentro do bucket (opcional; o código já separa em evidencias/foto e evidencias/audio)
SUPABASE_FOLDER=
