<%- include('../partials/head', { title: 'Selecione seu perfil', css: 'auth' }) %>

<main class="perfil-screen" role="main" aria-label="Seleção de perfil">

  <!-- Logo AgroFlow -->
  <div class="perfil-logo" aria-hidden="true">
    <img
      src="https://www.figma.com/api/mcp/asset/30f29d30-bb31-4cd7-922a-066f394a8f6f"
      alt="AgroFlow"
      width="357"
      height="292"
    />
  </div>

  <!-- Título -->
  <h1 class="perfil-title">
    Selecione<br>seu perfil
  </h1>
  <p class="perfil-subtitle">Escolha como deseja acessar o sistema</p>

  <!-- Card de seleção -->
  <div class="perfil-card" role="group" aria-labelledby="perfil-label">
    <p class="perfil-label" id="perfil-label">Acessar como:</p>

    <!-- Supervisor: botão sólido (destaque) -->
    <a href="/auth/login?role=supervisor" class="btn btn--primary" aria-label="Acessar como Supervisor">
      Supervisor
    </a>

    <!-- Gerente: botão outlined -->
    <a href="/auth/login?role=gerente" class="btn btn--outline" aria-label="Acessar como Gerente">
      Gerente
    </a>
  </div>

  <p class="perfil-version" aria-hidden="true">v1.0.0</p>

</main>

</body>
</html>
