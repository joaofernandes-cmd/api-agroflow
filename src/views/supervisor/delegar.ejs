<%- include('../partials/head', { title: title, css: css }) %>

<%#
  Variáveis esperadas pelo controller:
  - usuario: { nome: string }
  - css: ['supervisor']
%>

<!-- ============================================================
     TELA: Delegar tarefa
     Mobile  → TopNav com voltar + formulário + BottomNav
     Desktop → Sidebar + TopBar + formulário (esq) + tarefas ativas (dir)
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/supervisor/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Delegar tarefa</h1>
  </header>

  <!-- Formulário -->
  <main class="form-content" role="main">
    <form class="delegate-form" id="form-delegar" novalidate>

      <div class="dfield">
        <label class="dfield__label" for="capataz-mobile">Capataz | Retiro</label>
        <div class="dfield__select-wrap">
          <select class="dfield__select" id="capataz-mobile" name="capatazRetiro" required aria-required="true">
            <option value="" disabled selected>Nome do capataz e do retiro</option>
            <option value="lucas-aroeira">Lucas • Aroeira</option>
            <option value="alberto-cmb">Alberto • CMB</option>
            <option value="jose-cristo">José Carlos • Cristo</option>
            <option value="manoel-puga">Manoel • Puga</option>
          </select>
        </div>
      </div>

      <div class="dfield">
        <label class="dfield__label" for="atividade-mobile">Atividade solicitada</label>
        <div class="dfield__select-wrap">
          <select class="dfield__select" id="atividade-mobile" name="atividade" required aria-required="true">
            <option value="" disabled selected>Tarefa a delegar</option>
            <option value="conferencia">Conferência do rebanho</option>
            <option value="transferencia-gado">Transferência de gado</option>
            <option value="contagem">Contagem geral</option>
            <option value="inspecao">Inspeção sanitária</option>
            <option value="outro">Outro</option>
          </select>
        </div>
      </div>

      <div class="dfield">
        <label class="dfield__label">Prioridade</label>
        <div class="prio-seletor" role="radiogroup" aria-label="Prioridade">
          <button type="button" class="prio-opcao prio-opcao--alta" data-valor="alta">Alta</button>
          <button type="button" class="prio-opcao prio-opcao--media" data-valor="media">Média</button>
          <button type="button" class="prio-opcao prio-opcao--baixa" data-valor="baixa">Baixa</button>
          <button type="button" class="prio-opcao prio-opcao--critica" data-valor="critica">Crítica</button>
          <input type="hidden" id="prioridade-mobile" name="prioridade" />
        </div>
      </div>

      <div class="dfield">
        <label class="dfield__label" for="descricao-mobile">Descrição (obrigatório)</label>
        <textarea
          class="dfield__textarea"
          id="descricao-mobile"
          name="descricao"
          placeholder="Adicione detalhes da tarefa..."
          required
          aria-required="true"
          rows="4"
        ></textarea>
      </div>

      <p class="delegar-feedback" style="margin: 0 0 8px; font-size: 14px; line-height: 1.4; display: none;"></p>
      <button type="submit" class="btn btn--primary btn--enviar">Enviar</button>

    </form>
  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'delegar' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <!-- Sidebar -->
  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'delegar' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <h1 class="topbar__title">Delegar tarefa</h1>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <!-- Conteúdo: formulário + tarefas ativas -->
    <main class="desktop-content delegar-grid" role="main">

      <!-- Coluna esquerda: formulário -->
      <section class="delegar-form-col" aria-label="Formulário de delegação">
        <form id="form-delegar-desktop" novalidate>

          <div class="dfield dfield--desktop">
            <label class="dfield__label dfield__label--dark" for="capataz-desktop">Capataz | Retiro</label>
            <div class="dfield__select-wrap">
              <select class="dfield__select dfield__select--desktop" id="capataz-desktop" name="capatazRetiro" required>
                <option value="" disabled selected>Nome do capataz e do retiro</option>
                <option value="lucas-aroeira">Lucas • Aroeira</option>
                <option value="alberto-cmb">Alberto • CMB</option>
                <option value="jose-cristo">José Carlos • Cristo</option>
                <option value="manoel-puga">Manoel • Puga</option>
              </select>
            </div>
          </div>

          <div class="dfield dfield--desktop">
            <label class="dfield__label dfield__label--dark" for="atividade-desktop">Atividade solicitada</label>
            <div class="dfield__select-wrap">
              <select class="dfield__select dfield__select--desktop" id="atividade-desktop" name="atividade" required>
                <option value="" disabled selected>Tarefa a delegar</option>
                <option value="conferencia">Conferência do rebanho</option>
                <option value="transferencia-gado">Transferência de gado</option>
                <option value="contagem">Contagem geral</option>
                <option value="inspecao">Inspeção sanitária</option>
                <option value="outro">Outro</option>
              </select>
            </div>
          </div>

          <div class="dfield dfield--desktop">
            <label class="dfield__label dfield__label--dark">Prioridade</label>
            <div class="prio-seletor" role="radiogroup" aria-label="Prioridade">
              <button type="button" class="prio-opcao prio-opcao--alta" data-valor="alta">Alta</button>
              <button type="button" class="prio-opcao prio-opcao--media" data-valor="media">Média</button>
              <button type="button" class="prio-opcao prio-opcao--baixa" data-valor="baixa">Baixa</button>
              <button type="button" class="prio-opcao prio-opcao--critica" data-valor="critica">Crítica</button>
              <input type="hidden" id="prioridade-desktop" name="prioridade" />
            </div>
          </div>

          <div class="dfield dfield--desktop">
            <label class="dfield__label dfield__label--dark" for="descricao-desktop">Descrição (obrigatório)</label>
            <textarea
              class="dfield__textarea dfield__textarea--desktop"
              id="descricao-desktop"
              name="descricao"
              placeholder="Adicione detalhes da tarefa..."
              required
              rows="5"
            ></textarea>
          </div>

          <p class="delegar-feedback" style="margin: 0 0 8px; font-size: 14px; line-height: 1.4; display: none;"></p>
          <button type="submit" class="btn btn--primary btn--enviar-desktop">Enviar tarefa</button>

        </form>
      </section>

      <!-- Coluna direita: tarefas ativas -->
      <aside class="delegar-tarefas-col" aria-labelledby="tarefas-ativas-title">
        <h2 class="section__title" id="tarefas-ativas-title">Tarefas ativas</h2>

        <article class="tarefa-card">
          <div class="tarefa-card__accent tarefa-card__accent--red"></div>
          <div class="tarefa-card__body">
            <p class="tarefa-card__name">Inspeção de cercas</p>
            <p class="tarefa-card__meta">Alberto • CMB</p>
          </div>
          <span class="prioridade-badge prioridade-badge--alta">Alta</span>
        </article>

        <article class="tarefa-card">
          <div class="tarefa-card__accent tarefa-card__accent--yellow"></div>
          <div class="tarefa-card__body">
            <p class="tarefa-card__name">Contagem geral</p>
            <p class="tarefa-card__meta">José Carlos • Cristo</p>
          </div>
          <span class="prioridade-badge prioridade-badge--media">Média</span>
        </article>

        <article class="tarefa-card">
          <div class="tarefa-card__accent tarefa-card__accent--blue"></div>
          <div class="tarefa-card__body">
            <p class="tarefa-card__name">Inspeção sanitária</p>
            <p class="tarefa-card__meta">Lucas • Aroeira</p>
          </div>
          <span class="prioridade-badge prioridade-badge--baixa">Baixa</span>
        </article>

      </aside>

    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script src="/js/prioridade-seletor.js"></script>
<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  function mostrarFeedback(mensagem, tipo) {
    document.querySelectorAll('.delegar-feedback').forEach(el => {
      el.textContent = mensagem;
      el.style.color = tipo === 'error' ? '#b42318' : '#146c43';
      el.style.display = mensagem ? 'block' : 'none';
    });
  }

  function getSession() {
    try {
      const token = localStorage.getItem('agroflow.token');
      const usuarioRaw = localStorage.getItem('agroflow.usuario');

      if (!token || !usuarioRaw) return null;

      return {
        token,
        usuario: JSON.parse(usuarioRaw),
      };
    } catch {
      return null;
    }
  }

  function atualizarEstadoSelect(select) {
    select.classList.toggle('dfield__select--has-value', select.value !== '');
  }

  function preencherCapatazes(selects, capatazes) {
    selects.forEach(select => {
      const placeholder = select.querySelector('option[value=""]')?.textContent || 'Selecione um capataz';

      select.innerHTML = '';

      const optionPadrao = document.createElement('option');
      optionPadrao.value = '';
      optionPadrao.disabled = true;
      optionPadrao.selected = true;
      optionPadrao.textContent = placeholder;
      select.appendChild(optionPadrao);

      capatazes.forEach(capataz => {
        const option = document.createElement('option');
        option.value = capataz.id;
        option.textContent = `${capataz.nome} • Retiro ${capataz.retiro_id}`;
        select.appendChild(option);
      });

      select.dataset.loaded = 'true';
      atualizarEstadoSelect(select);
      select.addEventListener('change', () => atualizarEstadoSelect(select));
    });
  }

  async function carregarCapatazes() {
    const session = getSession();
    if (!session) {
      return;
    }

    const selects = Array.from(document.querySelectorAll('select[name="capatazRetiro"]'));

    try {
      const response = await fetch(`/usuarios/capatazes/retiro/${session.usuario.retiro_id}`, {
        headers: {
          Authorization: `Bearer ${session.token}`,
        },
      });

      const data = await response.json().catch(() => []);

      if (!response.ok) {
        throw new Error(data.error || 'Não foi possível carregar os capatazes');
      }

      if (!Array.isArray(data) || data.length === 0) {
        throw new Error('Nenhum capataz encontrado para este retiro');
      }

      preencherCapatazes(selects, data);
      mostrarFeedback('Capatazes carregados com sucesso.', 'success');
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao carregar capatazes', 'error');
      selects.forEach(select => {
        select.dataset.loaded = 'false';
        atualizarEstadoSelect(select);
      });
    }
  }

  async function enviarTarefa(event) {
    event.preventDefault();

    const form = event.currentTarget;
    const session = getSession();

    if (!session) {
      return;
    }

    const capataz = form.querySelector('select[name="capatazRetiro"]');
    const atividade = form.querySelector('select[name="atividade"]');
    const prioridade = form.querySelector('[name="prioridade"]');
    const descricao = form.querySelector('textarea[name="descricao"]');

    if (!capataz || !atividade || !prioridade || !descricao) {
      mostrarFeedback('Formulário incompleto.', 'error');
      return;
    }

    if (capataz.dataset.loaded !== 'true') {
      mostrarFeedback('Os capatazes ainda não foram carregados.', 'error');
      return;
    }

    const payload = {
      retiro_id: session.usuario.retiro_id,
      atribuida_a: capataz.value,
      descricao: descricao.value.trim(),
      categoria: atividade.value,
      prioridade: prioridade.value,
      usuarioCriador: session.usuario,
    };

    if (!payload.atribuida_a || !payload.categoria || !payload.prioridade || !payload.descricao) {
      mostrarFeedback('Preencha todos os campos obrigatórios.', 'error');
      return;
    }

    const botao = form.querySelector('button[type="submit"]');
    if (botao) {
      botao.disabled = true;
      botao.textContent = 'Enviando...';
    }

    try {
      const response = await fetch('/tarefas', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${session.token}`,
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data.error || 'Não foi possível enviar a tarefa');
      }

      mostrarFeedback('Tarefa enviada com sucesso.', 'success');
      form.reset();

      document.querySelectorAll('.dfield__select').forEach(select => atualizarEstadoSelect(select));
      document.querySelectorAll('textarea[name="descricao"]').forEach(textarea => {
        textarea.value = '';
      });
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao enviar tarefa', 'error');
    } finally {
      if (botao) {
        botao.disabled = false;
        botao.textContent = form.id === 'form-delegar-desktop' ? 'Enviar tarefa' : 'Enviar';
      }
    }
  }

  document.querySelectorAll('#form-delegar, #form-delegar-desktop').forEach(form => {
    form.addEventListener('submit', enviarTarefa);
  });

  document.querySelectorAll('.dfield__select').forEach(select => {
    atualizarEstadoSelect(select);
    select.addEventListener('change', () => atualizarEstadoSelect(select));
  });

  carregarCapatazes();
</script>

</body>
</html>
