<%- include('../partials/head', { title: 'Início', css: 'supervisor' }) %>

<!-- ============================================================
     TELA: Home Supervisor
     Mobile  → TopNav verde + BottomNav + cards empilhados
     Desktop → Sidebar fixa esquerda + TopBar + grid de conteúdo
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav -->
  <header class="topnav" role="banner">
    <h1 class="topnav__title">Início</h1>
    <button class="topnav__bell" aria-label="Notificações">
      <img src="/assets/icons/notificacao.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span class="topnav__bell-dot" aria-hidden="true"></span>
    </button>
  </header>

  <!-- Saudação -->
  <section class="greeting" aria-label="Saudação">
    <p class="greeting__name">Bom dia, <%= usuario?.nome?.split(' ')[0] || 'Luiz' %>!</p>
    <p class="greeting__date" id="data-hoje"></p>
  </section>

  <!-- Conteúdo principal -->
  <main class="home-content" role="main">

    <!-- Acesso rápido -->
    <section class="section" aria-labelledby="acesso-rapido-title">
      <h2 class="section__title" id="acesso-rapido-title">Acesso rápido</h2>

      <a href="/supervisor/revisao" class="qcard qcard--yellow" aria-label="Tarefas pendentes">
        <div class="qcard__accent" aria-hidden="true"></div>
        <div class="qcard__body">
          <p class="qcard__name">Tarefas pendentes</p>
          <p class="qcard__desc">3 registros aguardando revisão</p>
        </div>
        <span class="qcard__arrow" aria-hidden="true">›</span>
      </a>

      <a href="/supervisor/tickets" class="qcard qcard--red" aria-label="Tickets de infraestrutura">
        <div class="qcard__accent" aria-hidden="true"></div>
        <div class="qcard__body">
          <p class="qcard__name">Tickets de infraestrutura</p>
          <p class="qcard__desc">2 chamados ativos no sistema</p>
        </div>
        <span class="qcard__arrow" aria-hidden="true">›</span>
      </a>
    </section>

    <!-- Operações de campo -->
    <section class="section" aria-labelledby="operacoes-title">
      <h2 class="section__title" id="operacoes-title">Operações de campo</h2>

      <a href="/supervisor/delegar" class="qcard qcard--blue" aria-label="Delegar tarefas">
        <div class="qcard__accent" aria-hidden="true"></div>
        <div class="qcard__body">
          <p class="qcard__name">Delegar tarefas</p>
          <p class="qcard__desc">Atribua atividades para capatazes</p>
        </div>
        <span class="qcard__arrow" aria-hidden="true">›</span>
      </a>
    </section>

  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'home' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'home' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <h1 class="topbar__title">Início</h1>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <!-- Saudação -->
    <section class="greeting-desktop" aria-label="Saudação">
      <p class="greeting-desktop__name">Bom dia, <%= usuario?.nome || 'Luiz Felipe' %>!</p>
      <p class="greeting-desktop__date" id="data-hoje-desktop2"></p>
    </section>

    <!-- Conteúdo -->
    <main class="desktop-content" role="main">

      <!-- Acesso rápido -->
      <section class="section" aria-labelledby="acesso-rapido-desktop">
        <h2 class="section__title" id="acesso-rapido-desktop">Acesso rápido</h2>
        <div class="cards-grid">
          <a href="/supervisor/revisao" class="qcard qcard--yellow">
            <div class="qcard__accent" aria-hidden="true"></div>
            <div class="qcard__body">
              <p class="qcard__name">Tarefas pendentes</p>
              <p class="qcard__desc">3 registros aguardando revisão</p>
            </div>
            <span class="qcard__arrow" aria-hidden="true">›</span>
          </a>
          <a href="/supervisor/tickets" class="qcard qcard--red">
            <div class="qcard__accent" aria-hidden="true"></div>
            <div class="qcard__body">
              <p class="qcard__name">Tickets de infraestrutura</p>
              <p class="qcard__desc">2 chamados ativos no sistema</p>
            </div>
            <span class="qcard__arrow" aria-hidden="true">›</span>
          </a>
        </div>
      </section>

      <!-- Operações de campo -->
      <section class="section" aria-labelledby="operacoes-desktop">
        <h2 class="section__title" id="operacoes-desktop">Operações de campo</h2>
        <div class="cards-grid cards-grid--single">
          <a href="/supervisor/delegar" class="qcard qcard--blue">
            <div class="qcard__accent" aria-hidden="true"></div>
            <div class="qcard__body">
              <p class="qcard__name">Delegar tarefas</p>
              <p class="qcard__desc">Atribua atividades para capatazes</p>
            </div>
            <span class="qcard__arrow" aria-hidden="true">›</span>
          </a>
        </div>
      </section>

      <!-- Atividade recente -->
      <section class="section" aria-labelledby="atividade-desktop">
        <h2 class="section__title" id="atividade-desktop">Atividade recente</h2>
        <div class="qcard qcard--yellow">
          <div class="qcard__accent" aria-hidden="true"></div>
          <div class="qcard__body">
            <p class="qcard__name">Conferência do rebanho — Aroeira</p>
            <p class="qcard__desc">Capataz Lucas • há 1h</p>
          </div>
        </div>
        <div class="qcard qcard--yellow">
          <div class="qcard__accent" aria-hidden="true"></div>
          <div class="qcard__body">
            <p class="qcard__name">Transferência de gado lote B — CMB</p>
            <p class="qcard__desc">Capataz Alberto • há 2h</p>
          </div>
        </div>
        <div class="qcard qcard--red">
          <div class="qcard__accent" aria-hidden="true"></div>
          <div class="qcard__body">
            <p class="qcard__name">Mortalidade acima do esperado</p>
            <p class="qcard__desc">Puga • Hoje, 08:24</p>
          </div>
        </div>
      </section>

    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script>
  /* Preenche a data atual dinamicamente */
  function formatarData() {
    return new Date().toLocaleDateString('pt-BR', {
      weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
    }).replace(/^\w/, c => c.toUpperCase());
  }

  function carregarSessao() {
    try {
      const usuarioRaw = localStorage.getItem('agroflow.usuario');
      if (!usuarioRaw) return null;
      return JSON.parse(usuarioRaw);
    } catch {
      return null;
    }
  }

  const data = formatarData();
  ['data-hoje', 'data-hoje-desktop', 'data-hoje-desktop2'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = data;
  });

  const usuario = carregarSessao();
  if (usuario?.nome) {
    document.querySelectorAll('.greeting__name, .greeting-desktop__name, .sidebar__user-name').forEach(el => {
      el.textContent = `Bom dia, ${usuario.nome.split(' ')[0]}!`;
    });

    document.querySelectorAll('.sidebar__user-role').forEach(el => {
      el.textContent = 'Supervisor';
    });

    document.querySelectorAll('.sidebar__avatar').forEach(el => {
      el.textContent = usuario.nome
        .split(' ')
        .map(parte => parte[0])
        .slice(0, 2)
        .join('')
        .toUpperCase();
    });
  }
</script>

</body>
</html>
