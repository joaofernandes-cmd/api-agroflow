<%- include('../partials/head', { title: 'Início', css: 'supervisor' }) %>

<!-- ============================================================
     TELA: Home Supervisor
     Mobile  → TopNav verde + BottomNav + cards empilhados
     Desktop → Sidebar fixa esquerda + TopBar + grid de conteúdo
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav -->
  <header class="topnav" role="banner">
    <h1 class="topnav__title">Início</h1>
    <button class="topnav__bell" aria-label="Notificações">
      <img src="/assets/icons/notificacao.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span class="topnav__bell-dot" aria-hidden="true"></span>
    </button>
  </header>

  <!-- Saudação -->
  <section class="greeting" aria-label="Saudação">
    <p class="greeting__name">Bom dia, <%= usuario?.nome?.split(' ')[0] || 'Luiz' %>!</p>
    <p class="greeting__date" id="data-hoje"></p>
  </section>

  <!-- Conteúdo principal -->
  <main class="home-content" role="main">

    <!-- Acesso rápido (blocos grandes 2x2) -->
    <section class="section" aria-labelledby="acesso-rapido-title">
      <h2 class="section__title" id="acesso-rapido-title">Acesso rápido</h2>

      <div class="tile-grid">
        <a href="/supervisor/revisao" class="tile tile--yellow" aria-label="Tarefas pendentes: 3 aguardando revisão">
          <span class="tile__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
          </span>
          <span class="tile__text">
            <span class="tile__name">Tarefas pendentes</span>
            <span class="tile__sub">3 aguardando revisão</span>
          </span>
        </a>

        <a href="/supervisor/tickets" class="tile tile--red" aria-label="Tickets de infraestrutura: 2 chamados ativos">
          <span class="tile__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </span>
          <span class="tile__text">
            <span class="tile__name">Tickets</span>
            <span class="tile__sub">2 chamados ativos</span>
          </span>
        </a>

        <a href="/supervisor/delegar" class="tile tile--blue" aria-label="Delegar tarefa">
          <span class="tile__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
          </span>
          <span class="tile__text">
            <span class="tile__name">Delegar tarefa</span>
            <span class="tile__sub">Atribuir ao capataz</span>
          </span>
        </a>

        <a href="/supervisor/relatorios" class="tile tile--green" aria-label="Relatórios">
          <span class="tile__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>
          </span>
          <span class="tile__text">
            <span class="tile__name">Relatórios</span>
            <span class="tile__sub">Ver resumos</span>
          </span>
        </a>
      </div>
    </section>

    <!-- Tarefas delegadas (criadas por você, ainda não realizadas pelo capataz) -->
    <section class="section" aria-labelledby="delegadas-title">
      <div class="section__head">
        <h2 class="section__title" id="delegadas-title">Tarefas delegadas</h2>
        <span class="section__count"><%= tarefasDelegadas.length %> pendente<%= tarefasDelegadas.length === 1 ? '' : 's' %></span>
      </div>

      <div class="atencao-list">
        <% if (tarefasDelegadas.length === 0) { %>
          <p class="atencao-vazio">Tudo em dia — nenhuma tarefa pendente com os capatazes.</p>
        <% } %>
        <% tarefasDelegadas.forEach((t) => { %>
          <a href="/supervisor/tarefa?id=<%= t.id %>" class="task-row task-row--<%= t.prioridade %>">
            <span class="task-row__accent" aria-hidden="true"></span>
            <span class="task-row__body">
              <span class="task-row__head">
                <span class="prioridade-badge prioridade-badge--<%= t.prioridade %>"><%= t.nivel %></span>
                <span class="task-row__type"><%= t.categoria %></span>
              </span>
              <span class="task-row__title"><%= t.titulo %></span>
              <span class="task-row__meta">Retiro <%= t.retiro %> · pendente</span>
            </span>
            <span class="task-row__due">
              <span class="task-row__due-label">Prazo</span>
              <span class="task-row__due-value"><%= t.prazo %></span>
            </span>
          </a>
        <% }) %>
      </div>
    </section>

  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'home' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'home' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <h1 class="topbar__title">Início</h1>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <!-- Saudação -->
    <section class="greeting-desktop" aria-label="Saudação">
      <p class="greeting-desktop__name">Bom dia, <%= usuario?.nome || 'Luiz Felipe' %>!</p>
      <p class="greeting-desktop__date" id="data-hoje-desktop2"></p>
    </section>

    <!-- Conteúdo -->
    <main class="desktop-content" role="main">

      <!-- Acesso rápido (blocos grandes) -->
      <section class="section" aria-labelledby="acesso-rapido-desktop">
        <h2 class="section__title" id="acesso-rapido-desktop">Acesso rápido</h2>
        <div class="tile-grid">
          <a href="/supervisor/revisao" class="tile tile--yellow" aria-label="Tarefas pendentes: 3 aguardando revisão">
            <span class="tile__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>
            </span>
            <span class="tile__text">
              <span class="tile__name">Tarefas pendentes</span>
              <span class="tile__sub">3 aguardando revisão</span>
            </span>
          </a>
          <a href="/supervisor/tickets" class="tile tile--red" aria-label="Tickets de infraestrutura: 2 chamados ativos">
            <span class="tile__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </span>
            <span class="tile__text">
              <span class="tile__name">Tickets</span>
              <span class="tile__sub">2 chamados ativos</span>
            </span>
          </a>
          <a href="/supervisor/delegar" class="tile tile--blue" aria-label="Delegar tarefa">
            <span class="tile__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
            </span>
            <span class="tile__text">
              <span class="tile__name">Delegar tarefa</span>
              <span class="tile__sub">Atribuir ao capataz</span>
            </span>
          </a>
          <a href="/supervisor/relatorios" class="tile tile--green" aria-label="Relatórios">
            <span class="tile__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>
            </span>
            <span class="tile__text">
              <span class="tile__name">Relatórios</span>
              <span class="tile__sub">Ver resumos</span>
            </span>
          </a>
        </div>
      </section>

      <!-- Tarefas delegadas (criadas por você, ainda não realizadas pelo capataz) -->
      <section class="section" aria-labelledby="delegadas-desktop">
        <div class="section__head">
          <h2 class="section__title" id="delegadas-desktop">Tarefas delegadas</h2>
          <span class="section__count"><%= tarefasDelegadas.length %> pendente<%= tarefasDelegadas.length === 1 ? '' : 's' %></span>
        </div>

        <div class="atencao-list">
          <% if (tarefasDelegadas.length === 0) { %>
            <p class="atencao-vazio">Tudo em dia — nenhuma tarefa pendente com os capatazes.</p>
          <% } %>
          <% tarefasDelegadas.forEach((t) => { %>
            <a href="/supervisor/tarefa?id=<%= t.id %>" class="task-row task-row--<%= t.prioridade %>">
              <span class="task-row__accent" aria-hidden="true"></span>
              <span class="task-row__body">
                <span class="task-row__head">
                  <span class="prioridade-badge prioridade-badge--<%= t.prioridade %>"><%= t.nivel %></span>
                  <span class="task-row__type"><%= t.categoria %></span>
                </span>
                <span class="task-row__title"><%= t.titulo %></span>
                <span class="task-row__meta">Retiro <%= t.retiro %> · pendente</span>
              </span>
              <span class="task-row__due">
                <span class="task-row__due-label">Prazo</span>
                <span class="task-row__due-value"><%= t.prazo %></span>
              </span>
            </a>
          <% }) %>
        </div>
      </section>

    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script>
  /* Preenche a data atual dinamicamente */
  function formatarData() {
    return new Date().toLocaleDateString('pt-BR', {
      weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
    }).replace(/^\w/, c => c.toUpperCase());
  }

  function carregarSessao() {
    try {
      const usuarioRaw = localStorage.getItem('agroflow.usuario');
      if (!usuarioRaw) return null;
      return JSON.parse(usuarioRaw);
    } catch {
      return null;
    }
  }

  const data = formatarData();
  ['data-hoje', 'data-hoje-desktop', 'data-hoje-desktop2'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = data;
  });

  const usuario = carregarSessao();
  if (usuario?.nome) {
    document.querySelectorAll('.greeting__name, .greeting-desktop__name, .sidebar__user-name').forEach(el => {
      el.textContent = `Bom dia, ${usuario.nome.split(' ')[0]}!`;
    });

    document.querySelectorAll('.sidebar__user-role').forEach(el => {
      el.textContent = 'Supervisor';
    });

    document.querySelectorAll('.sidebar__avatar').forEach(el => {
      el.textContent = usuario.nome
        .split(' ')
        .map(parte => parte[0])
        .slice(0, 2)
        .join('')
        .toUpperCase();
    });
  }
</script>

</body>
</html>
