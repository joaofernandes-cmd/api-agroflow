<script>
  if (window.TarefasStore) {
    document.querySelectorAll('.concluidas-capataz').forEach(function (el) {
      TarefasStore.renderListaConcluidas(el, { selo: 'Validada', vazio: 'Nenhuma tarefa validada ainda.', dataPrefixo: 'Validada em' });
