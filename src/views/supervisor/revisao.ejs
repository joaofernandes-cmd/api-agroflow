</script>

<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  function carregarSessao() {
    try {
      const token = localStorage.getItem('agroflow.token');
      const usuarioRaw = localStorage.getItem('agroflow.usuario');
      if (!token || !usuarioRaw) return null;
      return { token, usuario: JSON.parse(usuarioRaw) };
    } catch {
      return null;
    }
  }

  function mostrarFeedback(id, mensagem, tipo) {
    const feedback = document.getElementById(id);
    if (!feedback) return;
    feedback.textContent = mensagem;
    feedback.style.color = tipo === 'error' ? '#b42318' : '#146c43';
  }

  function agoraFormatado() {
    return new Date().toLocaleString('pt-BR', {
      day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
    });
  }

  // Valida no backend (não bloqueia a UI se falhar — é demo).
  async function validarTarefaPorId(tarefaId) {
    try {
      const response = await fetch(`/validacoes/tarefas/${tarefaId}/aprovar`, { method: 'PATCH' });
      const data = await response.json().catch(() => ({}));
      return { ok: response.ok, mensagem: data.mensagem || data.error || '' };
    } catch (e) {
      return { ok: false, mensagem: 'Falha de conexão' };
    }
  }

  function reRenderConcluidas() {
    if (!window.TarefasStore) return;
    document.querySelectorAll('.concluidas-capataz').forEach(function (el) {
      TarefasStore.renderListaConcluidas(el, { selo: 'Validada', vazio: 'Nenhuma tarefa validada ainda.', dataPrefixo: 'Validada em' });
    });
  }

  // Recalcula o contador "N Pendentes" ao lado da busca conforme as tarefas
  // vão sendo validadas (some uma de cima → o número cai).
  function atualizarBadgePendentes() {
    const nMobile = document.querySelectorAll('.layout-mobile .pend-item').length;
    const nDesktop = document.querySelectorAll('.layout-desktop .revisao-table tbody tr[data-tarefa-id]').length;
    const badgeMobile = document.querySelector('.layout-mobile .revisao-badge-pendentes');
    const badgeDesktop = document.querySelector('.layout-desktop .revisao-badge-pendentes');
    if (badgeMobile) badgeMobile.textContent = nMobile + (nMobile === 1 ? ' Pendente' : ' Pendentes');
    if (badgeDesktop) badgeDesktop.textContent = nDesktop + (nDesktop === 1 ? ' Pendente' : ' Pendentes');
  }

  // Valida a tarefa: grava como concluída e move o item para a
  // seção "Validadas" (some de cima e aparece embaixo).
  function aceitarTarefa(id, titulo, retiro) {
    if (window.TarefasStore) {
      TarefasStore.concluir('rev-' + id, {
        titulo: titulo,
        retiro: retiro,
        dataConclusao: agoraFormatado(),
      });
      reRenderConcluidas();
    }
    validarTarefaPorId(id);
  }

  // Aceitar vara mobile (pend-item): some de cima e desce pra Concluídas
  function aceitarPendItem(item) {
    if (!item || item.dataset.aceito) return;
    item.dataset.aceito = '1';
    const nome = item.querySelector('.pend-title')?.textContent || 'Tarefa';
    const partes = nome.split(' — ');
    aceitarTarefa(item.dataset.tarefaId, partes[0].trim(), (partes[1] || '').trim());
    item.remove();
    atualizarBadgePendentes();
  }

  // Aceitar linha desktop (tabela): remove a linha e sua linha de detalhe
  function aceitarLinhaDesktop(row) {
    if (!row || row.dataset.aceito) return;
    row.dataset.aceito = '1';
    const titulo = (row.querySelector('.td--bold')?.textContent || 'Tarefa').trim();
    const retiro = (row.children[1]?.textContent || '').trim();
    const det = row.nextElementSibling;
    aceitarTarefa(row.dataset.tarefaId, titulo, retiro);
    row.remove();
    if (det && det.classList.contains('pend-detalhe')) det.remove();
    atualizarBadgePendentes();
  }

  // Botão "Validar" (vara mobile ou linha desktop)
  document.querySelectorAll('.btn-revisar').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.pend-item');
      if (item) { aceitarPendItem(item); return; }
      aceitarLinhaDesktop(btn.closest('tr'));
    });
  });

  // Setinha: abre/fecha as informações da tarefa pendente (mobile)
  document.querySelectorAll('.pend-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.pend-item');
      if (!item) return;
      const aberto = item.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', aberto ? 'true' : 'false');
    });
  });

  // "Ver mais" (desktop): abre a linha de detalhe com descrição + evidência
  document.querySelectorAll('.ver-mais').forEach(btn => {
    btn.addEventListener('click', () => {
      const det = btn.closest('tr')?.nextElementSibling;
      if (!det || !det.classList.contains('pend-detalhe')) return;
      const abrindo = det.hasAttribute('hidden');
      det.toggleAttribute('hidden');
      btn.setAttribute('aria-expanded', abrindo ? 'true' : 'false');
    });
  });

  // Filtro de busca — mobile
  const searchMobile = document.querySelector('.revisao-search');
  if (searchMobile) {
    searchMobile.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-list .pend-item').forEach(card => {
        const nome = card.querySelector('.pend-title')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }

  // Filtro de busca — desktop
  const searchDesktop = document.querySelector('.revisao-search-desktop');
  if (searchDesktop) {
    searchDesktop.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-table tbody tr[data-tarefa-id]').forEach(row => {
        const nome = row.querySelector('.td--bold')?.textContent.toLowerCase() ?? '';
        row.style.display = nome.includes(termo) ? '' : 'none';
        const det = row.nextElementSibling;
        if (det && det.classList.contains('pend-detalhe')) det.setAttribute('hidden', '');
        const vm = row.querySelector('.ver-mais');
        if (vm) vm.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Sincroniza o contador com a quantidade real de tarefas pendentes ao abrir.
  atualizarBadgePendentes();
</script>

</body>
</html>
