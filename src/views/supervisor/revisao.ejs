<%- include('../partials/head', { title: title, css: css }) %>

<%#
  Variáveis esperadas pelo controller:
  - usuario: { nome: string }
  - css: ['supervisor']
%>

<!-- ============================================================
     TELA: Revisão de Tarefas
     Mobile  → TopNav com voltar + barra de busca com badge + lista de cards + BottomNav
     Desktop → Sidebar + TopBar + barra de busca + tabela com botão Revisar
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/supervisor/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Revisão de Tarefas</h1>
  </header>

  <p id="revisao-feedback-mobile" style="margin: 0 16px; font-size: 14px; line-height: 1.4;"></p>

  <!-- Barra de busca + badge -->
  <div class="revisao-filter-bar" role="search">
    <div class="revisao-search-wrap">
      <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="revisao-search"
        type="search"
        placeholder="Pesquisar tarefas"
        aria-label="Pesquisar tarefas"
      />
    </div>
    <span class="revisao-badge-pendentes">Pendentes</span>
  </div>

  <!-- Lista de tarefas -->
  <main class="revisao-list" role="main">

    <article class="rev-card rev-card--pendente" data-tarefa-id="11">
      <div class="rev-card__accent"></div>
      <div class="rev-card__body">
        <p class="rev-card__name">Conferência do rebanho — Aroeira</p>
        <p class="rev-card__meta">Capataz Lucas • há 1h</p>
      </div>
      <span class="rev-badge rev-badge--pendente">Pendente</span>
      <button class="rev-card__check rev-card__check--empty" aria-label="Marcar como concluída" data-action="aprovar">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="rev-card rev-card--pendente" data-tarefa-id="12">
      <div class="rev-card__accent"></div>
      <div class="rev-card__body">
        <p class="rev-card__name">Inspeção de cercas — CMB</p>
        <p class="rev-card__meta">Capataz Alberto • há 1h</p>
      </div>
      <span class="rev-badge rev-badge--pendente">Pendente</span>
      <button class="rev-card__check rev-card__check--empty" aria-label="Marcar como concluída" data-action="aprovar">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="rev-card rev-card--pendente" data-tarefa-id="13">
      <div class="rev-card__accent"></div>
      <div class="rev-card__body">
        <p class="rev-card__name">Movimentação de animais — Puga</p>
        <p class="rev-card__meta">Capataz Manoel • há 1 dia</p>
      </div>
      <span class="rev-badge rev-badge--pendente">Pendente</span>
      <button class="rev-card__check rev-card__check--empty" aria-label="Marcar como concluída" data-action="aprovar">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="rev-card rev-card--pendente" data-tarefa-id="14">
      <div class="rev-card__accent"></div>
      <div class="rev-card__body">
        <p class="rev-card__name">Alimentação suplementar — Caieira</p>
        <p class="rev-card__meta">Capataz João Paulo • há 1 dia</p>
      </div>
      <span class="rev-badge rev-badge--pendente">Pendente</span>
      <button class="rev-card__check rev-card__check--empty" aria-label="Marcar como concluída" data-action="aprovar">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="rev-card rev-card--pendente" data-tarefa-id="15">
      <div class="rev-card__accent"></div>
      <div class="rev-card__body">
        <p class="rev-card__name">Inspeção sanitária — Aroeira</p>
        <p class="rev-card__meta">Capataz Lucas • há 2 dias</p>
      </div>
      <span class="rev-badge rev-badge--pendente">Pendente</span>
      <button class="rev-card__check rev-card__check--empty" aria-label="Marcar como concluída" data-action="aprovar">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="rev-card rev-card--pendente" data-tarefa-id="16">
      <div class="rev-card__accent"></div>
      <div class="rev-card__body">
        <p class="rev-card__name">Contagem geral — Cristo</p>
        <p class="rev-card__meta">Capataz José Carlos • há 3 dias</p>
      </div>
      <span class="rev-badge rev-badge--pendente">Pendente</span>
      <button class="rev-card__check rev-card__check--empty" aria-label="Marcar como concluída" data-action="aprovar">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'revisao' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <!-- Sidebar -->
  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'revisao' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <h1 class="topbar__title">Revisão de Tarefas</h1>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <p id="revisao-feedback-desktop" style="margin: 0 0 16px; font-size: 14px; line-height: 1.4;"></p>

    <!-- Barra de busca + badge desktop -->
    <div class="revisao-filter-bar-desktop" role="search">
      <div class="revisao-search-wrap-desktop">
        <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          class="revisao-search-desktop"
          type="search"
          placeholder="Pesquisar tarefas"
          aria-label="Pesquisar tarefas"
        />
      </div>
      <span class="revisao-badge-pendentes revisao-badge-pendentes--desktop">6 Pendentes</span>
    </div>

    <!-- Tabela de tarefas -->
    <main class="desktop-content revisao-desktop-content" role="main">
      <div class="revisao-table-wrap">
        <table class="revisao-table" aria-label="Lista de tarefas para revisão">
          <thead>
            <tr>
              <th>Tarefa</th>
              <th>Retiro</th>
              <th>Capataz</th>
              <th>Há quanto tempo</th>
              <th>Status</th>
              <th></th><!-- check -->
              <th>Ação</th>
            </tr>
          </thead>
          <tbody>
            <tr data-tarefa-id="11">
              <td class="td--bold">Conferência do rebanho</td>
              <td>Aroeira</td>
              <td>Capataz Lucas</td>
              <td>há 1h</td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><img src="/assets/icons/unchecked.svg" alt="pendente" width="24" height="24" /></td>
              <td><button class="btn-revisar" data-action="aprovar">Check</button></td>
            </tr>
            <tr class="tr--alt" data-tarefa-id="12">
              <td class="td--bold">Inspeção de cercas</td>
              <td>CMB</td>
              <td>Capataz Alberto</td>
              <td>há 1h</td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><img src="/assets/icons/unchecked.svg" alt="pendente" width="24" height="24" /></td>
              <td><button class="btn-revisar" data-action="aprovar">Check</button></td>
            </tr>
            <tr data-tarefa-id="13">
              <td class="td--bold">Movimentação de animais</td>
              <td>Puga</td>
              <td>Capataz Manoel</td>
              <td>há 1 dia</td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><img src="/assets/icons/unchecked.svg" alt="pendente" width="24" height="24" /></td>
              <td><button class="btn-revisar" data-action="aprovar">Check</button></td>
            </tr>
            <tr class="tr--alt" data-tarefa-id="14">
              <td class="td--bold">Alimentação suplementar</td>
              <td>Caieira</td>
              <td>Capataz João Paulo</td>
              <td>há 1 dia</td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><img src="/assets/icons/unchecked.svg" alt="pendente" width="24" height="24" /></td>
              <td><button class="btn-revisar" data-action="aprovar">Check</button></td>
            </tr>
            <tr data-tarefa-id="15">
              <td class="td--bold">Inspeção sanitária</td>
              <td>Aroeira</td>
              <td>Capataz Lucas</td>
              <td>há 2 dias</td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><img src="/assets/icons/unchecked.svg" alt="pendente" width="24" height="24" /></td>
              <td><button class="btn-revisar" data-action="aprovar">Check</button></td>
            </tr>
            <tr class="tr--alt" data-tarefa-id="16">
              <td class="td--bold">Contagem geral</td>
              <td>Cristo</td>
              <td>Capataz José Carlos</td>
              <td>há 3 dias</td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><img src="/assets/icons/unchecked.svg" alt="pendente" width="24" height="24" /></td>
              <td><button class="btn-revisar" data-action="aprovar">Check</button></td>
            </tr>
          </tbody>
        </table>
      </div>
    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  function carregarSessao() {
    try {
      const token = localStorage.getItem('agroflow.token');
      const usuarioRaw = localStorage.getItem('agroflow.usuario');
      if (!token || !usuarioRaw) return null;
      return { token, usuario: JSON.parse(usuarioRaw) };
    } catch {
      return null;
    }
  }

  function mostrarFeedback(id, mensagem, tipo) {
    const feedback = document.getElementById(id);
    if (!feedback) return;
    feedback.textContent = mensagem;
    feedback.style.color = tipo === 'error' ? '#b42318' : '#146c43';
  }

  function atualizarCardMobile(card, aprovado) {
    const badge = card.querySelector('.rev-badge');
    const btn = card.querySelector('.rev-card__check');
    const img = btn?.querySelector('img');

    if (!badge || !btn || !img) return;

    if (aprovado) {
      btn.classList.replace('rev-card__check--empty', 'rev-card__check--done');
      btn.setAttribute('aria-label', 'Concluída');
      img.src = IMG_MOBILE_FEITO;
      badge.classList.replace('rev-badge--pendente', 'rev-badge--concluido');
      badge.textContent = 'Concluído';
      card.classList.replace('rev-card--pendente', 'rev-card--concluido');
    } else {
      btn.classList.replace('rev-card__check--done', 'rev-card__check--empty');
      btn.setAttribute('aria-label', 'Marcar como concluída');
      img.src = IMG_MOBILE_VAZIO;
      badge.classList.replace('rev-badge--concluido', 'rev-badge--pendente');
      badge.textContent = 'Pendente';
      card.classList.replace('rev-card--concluido', 'rev-card--pendente');
    }
  }

  function atualizarLinhaDesktop(row, aprovado) {
    const badge = row.querySelector('.badge');
    const btn = row.querySelector('.btn-revisar');
    const img = row.querySelector('td img');

    if (!badge || !btn || !img) return;

    if (aprovado) {
      img.src = IMG_DESK_CONCLUIDO;
      img.alt = 'concluído';
      badge.classList.replace('badge--yellow', 'badge--green');
      badge.textContent = 'Concluído';
      btn.textContent = 'Uncheck';
    } else {
      img.src = IMG_DESK_PENDENTE;
      img.alt = 'pendente';
      badge.classList.replace('badge--green', 'badge--yellow');
      badge.textContent = 'Pendente';
      btn.textContent = 'Check';
    }
  }

  async function aprovarTarefaPorId(tarefaId) {
    const response = await fetch(`/validacoes/tarefas/${tarefaId}/aprovar`, {
      method: 'PATCH',
    });

    const data = await response.json().catch(() => ({}));
    if (!response.ok) {
      return { ok: false, mensagem: data.error || data.mensagem || 'Não foi possível aprovar a tarefa' };
    }

    return { ok: true, mensagem: data.mensagem || 'Tarefa aprovada com sucesso.' };
  }

  // ── Toggle check mobile ──
  const IMG_MOBILE_VAZIO   = '/assets/icons/unchecked.svg';
  const IMG_MOBILE_FEITO   = '/assets/icons/checked.svg';

  document.querySelectorAll('.rev-card__check').forEach(btn => {
    btn.addEventListener('click', async () => {
      const card = btn.closest('.rev-card');
      if (!card) return;
      const concluido = btn.classList.contains('rev-card__check--done');
      atualizarCardMobile(card, !concluido);
      if (!concluido) await aprovarTarefaPorId(card.dataset.tarefaId);
    });
  });

  // ── Toggle check desktop ──
  const IMG_DESK_PENDENTE  = '/assets/icons/unchecked.svg';
  const IMG_DESK_CONCLUIDO = '/assets/icons/checked.svg';

  async function toggleLinhaDesktop(row) {
    const btn = row.querySelector('.btn-revisar');
    const concluido = btn?.textContent.trim() === 'Uncheck';
    atualizarLinhaDesktop(row, !concluido);
    if (!concluido) await aprovarTarefaPorId(row.dataset.tarefaId);
  }

  document.querySelectorAll('.revisao-table td img').forEach(img => {
    img.classList.add('check-img');
    img.addEventListener('click', () => {
      const row = img.closest('tr');
      if (row) toggleLinhaDesktop(row);
    });
  });

  document.querySelectorAll('.btn-revisar').forEach(btn => {
    btn.addEventListener('click', () => {
      const row = btn.closest('tr');
      if (row) toggleLinhaDesktop(row);
    });
  });

  // Filtro de busca — mobile
  const searchMobile = document.querySelector('.revisao-search');
  if (searchMobile) {
    searchMobile.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-list .rev-card').forEach(card => {
        const nome = card.querySelector('.rev-card__name')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }

  // Filtro de busca — desktop
  const searchDesktop = document.querySelector('.revisao-search-desktop');
  if (searchDesktop) {
    searchDesktop.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-table tbody tr').forEach(row => {
        const nome = row.querySelector('.td--bold')?.textContent.toLowerCase() ?? '';
        row.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }
</script>

</body>
</html>
