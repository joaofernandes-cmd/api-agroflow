<%- include('../partials/head', { title: title, css: css }) %>

<%#
  Variáveis esperadas pelo controller:
  - usuario: { nome: string }
  - css: ['supervisor']
%>

<!-- ============================================================
     TELA: Tickets de infraestrutura
     Mobile  → TopNav com voltar + filtro com badge + lista de cards + BottomNav
     Desktop → Sidebar + TopBar + barra de busca + tabela com botão Atender/Ver
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/supervisor/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Tickets de infraestrutura</h1>
  </header>

  <!-- Barra de busca + badge -->
  <div class="tickets-filter-bar" role="search">
    <div class="revisao-search-wrap">
      <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="tickets-search"
        type="search"
        placeholder="Pesquisar chamados"
        aria-label="Pesquisar chamados"
      />
    </div>
    <span class="tickets-badge-ativos">3 ativos</span>
  </div>

  <!-- Lista de tickets -->
  <main class="tickets-list" role="main">

    <article class="ticket-card ticket-card--red">
      <div class="ticket-card__accent ticket-card__accent--red"></div>
      <div class="ticket-card__body">
        <p class="ticket-card__name">Cerca danificada no pasto</p>
        <p class="ticket-card__meta">Puga • Hoje, 08:24</p>
      </div>
      <span class="sev-badge sev-badge--alta">Alta</span>
      <button class="ticket-card__check" aria-label="Marcar como resolvido">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="ticket-card ticket-card--yellow">
      <div class="ticket-card__accent ticket-card__accent--yellow"></div>
      <div class="ticket-card__body">
        <p class="ticket-card__name">Estoque de ração abaixo do mínimo</p>
        <p class="ticket-card__meta">Bodoquena 1 • Hoje, 10:45</p>
      </div>
      <span class="sev-badge sev-badge--media">Média</span>
      <button class="ticket-card__check" aria-label="Marcar como resolvido">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="ticket-card ticket-card--red">
      <div class="ticket-card__accent ticket-card__accent--red"></div>
      <div class="ticket-card__body">
        <p class="ticket-card__name">Bomba d'água com falha</p>
        <p class="ticket-card__meta">Cristo • Amanhã</p>
      </div>
      <span class="sev-badge sev-badge--alta">Alta</span>
      <button class="ticket-card__check" aria-label="Marcar como resolvido">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="ticket-card ticket-card--red">
      <div class="ticket-card__accent ticket-card__accent--red"></div>
      <div class="ticket-card__body">
        <p class="ticket-card__name">Bebedouro com defeito</p>
        <p class="ticket-card__meta">CMB • em 3 dias</p>
      </div>
      <span class="sev-badge sev-badge--alta">Alta</span>
      <button class="ticket-card__check" aria-label="Marcar como resolvido">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="ticket-card ticket-card--blue">
      <div class="ticket-card__accent ticket-card__accent--blue"></div>
      <div class="ticket-card__body">
        <p class="ticket-card__name">Veículo do retiro sem manutenção</p>
        <p class="ticket-card__meta">Bodoquena 2 • há 5 dias</p>
      </div>
      <span class="sev-badge sev-badge--baixa">Baixa</span>
      <button class="ticket-card__check" aria-label="Resolvido">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

    <article class="ticket-card ticket-card--yellow">
      <div class="ticket-card__accent ticket-card__accent--yellow"></div>
      <div class="ticket-card__body">
        <p class="ticket-card__name">Gerador sem combustível</p>
        <p class="ticket-card__meta">Bodoquena 1 • em 4 dias</p>
      </div>
      <span class="sev-badge sev-badge--media">Média</span>
      <button class="ticket-card__check" aria-label="Marcar como resolvido">
        <img src="/assets/icons/unchecked.svg" alt="" width="24" height="24" />
      </button>
    </article>

  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'tickets' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <!-- Sidebar -->
  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'tickets' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <h1 class="topbar__title">Tickets de Infraestrutura</h1>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <!-- Barra de busca + badge desktop -->
    <div class="tickets-filter-bar-desktop" role="search">
      <div class="revisao-search-wrap-desktop">
        <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          class="revisao-search-desktop"
          type="search"
          placeholder="Buscar chamados..."
          aria-label="Buscar chamados"
        />
      </div>
      <span class="tickets-badge-ativos tickets-badge-ativos--desktop">3 Ativos</span>
    </div>

    <!-- Tabela de tickets -->
    <main class="desktop-content revisao-desktop-content" role="main">
      <div class="revisao-table-wrap">
        <table class="revisao-table" aria-label="Lista de tickets de infraestrutura">
          <thead>
            <tr>
              <th class="td--accent"></th>
              <th>Chamado</th>
              <th>Retiro</th>
              <th>Data/Hora</th>
              <th>Severidade</th>
              <th>Status</th>
              <th>Ação</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="td--accent td--accent-red"></td>
              <td class="td--bold">Cerca danificada no pasto</td>
              <td>Puga</td>
              <td>Hoje, 08:24</td>
              <td><span class="badge badge--red-soft">Alta</span></td>
              <td><span class="badge badge--red-soft">Ativo</span></td>
              <td><button class="btn-validar">Validar</button></td>
            </tr>
            <tr class="tr--alt">
              <td class="td--accent td--accent-yellow"></td>
              <td class="td--bold">Estoque de ração abaixo do mínimo</td>
              <td>Bodoquena 1</td>
              <td>Hoje, 10:45</td>
              <td><span class="badge badge--yellow">Média</span></td>
              <td><span class="badge badge--red-soft">Ativo</span></td>
              <td><button class="btn-validar">Validar</button></td>
            </tr>
            <tr>
              <td class="td--accent td--accent-red"></td>
              <td class="td--bold">Bomba d'água com falha</td>
              <td>Cristo</td>
              <td>Amanhã</td>
              <td><span class="badge badge--red-soft">Alta</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar">Validar</button></td>
            </tr>
            <tr class="tr--alt">
              <td class="td--accent td--accent-red"></td>
              <td class="td--bold">Bebedouro com defeito</td>
              <td>CMB</td>
              <td>em 3 dias</td>
              <td><span class="badge badge--red-soft">Alta</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar">Validar</button></td>
            </tr>
            <tr>
              <td class="td--accent td--accent-blue"></td>
              <td class="td--bold">Veículo do retiro sem manutenção</td>
              <td>Bodoquena 2</td>
              <td>há 5 dias</td>
              <td><span class="badge badge--blue">Baixa</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar">Validar</button></td>
            </tr>
            <tr class="tr--alt">
              <td class="td--accent td--accent-yellow"></td>
              <td class="td--bold">Gerador sem combustível</td>
              <td>Bodoquena 1</td>
              <td>em 4 dias</td>
              <td><span class="badge badge--yellow">Média</span></td>
              <td><span class="badge badge--red-soft">Ativo</span></td>
              <td><button class="btn-validar">Validar</button></td>
            </tr>
          </tbody>
        </table>
      </div>
    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  // Toggle check mobile
  document.querySelectorAll('.ticket-card__check').forEach(btn => {
    btn.addEventListener('click', () => {
      const img = btn.querySelector('img');
      if (!img) return;
      const checked = img.src.includes('checked.svg') && !img.src.includes('unchecked.svg');
      img.src = checked ? '/assets/icons/unchecked.svg' : '/assets/icons/checked.svg';
      btn.setAttribute('aria-label', checked ? 'Marcar como resolvido' : 'Resolvido');
    });
  });

  // Toggle Validar → Confirmado
  document.querySelectorAll('.btn-validar').forEach(btn => {
    btn.addEventListener('click', () => {
      const row = btn.closest('tr');
      if (!row) return;
      const statusCell = row.querySelector('td:nth-child(6) .badge');
      if (statusCell) {
        statusCell.className = 'badge badge--green';
        statusCell.textContent = 'Resolvido';
      }
      btn.className = 'btn-confirmado';
      btn.textContent = 'Confirmado';
    });
  });

  // Filtro de busca — mobile
  const searchMobile = document.querySelector('.tickets-search');
  if (searchMobile) {
    searchMobile.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.tickets-list .ticket-card').forEach(card => {
        const nome = card.querySelector('.ticket-card__name')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }

  // Filtro de busca — desktop
  const searchDesktop = document.querySelector('.revisao-search-desktop');
  if (searchDesktop) {
    searchDesktop.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-table tbody tr').forEach(row => {
        const nome = row.querySelector('.td--bold')?.textContent.toLowerCase() ?? '';
        row.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }
</script>

</body>
</html>
