<%- include('../partials/head', { title: title, css: css }) %>

<%#
  Variáveis esperadas pelo controller:
  - usuario: { nome: string }
  - css: ['supervisor']
%>

<!-- ============================================================
     TELA: Tickets de infraestrutura
     Mobile  → TopNav com voltar + filtro + lista de tickets + BottomNav
     Desktop → Sidebar + TopBar + busca + tabela com botão Validar
     Validar move o ticket para a seção "Validados" (mais recente no topo).
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/supervisor/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Tickets de infraestrutura</h1>
  </header>

  <!-- Barra de busca + badge -->
  <div class="tickets-filter-bar" role="search">
    <div class="revisao-search-wrap">
      <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="tickets-search"
        type="search"
        placeholder="Pesquisar tickets"
        aria-label="Pesquisar tickets"
      />
    </div>
    <span class="tickets-badge-ativos"><%= tickets.length %> Pendentes</span>
  </div>

  <!-- Lista de tickets -->
  <main class="tickets-list" role="main">

    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Tickets pendentes</h2>
      <p class="lista-secao__sub">Aguardando sua validação</p>

      <div id="tickets-ativos">
        <% tickets.forEach(function (t) { %>
        <div class="pend-item" data-ticket="<%= t.id %>" data-nome="<%= t.nome %>" data-retiro="<%= t.retiro %>" data-quando="<%= t.quando %>" data-sev="<%= t.severidade %>">
          <div class="pend-head">
            <span class="pend-title"><span class="sev-badge sev-badge--<%= t.sevClasse %>"><%= t.severidade %></span> <%= t.nome %></span>
            <button class="btn-revisar" data-action="validar">Validar</button>
            <button class="pend-toggle" type="button" aria-expanded="false" aria-label="Ver informações">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
          </div>
          <div class="pend-panel">
            <div class="pend-panel__inner">
              <p class="pend-info"><strong>Retiro:</strong> <%= t.retiro %><br><strong>Quando:</strong> <%= t.quando %><br><strong>Severidade:</strong> <%= t.severidade %><br><strong>Evidência:</strong> <%= t.evidencia %><br><strong>Descrição:</strong> <%= t.descricao %></p>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>

    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Validados</h2>
      <p class="lista-secao__sub">Tickets que você já validou</p>
      <div class="tickets-concluidas"></div>
    </section>

  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'tickets' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <!-- Sidebar -->
  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'tickets' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <div class="topbar__lead">
        <h1 class="topbar__title">Tickets de Infraestrutura</h1>
      </div>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <!-- Barra de busca + badge desktop -->
    <div class="tickets-filter-bar-desktop" role="search">
      <div class="revisao-search-wrap-desktop">
        <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          class="revisao-search-desktop"
          type="search"
          placeholder="Buscar tickets..."
          aria-label="Buscar tickets"
        />
      </div>
      <span class="tickets-badge-ativos tickets-badge-ativos--desktop"><%= tickets.length %> Pendentes</span>
    </div>

    <!-- Tabela de tickets -->
    <main class="desktop-content revisao-desktop-content" role="main">
      <section class="lista-secao">
        <h2 class="lista-secao__titulo">Tickets pendentes</h2>
        <p class="lista-secao__sub">Aguardando sua validação</p>
      </section>
      <div class="revisao-table-wrap">
        <table class="revisao-table" aria-label="Tickets pendentes">
          <thead>
            <tr>
              <th>Ticket</th>
              <th>Retiro</th>
              <th>Data/Hora</th>
              <th>Severidade</th>
              <th>Status</th>
              <th></th><!-- ver mais -->
              <th>Ação</th>
            </tr>
          </thead>
          <tbody id="tickets-ativos-tbody">
            <%
              function escHtmlTk(s){ return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
              function evidenciaBlocoTicket(t){
                if (t.evidencia === 'Texto') {
                  return '<p class="evidencia-texto">' + escHtmlTk(t.evidenciaTexto) + '</p>';
                }
                var isAudio = t.evidencia === 'Áudio';
                var icone = isAudio
                  ? '<path d="M12 2a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v1a7 7 0 0 1-14 0v-1"/><line x1="12" x2="12" y1="18" y2="22"/>'
                  : '<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/>';
                return '<div class="evidencia ' + (isAudio ? 'evidencia--audio' : 'evidencia--foto') + '">' +
                  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + icone + '</svg>' +
                  '<span class="evidencia__tipo">' + escHtmlTk(t.evidencia) + '</span></div>';
              }
            %>
            <% tickets.forEach(function (t, i) { %>
            <tr<%- i % 2 === 1 ? ' class="tr--alt"' : '' %> data-ticket="<%= t.id %>">
              <td class="td--bold"><%= t.nome %></td>
              <td><%= t.retiro %></td>
              <td><%= t.quando %></td>
              <td><span class="badge <%= t.badgeClasse %>"><%= t.severidade %></span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="ver-mais" type="button" aria-expanded="false">Ver mais <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button></td>
              <td><button class="btn-validar" data-action="validar">Validar</button></td>
            </tr>
            <tr class="pend-detalhe" hidden>
              <td colspan="7">
                <div class="pend-detalhe__inner">
                  <div class="concl-bloco">
                    <span class="concl-bloco__label">Descrição</span>
                    <p class="concl-bloco__texto"><%= t.descricao %></p>
                  </div>
                  <div class="concl-bloco">
                    <span class="concl-bloco__label">Evidência</span>
                    <%- evidenciaBlocoTicket(t) %>
                  </div>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <section class="lista-secao">
        <h2 class="lista-secao__titulo">Validados</h2>
        <p class="lista-secao__sub">Tickets que você já validou</p>
        <div class="tickets-concluidas"></div>
      </section>
    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script src="/js/contadores-pendentes.js"></script>
<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  // Recalcula o contador "N Pendentes" ao lado da busca conforme os tickets
  // vão sendo validados (some um de cima → o número cai).
  function atualizarBadgePendentes() {
    const nMobile = document.querySelectorAll('#tickets-ativos .pend-item').length;
    const nDesktop = document.querySelectorAll('#tickets-ativos-tbody tr[data-ticket]').length;
    const badgeMobile = document.querySelector('.layout-mobile .tickets-badge-ativos');
    const badgeDesktop = document.querySelector('.layout-desktop .tickets-badge-ativos');
    if (badgeMobile) badgeMobile.textContent = nMobile + (nMobile === 1 ? ' Pendente' : ' Pendentes');
    if (badgeDesktop) badgeDesktop.textContent = nDesktop + (nDesktop === 1 ? ' Pendente' : ' Pendentes');
    // Espelha o total na home (bloco "Tickets" do Acesso rápido).
    if (window.ContadoresPendentes) ContadoresPendentes.definirDoLayout('tickets', nMobile, nDesktop);
  }

  function escaparHTML(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  // Momento da validação (DD/MM/AAAA HH:MM) e nome do supervisor logado.
  function agoraFormatado() {
    return new Date().toLocaleString('pt-BR', {
      day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
    });
  }
  function nomeSupervisor() {
    try {
      const u = JSON.parse(localStorage.getItem('agroflow.usuario') || '{}');
      return (u && u.nome) ? u.nome.split(' ')[0] : 'Luiz Felipe';
    } catch (e) { return 'Luiz Felipe'; }
  }
  function sevClasse(sev) {
    const s = (sev || '').toLowerCase();
    if (s.indexOf('alta') >= 0) return 'alta';
    if (s.indexOf('méd') >= 0 || s.indexOf('med') >= 0) return 'media';
    return 'baixa';
  }
  // Card de evidência (mesmo visual das tarefas): foto/áudio com ícone, texto com a nota.
  function evidenciaHTML(tipo, texto) {
    if (tipo === 'Texto') return '<p class="evidencia-texto">' + escaparHTML(texto || '') + '</p>';
    const isAudio = tipo === 'Áudio';
    const icone = isAudio
      ? '<path d="M12 2a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v1a7 7 0 0 1-14 0v-1"/><line x1="12" x2="12" y1="18" y2="22"/>'
      : '<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/>';
    return '<div class="evidencia ' + (isAudio ? 'evidencia--audio' : 'evidencia--foto') + '">' +
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + icone + '</svg>' +
      '<span class="evidencia__tipo">' + escaparHTML(tipo) + '</span></div>';
  }

  // Descrição + evidência de cada ticket (fonte única, vinda do servidor —
  // o mesmo módulo que renderiza a lista acima).
  const TICKETS_DADOS = <%- JSON.stringify(ticketsDados) %>;

  // Tickets já validados (em memória) — mais recente no topo.
  const ticketsValidados = [];

  // Renderiza os tickets validados como "varas" que abrem na setinha,
  // no mesmo padrão das tarefas validadas (nome + selo + ver mais; sem Ação).
  function renderTicketsValidados() {
    document.querySelectorAll('.tickets-concluidas').forEach(function (container) {
      container.replaceChildren();
      if (!ticketsValidados.length) {
        const vazio = document.createElement('p');
        vazio.className = 'concl-vazio';
        vazio.textContent = 'Nenhum ticket validado ainda.';
        container.appendChild(vazio);
        return;
      }
      ticketsValidados.forEach(function (t) {
        const titulo = t.nome + (t.retiro ? ' — ' + t.retiro : '');

        const item = document.createElement('div');
        item.className = 'concl-item';

        const head = document.createElement('button');
        head.type = 'button';
        head.className = 'concl-head';
        head.setAttribute('aria-expanded', 'false');
        head.innerHTML =
          '<span class="concl-title"></span>' +
          '<span class="concl-badge">Validado</span>' +
          '<span class="concl-arrow" aria-hidden="true">' +
            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>' +
          '</span>';
        head.querySelector('.concl-title').textContent = titulo;

        const panel = document.createElement('div');
        panel.className = 'concl-panel';
        const inner = document.createElement('div');
        inner.className = 'concl-panel__inner';

        // Severidade em destaque (mesmo selo das prioridades das tarefas)
        if (t.severidade) {
          const tags = document.createElement('div');
          tags.className = 'concl-tags';
          const prio = document.createElement('span');
          prio.className = 'concl-prio concl-prio--' + sevClasse(t.severidade);
          prio.textContent = t.severidade;
          tags.appendChild(prio);
          inner.appendChild(tags);
        }

        // Quando foi validado + por quem
        const metaParts = [];
        if (t.dataValidacao) metaParts.push('Validado em ' + t.dataValidacao);
        if (t.supervisor) metaParts.push('Supervisor ' + t.supervisor);
        if (metaParts.length) {
          const meta = document.createElement('p');
          meta.className = 'concl-meta';
          meta.textContent = metaParts.join(' • ');
          inner.appendChild(meta);
        }

        // Descrição
        if (t.descricao) {
          const desc = document.createElement('div');
          desc.className = 'concl-bloco';
          const label = document.createElement('span');
          label.className = 'concl-bloco__label';
          label.textContent = 'Descrição';
          const texto = document.createElement('p');
          texto.className = 'concl-bloco__texto';
          texto.textContent = t.descricao;
          desc.appendChild(label);
          desc.appendChild(texto);
          inner.appendChild(desc);
        }

        // Evidência
        if (t.evidencia) {
          const ev = document.createElement('div');
          ev.className = 'concl-bloco';
          ev.innerHTML = '<span class="concl-bloco__label">Evidência</span>' + evidenciaHTML(t.evidencia, t.evidenciaTexto);
          inner.appendChild(ev);
        }

        panel.appendChild(inner);

        item.appendChild(head);
        item.appendChild(panel);
        container.appendChild(item);

        head.addEventListener('click', function () {
          const aberto = item.classList.toggle('is-open');
          head.setAttribute('aria-expanded', aberto ? 'true' : 'false');
        });
      });
    });
  }

  // Marca um ticket como validado: tira da lista de pendentes e mostra
  // como "vara" na seção Validados.
  function validarTicket(dados, origem) {
    dados.dataValidacao = agoraFormatado();
    dados.supervisor = nomeSupervisor();
    ticketsValidados.unshift(dados);
    if (origem) origem.remove();
    renderTicketsValidados();
    atualizarBadgePendentes();
    // Persiste no servidor: remove o ticket dos pendentes em memória, para o
    // contador (tela + home) continuar certo depois de recarregar.
    if (dados.id) {
      fetch('/supervisor/tickets/' + encodeURIComponent(dados.id) + '/validar', { method: 'POST' })
        .catch(function () {});
    }
  }

  // Validar (vara mobile): tira de pendentes e desce para Validados
  function validarPendItem(item) {
    if (!item || item.dataset.validado) return;
    item.dataset.validado = '1';
    const extra = TICKETS_DADOS[item.dataset.ticket] || {};
    validarTicket({
      id: item.dataset.ticket,
      nome: item.dataset.nome || (item.querySelector('.pend-title')?.textContent || 'Ticket').trim(),
      retiro: item.dataset.retiro || '',
      data: item.dataset.quando || '',
      severidade: item.dataset.sev || '',
      descricao: extra.descricao || '',
      evidencia: extra.evidencia || '',
      evidenciaTexto: extra.evidenciaTexto || '',
    }, item);
  }

  // Validar (linha desktop): remove a linha e a sua linha de detalhe
  function validarLinhaDesktop(row) {
    if (!row || row.dataset.validado) return;
    row.dataset.validado = '1';
    const cells = row.querySelectorAll('td');
    const det = row.nextElementSibling;
    const extra = TICKETS_DADOS[row.dataset.ticket] || {};
    validarTicket({
      id: row.dataset.ticket,
      nome: (row.querySelector('.td--bold')?.textContent || 'Ticket').trim(),
      retiro: (cells[1]?.textContent || '').trim(),
      data: (cells[2]?.textContent || '').trim(),
      severidade: (cells[3]?.querySelector('.badge')?.textContent || '').trim(),
      descricao: extra.descricao || '',
      evidencia: extra.evidencia || '',
      evidenciaTexto: extra.evidenciaTexto || '',
    }, row);
    if (det && det.classList.contains('pend-detalhe')) det.remove();
  }

  // Botão "Validar" (vara mobile ou linha desktop)
  document.querySelectorAll('[data-action="validar"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.pend-item');
      if (item) { validarPendItem(item); return; }
      validarLinhaDesktop(btn.closest('tr'));
    });
  });

  // Setinha: abre/fecha as informações do ticket pendente (mobile)
  document.querySelectorAll('.pend-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.pend-item');
      if (!item) return;
      const aberto = item.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', aberto ? 'true' : 'false');
    });
  });

  // "Ver mais" (desktop): abre a linha de detalhe com a descrição + evidência
  document.querySelectorAll('.ver-mais').forEach(btn => {
    btn.addEventListener('click', () => {
      const det = btn.closest('tr')?.nextElementSibling;
      if (!det || !det.classList.contains('pend-detalhe')) return;
      const abrindo = det.hasAttribute('hidden');
      det.toggleAttribute('hidden');
      btn.setAttribute('aria-expanded', abrindo ? 'true' : 'false');
    });
  });

  // Estado inicial: contador e lista de validados (vazia) ao abrir.
  atualizarBadgePendentes();
  renderTicketsValidados();

  // Filtro de busca — mobile
  const searchMobile = document.querySelector('.tickets-search');
  if (searchMobile) {
    searchMobile.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.tickets-list .pend-item').forEach(card => {
        const nome = card.querySelector('.pend-title')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }

  // Filtro de busca — desktop
  const searchDesktop = document.querySelector('.revisao-search-desktop');
  if (searchDesktop) {
    searchDesktop.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-table tbody tr[data-ticket]').forEach(row => {
        const nome = row.querySelector('.td--bold')?.textContent.toLowerCase() ?? '';
        row.style.display = nome.includes(termo) ? '' : 'none';
        const det = row.nextElementSibling;
        if (det && det.classList.contains('pend-detalhe')) det.setAttribute('hidden', '');
        const vm = row.querySelector('.ver-mais');
        if (vm) vm.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>

</body>
</html>
