<%- include('../partials/head', { title: title, css: css }) %>

<%#
  Variáveis esperadas pelo controller:
  - usuario: { nome: string }
  - css: ['supervisor']
%>

<!-- ============================================================
     TELA: Tickets de infraestrutura
     Mobile  → TopNav com voltar + filtro + lista de chamados + BottomNav
     Desktop → Sidebar + TopBar + busca + tabela com botão Validar
     Validar move o chamado para a seção "Validados" (mais recente no topo).
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/supervisor/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Tickets de infraestrutura</h1>
  </header>

  <!-- Barra de busca + badge -->
  <div class="tickets-filter-bar" role="search">
    <div class="revisao-search-wrap">
      <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="tickets-search"
        type="search"
        placeholder="Pesquisar chamados"
        aria-label="Pesquisar chamados"
      />
    </div>
    <span class="tickets-badge-ativos">6 Pendentes</span>
  </div>

  <!-- Lista de tickets -->
  <main class="tickets-list" role="main">

    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Chamados pendentes</h2>
      <p class="lista-secao__sub">Aguardando sua validação</p>

      <div id="tickets-ativos">
        <article class="ticket-card ticket-card--red" data-ticket="1">
          <div class="ticket-card__accent ticket-card__accent--red"></div>
          <div class="ticket-card__body">
            <p class="ticket-card__name">Cerca danificada no pasto</p>
            <p class="ticket-card__meta">Puga • Hoje, 08:24</p>
          </div>
          <span class="sev-badge sev-badge--alta">Alta</span>
          <button class="btn-revisar" data-action="validar">Validar</button>
        </article>

        <article class="ticket-card ticket-card--yellow" data-ticket="2">
          <div class="ticket-card__accent ticket-card__accent--yellow"></div>
          <div class="ticket-card__body">
            <p class="ticket-card__name">Estoque de ração abaixo do mínimo</p>
            <p class="ticket-card__meta">Bodoquena 1 • Hoje, 10:45</p>
          </div>
          <span class="sev-badge sev-badge--media">Média</span>
          <button class="btn-revisar" data-action="validar">Validar</button>
        </article>

        <article class="ticket-card ticket-card--red" data-ticket="3">
          <div class="ticket-card__accent ticket-card__accent--red"></div>
          <div class="ticket-card__body">
            <p class="ticket-card__name">Bomba d'água com falha</p>
            <p class="ticket-card__meta">Cristo • Amanhã</p>
          </div>
          <span class="sev-badge sev-badge--alta">Alta</span>
          <button class="btn-revisar" data-action="validar">Validar</button>
        </article>

        <article class="ticket-card ticket-card--red" data-ticket="4">
          <div class="ticket-card__accent ticket-card__accent--red"></div>
          <div class="ticket-card__body">
            <p class="ticket-card__name">Bebedouro com defeito</p>
            <p class="ticket-card__meta">CMB • em 3 dias</p>
          </div>
          <span class="sev-badge sev-badge--alta">Alta</span>
          <button class="btn-revisar" data-action="validar">Validar</button>
        </article>

        <article class="ticket-card ticket-card--blue" data-ticket="5">
          <div class="ticket-card__accent ticket-card__accent--blue"></div>
          <div class="ticket-card__body">
            <p class="ticket-card__name">Veículo do retiro sem manutenção</p>
            <p class="ticket-card__meta">Bodoquena 2 • há 5 dias</p>
          </div>
          <span class="sev-badge sev-badge--baixa">Baixa</span>
          <button class="btn-revisar" data-action="validar">Validar</button>
        </article>

        <article class="ticket-card ticket-card--yellow" data-ticket="6">
          <div class="ticket-card__accent ticket-card__accent--yellow"></div>
          <div class="ticket-card__body">
            <p class="ticket-card__name">Gerador sem combustível</p>
            <p class="ticket-card__meta">Bodoquena 1 • em 4 dias</p>
          </div>
          <span class="sev-badge sev-badge--media">Média</span>
          <button class="btn-revisar" data-action="validar">Validar</button>
        </article>
      </div>
    </section>

    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Validados</h2>
      <p class="lista-secao__sub">Chamados que você já validou</p>
      <div class="tickets-concluidas"></div>
    </section>

  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'tickets' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <!-- Sidebar -->
  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'tickets' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <div class="topbar__lead">
        <h1 class="topbar__title">Tickets de Infraestrutura</h1>
      </div>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <!-- Barra de busca + badge desktop -->
    <div class="tickets-filter-bar-desktop" role="search">
      <div class="revisao-search-wrap-desktop">
        <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          class="revisao-search-desktop"
          type="search"
          placeholder="Buscar chamados..."
          aria-label="Buscar chamados"
        />
      </div>
      <span class="tickets-badge-ativos tickets-badge-ativos--desktop">6 Pendentes</span>
    </div>

    <!-- Tabela de tickets -->
    <main class="desktop-content revisao-desktop-content" role="main">
      <section class="lista-secao">
        <h2 class="lista-secao__titulo">Chamados pendentes</h2>
        <p class="lista-secao__sub">Aguardando sua validação</p>
      </section>
      <div class="revisao-table-wrap">
        <table class="revisao-table" aria-label="Chamados pendentes">
          <thead>
            <tr>
              <th>Chamado</th>
              <th>Retiro</th>
              <th>Data/Hora</th>
              <th>Severidade</th>
              <th>Status</th>
              <th>Ação</th>
            </tr>
          </thead>
          <tbody id="tickets-ativos-tbody">
            <tr>
              <td class="td--bold">Cerca danificada no pasto</td>
              <td>Puga</td>
              <td>Hoje, 08:24</td>
              <td><span class="badge badge--red-soft">Alta</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar" data-action="validar">Validar</button></td>
            </tr>
            <tr class="tr--alt">
              <td class="td--bold">Estoque de ração abaixo do mínimo</td>
              <td>Bodoquena 1</td>
              <td>Hoje, 10:45</td>
              <td><span class="badge badge--yellow">Média</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar" data-action="validar">Validar</button></td>
            </tr>
            <tr>
              <td class="td--bold">Bomba d'água com falha</td>
              <td>Cristo</td>
              <td>Amanhã</td>
              <td><span class="badge badge--red-soft">Alta</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar" data-action="validar">Validar</button></td>
            </tr>
            <tr class="tr--alt">
              <td class="td--bold">Bebedouro com defeito</td>
              <td>CMB</td>
              <td>em 3 dias</td>
              <td><span class="badge badge--red-soft">Alta</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar" data-action="validar">Validar</button></td>
            </tr>
            <tr>
              <td class="td--bold">Veículo do retiro sem manutenção</td>
              <td>Bodoquena 2</td>
              <td>há 5 dias</td>
              <td><span class="badge badge--blue">Baixa</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar" data-action="validar">Validar</button></td>
            </tr>
            <tr class="tr--alt">
              <td class="td--bold">Gerador sem combustível</td>
              <td>Bodoquena 1</td>
              <td>em 4 dias</td>
              <td><span class="badge badge--yellow">Média</span></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="btn-validar" data-action="validar">Validar</button></td>
            </tr>
          </tbody>
        </table>
      </div>

      <section class="lista-secao">
        <h2 class="lista-secao__titulo">Validados</h2>
        <p class="lista-secao__sub">Chamados que você já validou</p>
        <div class="tickets-concluidas"></div>
      </section>
    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  // Recalcula o contador "N Pendentes" ao lado da busca conforme os chamados
  // vão sendo validados (some um de cima → o número cai).
  function atualizarBadgePendentes() {
    const nMobile = document.querySelectorAll('#tickets-ativos .ticket-card').length;
    const nDesktop = document.querySelectorAll('#tickets-ativos-tbody tr').length;
    const badgeMobile = document.querySelector('.layout-mobile .tickets-badge-ativos');
    const badgeDesktop = document.querySelector('.layout-desktop .tickets-badge-ativos');
    if (badgeMobile) badgeMobile.textContent = nMobile + (nMobile === 1 ? ' Pendente' : ' Pendentes');
    if (badgeDesktop) badgeDesktop.textContent = nDesktop + (nDesktop === 1 ? ' Pendente' : ' Pendentes');
  }

  function escaparHTML(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  // Chamados já validados (em memória) — mais recente no topo.
  const ticketsValidados = [];

  // Renderiza os chamados validados como "varas" que abrem na setinha,
  // no mesmo padrão das tarefas validadas (nome + selo + ver mais; sem Ação).
  function renderTicketsValidados() {
    document.querySelectorAll('.tickets-concluidas').forEach(function (container) {
      container.innerHTML = '';
      if (!ticketsValidados.length) {
        container.innerHTML = '<p class="concl-vazio">Nenhum chamado validado ainda.</p>';
        return;
      }
      ticketsValidados.forEach(function (t) {
        const titulo = escaparHTML(t.nome) + (t.retiro ? ' — ' + escaparHTML(t.retiro) : '');

        const item = document.createElement('div');
        item.className = 'concl-item';

        const head = document.createElement('button');
        head.type = 'button';
        head.className = 'concl-head';
        head.setAttribute('aria-expanded', 'false');
        head.innerHTML =
          '<span class="concl-title">' + titulo + '</span>' +
          '<span class="concl-badge">Validado</span>' +
          '<span class="concl-arrow" aria-hidden="true">' +
            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>' +
          '</span>';

        const panel = document.createElement('div');
        panel.className = 'concl-panel';
        const inner = document.createElement('div');
        inner.className = 'concl-panel__inner';
        const metaParts = [];
        if (t.severidade) metaParts.push('Severidade ' + t.severidade);
        if (t.data) metaParts.push(t.data);
        if (metaParts.length) {
          const meta = document.createElement('p');
          meta.className = 'concl-meta';
          meta.textContent = metaParts.join(' • ');
          inner.appendChild(meta);
        }
        panel.appendChild(inner);

        item.appendChild(head);
        item.appendChild(panel);
        container.appendChild(item);

        head.addEventListener('click', function () {
          const aberto = item.classList.toggle('is-open');
          head.setAttribute('aria-expanded', aberto ? 'true' : 'false');
        });
      });
    });
  }

  // Marca um chamado como validado: tira da lista de pendentes e mostra
  // como "vara" na seção Validados.
  function validarTicket(dados, origem) {
    ticketsValidados.unshift(dados);
    if (origem) origem.remove();
    renderTicketsValidados();
    atualizarBadgePendentes();
  }

  // Validar (mobile): tira o card de pendentes e some pra Validados
  function validarCardMobile(card) {
    if (!card || card.dataset.validado) return;
    card.dataset.validado = '1';
    const meta = (card.querySelector('.ticket-card__meta')?.textContent || '').split('•');
    validarTicket({
      nome: (card.querySelector('.ticket-card__name')?.textContent || 'Chamado').trim(),
      retiro: (meta[0] || '').trim(),
      data: (meta[1] || '').trim(),
      severidade: (card.querySelector('.sev-badge')?.textContent || '').trim(),
    }, card);
  }

  // Validar (desktop): tira a linha de pendentes e some pra Validados
  function validarLinhaDesktop(row) {
    if (!row || row.dataset.validado) return;
    row.dataset.validado = '1';
    const cells = row.querySelectorAll('td');
    validarTicket({
      nome: (row.querySelector('.td--bold')?.textContent || 'Chamado').trim(),
      retiro: (cells[1]?.textContent || '').trim(),
      data: (cells[2]?.textContent || '').trim(),
      severidade: (cells[3]?.querySelector('.badge')?.textContent || '').trim(),
    }, row);
  }

  // Botão "Validar" (card mobile ou linha desktop)
  document.querySelectorAll('[data-action="validar"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.ticket-card');
      if (card) { validarCardMobile(card); return; }
      validarLinhaDesktop(btn.closest('tr'));
    });
  });

  // Estado inicial: contador e lista de validados (vazia) ao abrir.
  atualizarBadgePendentes();
  renderTicketsValidados();

  // Filtro de busca — mobile
  const searchMobile = document.querySelector('.tickets-search');
  if (searchMobile) {
    searchMobile.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.tickets-list .ticket-card').forEach(card => {
        const nome = card.querySelector('.ticket-card__name')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }

  // Filtro de busca — desktop
  const searchDesktop = document.querySelector('.revisao-search-desktop');
  if (searchDesktop) {
    searchDesktop.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-table tbody tr').forEach(row => {
        const nome = row.querySelector('.td--bold')?.textContent.toLowerCase() ?? '';
        if (!row.querySelector('.td--bold')) return;
        row.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }
</script>

</body>
</html>
