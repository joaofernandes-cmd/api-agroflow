<!-- ============================================================
     TELA: Tickets de infraestrutura
     Mobile  → TopNav com voltar + filtro + lista de tickets + BottomNav
     Desktop → Sidebar + TopBar + busca + tabela com botão Validar
     Validar move o ticket para a seção "Validados" (mais recente no topo).
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/supervisor/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Tickets de infraestrutura</h1>
  </header>

  <!-- Barra de busca + badge -->
  <div class="tickets-filter-bar" role="search">
    <div class="revisao-search-wrap">
      <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="tickets-search"
        type="search"
        placeholder="Pesquisar tickets"
        aria-label="Pesquisar tickets"
      />
    </div>
    <span class="tickets-badge-ativos">6 Pendentes</span>
  </div>

  <!-- Lista de tickets -->
  <main class="tickets-list" role="main">

    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Tickets pendentes</h2>
      <p class="lista-secao__sub">Aguardando sua validação</p>

      <div id="tickets-ativos">
        <div class="pend-item" data-ticket="1" data-nome="Cerca danificada no pasto" data-retiro="Puga" data-quando="Hoje, 08:24" data-sev="Alta">
          <div class="pend-head">
            <span class="pend-title"><span class="sev-badge sev-badge--alta">Alta</span> Cerca danificada no pasto</span>
            <button class="btn-revisar" data-action="validar">Validar</button>
            <button class="pend-toggle" type="button" aria-expanded="false" aria-label="Ver informações">
