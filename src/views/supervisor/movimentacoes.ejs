<!-- ============================================================
     TELA: Movimentações do rebanho
     O capataz registra/sobe as movimentações (nascimento, morte,
     transferência, compra, venda…) e o supervisor as valida — mesmo
     fluxo da tela de Tarefas (Revisão), só que para movimentações.
     Mobile  → TopNav com voltar + busca com badge + lista com detalhe + BottomNav
     Desktop → Sidebar + TopBar + busca + tabela com "Ver mais" e botão Validar
     Validar move a movimentação para a seção "Validadas".
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
