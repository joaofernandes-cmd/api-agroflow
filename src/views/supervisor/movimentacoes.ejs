<%- include('../partials/head', { title: title, css: css }) %>

<%#
  Variáveis esperadas pelo controller:
  - usuario: { nome: string }
  - css: ['supervisor']
%>

<!-- ============================================================
     TELA: Movimentações do rebanho
     O capataz registra/sobe as movimentações (nascimento, morte,
     transferência, compra, venda…) e o supervisor as valida — mesmo
     fluxo da tela de Tarefas (Revisão), só que para movimentações.
     Mobile  → TopNav com voltar + busca com badge + lista com detalhe + BottomNav
     Desktop → Sidebar + TopBar + busca + tabela com "Ver mais" e botão Validar
     Validar move a movimentação para a seção "Validadas".
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/supervisor/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Movimentações</h1>
  </header>

  <!-- Barra de busca + badge -->
  <div class="revisao-filter-bar" role="search">
    <div class="revisao-search-wrap">
      <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="revisao-search"
        type="search"
        placeholder="Pesquisar movimentações"
        aria-label="Pesquisar movimentações"
      />
    </div>
    <span class="revisao-badge-pendentes"><%= movimentacoes.length %> Pendentes</span>
  </div>

  <!-- Lista de movimentações -->
  <main class="revisao-list" role="main">

    <!-- Pendentes de validação -->
    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Pendentes de validação</h2>
      <p class="lista-secao__sub">Movimentações registradas pelos capatazes</p>

      <% movimentacoes.forEach(function (m) { %>
      <div class="pend-item" data-mov-id="<%= m.id %>">
        <div class="pend-head">
          <span class="pend-title"><span class="badge <%= m.badgeClasse %>"><%= m.tipo %></span> <%= m.local %></span>
          <button class="btn-revisar" data-action="validar">Validar</button>
          <button class="pend-toggle" type="button" aria-expanded="false" aria-label="Ver informações">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
        </div>
        <div class="pend-panel">
          <div class="pend-panel__inner">
            <p class="pend-info"><strong>Capataz:</strong> <%= m.capataz %><br><% if (m.tipo === 'Transferência') { %><strong>Origem:</strong> <%= m.origem %><br><strong>Destino:</strong> <%= m.destino %><br><% } else { %><strong>Retiro:</strong> <%= m.retiro %><br><% } %><strong>Quantidade:</strong> <%= m.quantidadeRotulo %><br><strong>Estágio:</strong> <%= m.estagio %><br><% if (m.causaObito) { %><strong>Causa do óbito:</strong> <%= m.causaObito %><br><% } %><strong>Evidência:</strong> <%= m.evidencia %><br><strong>Enviado:</strong> <%= m.enviado %></p>
          </div>
        </div>
      </div>
      <% }) %>

    </section>

    <!-- Validadas -->
    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Validadas</h2>
      <p class="lista-secao__sub">Movimentações que você já validou</p>
      <div class="movimentacoes-validadas"></div>
    </section>

  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'movimentacoes' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <!-- Sidebar -->
  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'movimentacoes' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <div class="topbar__lead">
        <h1 class="topbar__title">Movimentações</h1>
      </div>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <!-- Barra de busca + badge desktop -->
    <div class="revisao-filter-bar-desktop" role="search">
      <div class="revisao-search-wrap-desktop">
        <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          class="revisao-search-desktop"
          type="search"
          placeholder="Pesquisar movimentações"
          aria-label="Pesquisar movimentações"
        />
      </div>
      <span class="revisao-badge-pendentes revisao-badge-pendentes--desktop"><%= movimentacoes.length %> Pendentes</span>
    </div>

    <!-- Tabela de movimentações -->
    <main class="desktop-content revisao-desktop-content" role="main">
      <!-- Pendentes de validação -->
      <section class="lista-secao">
        <h2 class="lista-secao__titulo">Pendentes de validação</h2>
        <p class="lista-secao__sub">Movimentações registradas pelos capatazes</p>
      </section>

      <div class="revisao-table-wrap">
        <table class="revisao-table" aria-label="Movimentações pendentes de validação">
          <thead>
            <tr>
              <th>Tipo</th>
              <th>Retiro / Trajeto</th>
              <th>Capataz</th>
              <th>Quantidade</th>
              <th>Status</th>
              <th></th><!-- ver mais -->
              <th>Ação</th>
            </tr>
          </thead>
          <tbody>
            <%
              function escHtmlMov(s){ return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
              function evidenciaBlocoMov(m){
                if (m.evidencia === 'Texto') {
                  return '<p class="evidencia-texto">' + escHtmlMov(m.evidenciaTexto) + '</p>';
                }
                var isAudio = m.evidencia === 'Áudio';
                var icone = isAudio
                  ? '<path d="M12 2a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v1a7 7 0 0 1-14 0v-1"/><line x1="12" x2="12" y1="18" y2="22"/>'
                  : '<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/>';
                return '<div class="evidencia ' + (isAudio ? 'evidencia--audio' : 'evidencia--foto') + '">' +
                  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + icone + '</svg>' +
                  '<span class="evidencia__tipo">' + escHtmlMov(m.evidencia) + '</span></div>';
              }
            %>
            <% movimentacoes.forEach(function (m, i) { %>
            <tr<%- i % 2 === 1 ? ' class="tr--alt"' : '' %> data-mov-id="<%= m.id %>">
              <td class="td--bold"><span class="badge <%= m.badgeClasse %>"><%= m.tipo %></span></td>
              <td><%= m.local %></td>
              <td>Capataz <%= m.capataz %></td>
              <td><%= m.quantidadeRotulo %></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="ver-mais" type="button" aria-expanded="false">Ver mais <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button></td>
              <td><button class="btn-revisar" data-action="validar">Validar</button></td>
            </tr>
            <tr class="pend-detalhe" hidden>
              <td colspan="7">
                <div class="pend-detalhe__inner">
                  <div class="concl-bloco">
                    <span class="concl-bloco__label">Detalhes</span>
                    <p class="concl-bloco__texto"><%= m.detalhes %></p>
                  </div>
                  <div class="concl-bloco">
                    <span class="concl-bloco__label">Evidência</span>
                    <%- evidenciaBlocoMov(m) %>
                  </div>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Validadas -->
      <section class="lista-secao">
        <h2 class="lista-secao__titulo">Validadas</h2>
        <p class="lista-secao__sub">Movimentações que você já validou</p>
        <div class="movimentacoes-validadas"></div>
      </section>
    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script src="/js/contadores-pendentes.js"></script>
<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  function escaparHTML(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  // Momento da validação (DD/MM/AAAA HH:MM) e nome do supervisor logado.
  function agoraFormatado() {
    return new Date().toLocaleString('pt-BR', {
      day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
    });
  }
  function nomeSupervisor() {
    try {
      const u = JSON.parse(localStorage.getItem('agroflow.usuario') || '{}');
      return (u && u.nome) ? u.nome.split(' ')[0] : 'Luiz Felipe';
    } catch (e) { return 'Luiz Felipe'; }
  }
  // Card de evidência (mesmo visual das tarefas): foto/áudio com ícone, texto com a nota.
  function evidenciaHTML(tipo, texto) {
    if (tipo === 'Texto') return '<p class="evidencia-texto">' + escaparHTML(texto || '') + '</p>';
    const isAudio = tipo === 'Áudio';
    const icone = isAudio
      ? '<path d="M12 2a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v1a7 7 0 0 1-14 0v-1"/><line x1="12" x2="12" y1="18" y2="22"/>'
      : '<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/>';
    return '<div class="evidencia ' + (isAudio ? 'evidencia--audio' : 'evidencia--foto') + '">' +
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + icone + '</svg>' +
      '<span class="evidencia__tipo">' + escaparHTML(tipo) + '</span></div>';
  }

  // Detalhes + evidência de cada movimentação (fonte única, vinda do servidor —
  // o mesmo módulo que renderiza a lista acima).
  const MOV_DADOS = <%- JSON.stringify(movimentacoesDados) %>;

  // Recalcula o contador "N Pendentes" ao lado da busca conforme as
  // movimentações vão sendo validadas (some uma de cima → o número cai).
  function atualizarBadgePendentes() {
    const nMobile = document.querySelectorAll('.layout-mobile .pend-item').length;
    const nDesktop = document.querySelectorAll('.layout-desktop .revisao-table tbody tr[data-mov-id]').length;
    const badgeMobile = document.querySelector('.layout-mobile .revisao-badge-pendentes');
    const badgeDesktop = document.querySelector('.layout-desktop .revisao-badge-pendentes');
    if (badgeMobile) badgeMobile.textContent = nMobile + (nMobile === 1 ? ' Pendente' : ' Pendentes');
    if (badgeDesktop) badgeDesktop.textContent = nDesktop + (nDesktop === 1 ? ' Pendente' : ' Pendentes');
    // Espelha o total na home (bloco "Movimentações" do Acesso rápido).
    if (window.ContadoresPendentes) ContadoresPendentes.definirDoLayout('movimentacoes', nMobile, nDesktop);
  }

  // Movimentações já validadas (em memória) — mais recente no topo.
  const movimentacoesValidadas = [];

  // Renderiza as validadas como "varas" que abrem na setinha, no mesmo
  // padrão das tarefas/tickets validados (tipo + retiro + selo; sem Ação).
  function renderValidadas() {
    document.querySelectorAll('.movimentacoes-validadas').forEach(function (container) {
      container.innerHTML = '';
      if (!movimentacoesValidadas.length) {
        container.innerHTML = '<p class="concl-vazio">Nenhuma movimentação validada ainda.</p>';
        return;
      }
      movimentacoesValidadas.forEach(function (m) {
        const titulo = escaparHTML(m.tipo) + (m.local ? ' — ' + escaparHTML(m.local) : '');

        const item = document.createElement('div');
        item.className = 'concl-item';

        const head = document.createElement('button');
        head.type = 'button';
        head.className = 'concl-head';
        head.setAttribute('aria-expanded', 'false');
        head.innerHTML =
          '<span class="concl-title">' + titulo + '</span>' +
          '<span class="concl-badge">Validada</span>' +
          '<span class="concl-arrow" aria-hidden="true">' +
            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>' +
          '</span>';

        const panel = document.createElement('div');
        panel.className = 'concl-panel';
        const inner = document.createElement('div');
        inner.className = 'concl-panel__inner';

        // Quando foi validada + por quem
        const metaParts = [];
        if (m.dataValidacao) metaParts.push('Validada em ' + m.dataValidacao);
        if (m.supervisor) metaParts.push('Supervisor ' + m.supervisor);
        if (metaParts.length) {
          const meta = document.createElement('p');
          meta.className = 'concl-meta';
          meta.textContent = metaParts.join(' • ');
          inner.appendChild(meta);
        }

        // Detalhes (capataz, quantidade, estágio…)
        const detParts = [];
        if (m.capataz) detParts.push('Capataz ' + m.capataz);
        if (m.quantidade) detParts.push(m.quantidade);
        const detTexto = [detParts.join(' • '), m.detalhes].filter(Boolean).join(' • ');
        if (detTexto) {
          const desc = document.createElement('div');
          desc.className = 'concl-bloco';
          desc.innerHTML = '<span class="concl-bloco__label">Detalhes</span>' +
            '<p class="concl-bloco__texto">' + escaparHTML(detTexto) + '</p>';
          inner.appendChild(desc);
        }

        // Evidência
        if (m.evidencia) {
          const ev = document.createElement('div');
          ev.className = 'concl-bloco';
          ev.innerHTML = '<span class="concl-bloco__label">Evidência</span>' + evidenciaHTML(m.evidencia, m.evidenciaTexto);
          inner.appendChild(ev);
        }

        panel.appendChild(inner);

        item.appendChild(head);
        item.appendChild(panel);
        container.appendChild(item);

        head.addEventListener('click', function () {
          const aberto = item.classList.toggle('is-open');
          head.setAttribute('aria-expanded', aberto ? 'true' : 'false');
        });
      });
    });
  }

  // Valida no backend (não bloqueia a UI se falhar — é demo).
  async function validarMovimentacaoPorId(movId) {
    try {
      const token = localStorage.getItem('agroflow.token');
      const response = await fetch(`/validacoes/movimentacoes/${movId}/validar`, {
        method: 'PATCH',
        headers: token ? { Authorization: `Bearer ${token}` } : {},
      });
      const data = await response.json().catch(() => ({}));
      return { ok: response.ok, mensagem: data.mensagem || data.error || '' };
    } catch (e) {
      return { ok: false, mensagem: 'Falha de conexão' };
    }
  }

  // Marca uma movimentação como validada: tira de pendentes e mostra
  // como "vara" na seção Validadas.
  function validarMovimentacao(dados, origem) {
    dados.dataValidacao = agoraFormatado();
    dados.supervisor = nomeSupervisor();
    movimentacoesValidadas.unshift(dados);
    if (origem) origem.remove();
    validarMovimentacaoPorId(dados.id);
    // Persiste no servidor (demo): remove a movimentação dos pendentes em
    // memória, para o contador (tela + home) continuar certo após recarregar.
    if (dados.id) {
      fetch('/supervisor/movimentacoes/' + encodeURIComponent(dados.id) + '/validar', { method: 'POST' })
        .catch(function () {});
    }
    renderValidadas();
    atualizarBadgePendentes();
  }

  // Validar (vara mobile): tira de pendentes e desce para Validadas
  function validarPendItem(item) {
    if (!item || item.dataset.validado) return;
    item.dataset.validado = '1';
    const tipo = (item.querySelector('.pend-title .badge')?.textContent || '').trim();
    const tituloCompleto = (item.querySelector('.pend-title')?.textContent || '').trim();
    const local = tituloCompleto.replace(tipo, '').trim();
    const info = item.querySelector('.pend-info')?.textContent || '';
    const capataz = (info.match(/Capataz:\s*([^\n]+?)(?:Origem|Retiro|Quantidade|$)/)?.[1] || '').trim();
    const quantidade = (info.match(/Quantidade:\s*([0-9]+\s*anima(?:l|is))/)?.[1] || '').trim();
    const extra = MOV_DADOS[item.dataset.movId] || {};
    validarMovimentacao({
      id: item.dataset.movId, tipo, local, capataz, quantidade,
      detalhes: extra.detalhes || '', evidencia: extra.evidencia || '', evidenciaTexto: extra.evidenciaTexto || '',
    }, item);
  }

  // Validar (linha desktop): remove a linha e sua linha de detalhe
  function validarLinhaDesktop(row) {
    if (!row || row.dataset.validado) return;
    row.dataset.validado = '1';
    const cells = row.querySelectorAll('td');
    const det = row.nextElementSibling;
    const extra = MOV_DADOS[row.dataset.movId] || {};
    validarMovimentacao({
      id: row.dataset.movId,
      tipo: (cells[0]?.textContent || 'Movimentação').trim(),
      local: (cells[1]?.textContent || '').trim(),
      capataz: (cells[2]?.textContent || '').replace(/^Capataz\s*/, '').trim(),
      quantidade: (cells[3]?.textContent || '').trim(),
      detalhes: extra.detalhes || '', evidencia: extra.evidencia || '', evidenciaTexto: extra.evidenciaTexto || '',
    }, row);
    if (det && det.classList.contains('pend-detalhe')) det.remove();
  }

  // Botão "Validar" (vara mobile ou linha desktop)
  document.querySelectorAll('.btn-revisar').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.pend-item');
      if (item) { validarPendItem(item); return; }
      validarLinhaDesktop(btn.closest('tr'));
    });
  });

  // Setinha: abre/fecha as informações da movimentação pendente (mobile)
  document.querySelectorAll('.pend-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.pend-item');
      if (!item) return;
      const aberto = item.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', aberto ? 'true' : 'false');
    });
  });

  // "Ver mais" (desktop): abre a linha de detalhe com os dados + evidência
  document.querySelectorAll('.ver-mais').forEach(btn => {
    btn.addEventListener('click', () => {
      const det = btn.closest('tr')?.nextElementSibling;
      if (!det || !det.classList.contains('pend-detalhe')) return;
      const abrindo = det.hasAttribute('hidden');
      det.toggleAttribute('hidden');
      btn.setAttribute('aria-expanded', abrindo ? 'true' : 'false');
    });
  });

  // Filtro de busca — mobile
  const searchMobile = document.querySelector('.revisao-search');
  if (searchMobile) {
    searchMobile.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-list .pend-item').forEach(card => {
        const nome = card.querySelector('.pend-title')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }

  // Filtro de busca — desktop
  const searchDesktop = document.querySelector('.revisao-search-desktop');
  if (searchDesktop) {
    searchDesktop.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-table tbody tr[data-mov-id]').forEach(row => {
        const tipo = row.querySelector('.td--bold')?.textContent.toLowerCase() ?? '';
        const local = row.children[1]?.textContent.toLowerCase() ?? '';
        row.style.display = (tipo.includes(termo) || local.includes(termo)) ? '' : 'none';
        const det = row.nextElementSibling;
        if (det && det.classList.contains('pend-detalhe')) det.setAttribute('hidden', '');
        const vm = row.querySelector('.ver-mais');
        if (vm) vm.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Estado inicial: contador e lista de validadas (vazia) ao abrir.
  atualizarBadgePendentes();
  renderValidadas();
</script>

</body>
</html>
