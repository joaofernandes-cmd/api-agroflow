<%- include('../partials/head', { title: title, css: css }) %>

<%#
  Variáveis esperadas pelo controller:
  - usuario: { nome: string }
  - css: ['supervisor']
%>

<!-- ============================================================
     TELA: Movimentações do rebanho
     O capataz registra/sobe as movimentações (nascimento, morte,
     transferência, compra, venda…) e o supervisor as valida — mesmo
     fluxo da tela de Tarefas (Revisão), só que para movimentações.
     Mobile  → TopNav com voltar + busca com badge + lista com detalhe + BottomNav
     Desktop → Sidebar + TopBar + busca + tabela com "Ver mais" e botão Validar
     Validar move a movimentação para a seção "Validadas".
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/supervisor/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Movimentações</h1>
  </header>

  <!-- Barra de busca + badge -->
  <div class="revisao-filter-bar" role="search">
    <div class="revisao-search-wrap">
      <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        class="revisao-search"
        type="search"
        placeholder="Pesquisar movimentações"
        aria-label="Pesquisar movimentações"
      />
    </div>
    <span class="revisao-badge-pendentes"><%= movimentacoes.length %> Pendentes</span>
  </div>

  <!-- Lista de movimentações -->
  <main class="revisao-list" role="main">

    <!-- Pendentes de validação -->
    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Pendentes de validação</h2>
      <p class="lista-secao__sub">Movimentações registradas pelos capatazes</p>

      <% movimentacoes.forEach(function (m) { %>
      <div class="pend-item" data-mov-id="<%= m.id %>">
        <div class="pend-head">
          <span class="pend-title"><span class="badge <%= m.badgeClasse %>"><%= m.tipo %></span> <%= m.local %></span>
          <button class="btn-revisar" data-action="validar">Validar</button>
          <button class="pend-toggle" type="button" aria-expanded="false" aria-label="Ver informações">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
        </div>
        <div class="pend-panel">
          <div class="pend-panel__inner">
            <p class="pend-info"><strong>Capataz:</strong> <%= m.capataz %><br><% if (m.tipo === 'Transferência') { %><strong>Origem:</strong> <%= m.origem %><br><strong>Destino:</strong> <%= m.destino %><br><% } else { %><strong>Retiro:</strong> <%= m.retiro %><br><% } %><strong>Quantidade:</strong> <%= m.quantidadeRotulo %><br><strong>Estágio:</strong> <%= m.estagio %><br><% if (m.causaObito) { %><strong>Causa do óbito:</strong> <%= m.causaObito %><br><% } %><strong>Evidência:</strong> <%= m.evidencia %><br><strong>Enviado:</strong> <%= m.enviado %></p>
          </div>
        </div>
      </div>
      <% }) %>

    </section>

    <!-- Validadas -->
    <section class="lista-secao">
      <h2 class="lista-secao__titulo">Validadas</h2>
      <p class="lista-secao__sub">Movimentações que você já validou</p>
      <div class="movimentacoes-validadas"><%- include('../partials/movimentacoes-validadas', { movimentacoesValidadas }) %></div>
    </section>

  </main>

  <!-- BottomNav -->
  <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'movimentacoes' }) %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <!-- Sidebar -->
  <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'movimentacoes' }) %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar -->
    <header class="topbar" role="banner">
      <div class="topbar__lead">
        <h1 class="topbar__title">Movimentações</h1>
      </div>
      <p class="topbar__date" id="data-hoje-desktop"></p>
    </header>

    <!-- Barra de busca + badge desktop -->
    <div class="revisao-filter-bar-desktop" role="search">
      <div class="revisao-search-wrap-desktop">
        <svg class="revisao-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          class="revisao-search-desktop"
          type="search"
          placeholder="Pesquisar movimentações"
          aria-label="Pesquisar movimentações"
        />
      </div>
      <span class="revisao-badge-pendentes revisao-badge-pendentes--desktop"><%= movimentacoes.length %> Pendentes</span>
    </div>

    <!-- Tabela de movimentações -->
    <main class="desktop-content revisao-desktop-content" role="main">
      <!-- Pendentes de validação -->
      <section class="lista-secao">
        <h2 class="lista-secao__titulo">Pendentes de validação</h2>
        <p class="lista-secao__sub">Movimentações registradas pelos capatazes</p>
      </section>

      <div class="revisao-table-wrap">
        <table class="revisao-table" aria-label="Movimentações pendentes de validação">
          <thead>
            <tr>
              <th>Tipo</th>
              <th>Retiro / Trajeto</th>
              <th>Capataz</th>
              <th>Quantidade</th>
              <th>Status</th>
              <th></th><!-- ver mais -->
              <th>Ação</th>
            </tr>
          </thead>
          <tbody>
            <%
              function escHtmlMov(s){ return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
              function evidenciaBlocoMov(m){
                if (!m.evidencia) {
                  return '<p class="evidencia-texto">Sem evidência registrada.</p>';
                }
                if (m.evidencia === 'Texto') {
                  return '<p class="evidencia-texto">' + escHtmlMov(m.evidenciaTexto) + '</p>';
                }
                var isAudio = m.evidencia === 'Áudio';
                if (m.evidenciaUrl && isAudio) {
                  return '<audio class="evidencia-audio" controls src="' + escHtmlMov(m.evidenciaUrl) + '"></audio>';
                }
                if (m.evidenciaUrl) {
                  return '<img class="evidencia-midia" src="' + escHtmlMov(m.evidenciaUrl) + '" alt="Foto da evidência">';
                }
                var icone = isAudio
                  ? '<path d="M12 2a3 3 0 0 0-3 3v6a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v1a7 7 0 0 1-14 0v-1"/><line x1="12" x2="12" y1="18" y2="22"/>'
                  : '<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/>';
                return '<div class="evidencia ' + (isAudio ? 'evidencia--audio' : 'evidencia--foto') + '">' +
                  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + icone + '</svg>' +
                  '<span class="evidencia__tipo">' + escHtmlMov(m.evidencia) + '</span></div>';
              }
            %>
            <% movimentacoes.forEach(function (m, i) { %>
            <tr<%- i % 2 === 1 ? ' class="tr--alt"' : '' %> data-mov-id="<%= m.id %>">
              <td class="td--bold"><span class="badge <%= m.badgeClasse %>"><%= m.tipo %></span></td>
              <td><%= m.local %></td>
              <td><%= m.capataz %></td>
              <td><%= m.quantidadeRotulo %></td>
              <td><span class="badge badge--yellow">Pendente</span></td>
              <td><button class="ver-mais" type="button" aria-expanded="false">Ver mais <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button></td>
              <td><button class="btn-revisar" data-action="validar">Validar</button></td>
            </tr>
            <tr class="pend-detalhe" hidden>
              <td colspan="7">
                <div class="pend-detalhe__inner">
                  <div class="concl-bloco">
                    <span class="concl-bloco__label">Detalhes</span>
                    <p class="concl-bloco__texto"><%= m.detalhes %></p>
                  </div>
                  <div class="concl-bloco">
                    <span class="concl-bloco__label">Evidência</span>
                    <%- evidenciaBlocoMov(m) %>
                  </div>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Validadas -->
      <section class="lista-secao">
        <h2 class="lista-secao__titulo">Validadas</h2>
        <p class="lista-secao__sub">Movimentações que você já validou</p>
        <div class="movimentacoes-validadas"><%- include('../partials/movimentacoes-validadas', { movimentacoesValidadas }) %></div>
      </section>
    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script src="/js/data-hoje.js"></script>
<script src="/js/revisao-utils.js"></script>
<script>

  function mostrarFeedbackValidacao(mensagem, tipo) {
    AgroFlowRevisao.mostrarFeedback({
      feedbackSelector: '.movimentacoes-feedback',
      alvoSelector: '.revisao-filter-bar',
      alvoFallbackSelector: '.revisao-list',
      feedbackClass: 'movimentacoes-feedback',
      mensagem,
      tipo,
    });
  }

  // Valida a movimentação no BACKEND (PATCH real, autenticado pelo cookie de
  // sessão). Em caso de sucesso recarrega: o servidor re-renderiza as listas a
  // partir do banco, então a movimentação sai de "Pendentes" e entra em
  // "Validadas" — e o mesmo dado passa a aparecer no relatório e para o gerente.
  async function validarMovimentacao(movId, btn) {
    return AgroFlowRevisao.validarItem({
      id: movId,
      botao: btn,
      url: '/validacoes/movimentacoes/' + encodeURIComponent(movId) + '/validar',
      mensagemErro: 'Não foi possível validar a movimentação.',
      mostrarFeedback: mostrarFeedbackValidacao,
    });
  }

  // Botão "Validar" (vara mobile ou linha desktop) — pega o id do elemento que
  // carrega data-mov-id (o card mobile ou a linha da tabela).
  AgroFlowRevisao.vincularValidacao({
    hostSelector: '[data-mov-id]',
    datasetKey: 'movId',
    validar: validarMovimentacao,
  });

  // Abrir/fechar as "varas" de movimentações já validadas.
  AgroFlowRevisao.vincularAcordeao('.movimentacoes-validadas .concl-head', '.concl-item');

  // Setinha: abre/fecha as informações da movimentação pendente (mobile)
  AgroFlowRevisao.vincularAcordeao('.pend-toggle', '.pend-item');

  // "Ver mais" (desktop): abre a linha de detalhe com os dados + evidência
  AgroFlowRevisao.vincularDetalheTabela('.ver-mais', 'pend-detalhe');

  // Filtro de busca — mobile
  const searchMobile = document.querySelector('.revisao-search');
  if (searchMobile) {
    searchMobile.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-list .pend-item').forEach(card => {
        const nome = card.querySelector('.pend-title')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }

  // Filtro de busca — desktop
  const searchDesktop = document.querySelector('.revisao-search-desktop');
  if (searchDesktop) {
    searchDesktop.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-table tbody tr[data-mov-id]').forEach(row => {
        const tipo = row.querySelector('.td--bold')?.textContent.toLowerCase() ?? '';
        const local = row.children[1]?.textContent.toLowerCase() ?? '';
        row.style.display = (tipo.includes(termo) || local.includes(termo)) ? '' : 'none';
        const det = row.nextElementSibling;
        if (det && det.classList.contains('pend-detalhe')) det.setAttribute('hidden', '');
        const vm = row.querySelector('.ver-mais');
        if (vm) vm.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>

</body>
</html>
