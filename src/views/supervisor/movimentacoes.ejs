<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  function escaparHTML(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  // Recalcula o contador "N Pendentes" ao lado da busca conforme as
  // movimentações vão sendo validadas (some uma de cima → o número cai).
  function atualizarBadgePendentes() {
    const nMobile = document.querySelectorAll('.layout-mobile .pend-item').length;
    const nDesktop = document.querySelectorAll('.layout-desktop .revisao-table tbody tr[data-mov-id]').length;
    const badgeMobile = document.querySelector('.layout-mobile .revisao-badge-pendentes');
    const badgeDesktop = document.querySelector('.layout-desktop .revisao-badge-pendentes');
    if (badgeMobile) badgeMobile.textContent = nMobile + (nMobile === 1 ? ' Pendente' : ' Pendentes');
    if (badgeDesktop) badgeDesktop.textContent = nDesktop + (nDesktop === 1 ? ' Pendente' : ' Pendentes');
  }

  // Movimentações já validadas (em memória) — mais recente no topo.
  const movimentacoesValidadas = [];

  // Renderiza as validadas como "varas" que abrem na setinha, no mesmo
  // padrão das tarefas/tickets validados (tipo + retiro + selo; sem Ação).
  function renderValidadas() {
    document.querySelectorAll('.movimentacoes-validadas').forEach(function (container) {
      container.innerHTML = '';
      if (!movimentacoesValidadas.length) {
        container.innerHTML = '<p class="concl-vazio">Nenhuma movimentação validada ainda.</p>';
        return;
      }
      movimentacoesValidadas.forEach(function (m) {
        const titulo = escaparHTML(m.tipo) + (m.local ? ' — ' + escaparHTML(m.local) : '');

        const item = document.createElement('div');
        item.className = 'concl-item';

        const head = document.createElement('button');
        head.type = 'button';
        head.className = 'concl-head';
        head.setAttribute('aria-expanded', 'false');
        head.innerHTML =
          '<span class="concl-title">' + titulo + '</span>' +
          '<span class="concl-badge">Validada</span>' +
          '<span class="concl-arrow" aria-hidden="true">' +
            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>' +
          '</span>';

        const panel = document.createElement('div');
        panel.className = 'concl-panel';
        const inner = document.createElement('div');
        inner.className = 'concl-panel__inner';
        const metaParts = [];
        if (m.capataz) metaParts.push('Capataz ' + m.capataz);
        if (m.quantidade) metaParts.push(m.quantidade);
        if (metaParts.length) {
          const meta = document.createElement('p');
          meta.className = 'concl-meta';
          meta.textContent = metaParts.join(' • ');
          inner.appendChild(meta);
        }
        panel.appendChild(inner);

        item.appendChild(head);
        item.appendChild(panel);
        container.appendChild(item);

        head.addEventListener('click', function () {
          const aberto = item.classList.toggle('is-open');
          head.setAttribute('aria-expanded', aberto ? 'true' : 'false');
        });
      });
    });
  }

  // Valida no backend (não bloqueia a UI se falhar — é demo).
  async function validarMovimentacaoPorId(movId) {
    try {
      const token = localStorage.getItem('agroflow.token');
      const response = await fetch(`/validacoes/movimentacoes/${movId}/validar`, {
        method: 'PATCH',
        headers: token ? { Authorization: `Bearer ${token}` } : {},
      });
      const data = await response.json().catch(() => ({}));
      return { ok: response.ok, mensagem: data.mensagem || data.error || '' };
    } catch (e) {
      return { ok: false, mensagem: 'Falha de conexão' };
    }
  }

  // Marca uma movimentação como validada: tira de pendentes e mostra
  // como "vara" na seção Validadas.
  function validarMovimentacao(dados, origem) {
    movimentacoesValidadas.unshift(dados);
    if (origem) origem.remove();
    validarMovimentacaoPorId(dados.id);
    renderValidadas();
    atualizarBadgePendentes();
  }

  // Validar (vara mobile): tira de pendentes e desce para Validadas
  function validarPendItem(item) {
    if (!item || item.dataset.validado) return;
    item.dataset.validado = '1';
    const tipo = (item.querySelector('.pend-title .badge')?.textContent || '').trim();
    const tituloCompleto = (item.querySelector('.pend-title')?.textContent || '').trim();
    const local = tituloCompleto.replace(tipo, '').trim();
    const info = item.querySelector('.pend-info')?.textContent || '';
    const capataz = (info.match(/Capataz:\s*([^\n]+?)(?:Origem|Retiro|Quantidade|$)/)?.[1] || '').trim();
    const quantidade = (info.match(/Quantidade:\s*([0-9]+\s*anima(?:l|is))/)?.[1] || '').trim();
    validarMovimentacao({ id: item.dataset.movId, tipo, local, capataz, quantidade }, item);
  }

  // Validar (linha desktop): remove a linha e sua linha de detalhe
  function validarLinhaDesktop(row) {
    if (!row || row.dataset.validado) return;
    row.dataset.validado = '1';
    const cells = row.querySelectorAll('td');
    const det = row.nextElementSibling;
    validarMovimentacao({
      id: row.dataset.movId,
      tipo: (cells[0]?.textContent || 'Movimentação').trim(),
      local: (cells[1]?.textContent || '').trim(),
      capataz: (cells[2]?.textContent || '').replace(/^Capataz\s*/, '').trim(),
      quantidade: (cells[3]?.textContent || '').trim(),
    }, row);
    if (det && det.classList.contains('pend-detalhe')) det.remove();
  }

  // Botão "Validar" (vara mobile ou linha desktop)
  document.querySelectorAll('.btn-revisar').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.pend-item');
      if (item) { validarPendItem(item); return; }
      validarLinhaDesktop(btn.closest('tr'));
    });
  });

  // Setinha: abre/fecha as informações da movimentação pendente (mobile)
  document.querySelectorAll('.pend-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.pend-item');
      if (!item) return;
      const aberto = item.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', aberto ? 'true' : 'false');
    });
  });

  // "Ver mais" (desktop): abre a linha de detalhe com os dados + evidência
  document.querySelectorAll('.ver-mais').forEach(btn => {
    btn.addEventListener('click', () => {
      const det = btn.closest('tr')?.nextElementSibling;
      if (!det || !det.classList.contains('pend-detalhe')) return;
      const abrindo = det.hasAttribute('hidden');
      det.toggleAttribute('hidden');
      btn.setAttribute('aria-expanded', abrindo ? 'true' : 'false');
    });
  });

  // Filtro de busca — mobile
  const searchMobile = document.querySelector('.revisao-search');
  if (searchMobile) {
    searchMobile.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-list .pend-item').forEach(card => {
        const nome = card.querySelector('.pend-title')?.textContent.toLowerCase() ?? '';
        card.style.display = nome.includes(termo) ? '' : 'none';
      });
    });
  }

  // Filtro de busca — desktop
  const searchDesktop = document.querySelector('.revisao-search-desktop');
  if (searchDesktop) {
    searchDesktop.addEventListener('input', function () {
      const termo = this.value.toLowerCase().trim();
      document.querySelectorAll('.revisao-table tbody tr[data-mov-id]').forEach(row => {
        const tipo = row.querySelector('.td--bold')?.textContent.toLowerCase() ?? '';
        const local = row.children[1]?.textContent.toLowerCase() ?? '';
        row.style.display = (tipo.includes(termo) || local.includes(termo)) ? '' : 'none';
        const det = row.nextElementSibling;
        if (det && det.classList.contains('pend-detalhe')) det.setAttribute('hidden', '');
        const vm = row.querySelector('.ver-mais');
        if (vm) vm.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Estado inicial: contador e lista de validadas (vazia) ao abrir.
  atualizarBadgePendentes();
  renderValidadas();
</script>

</body>
</html>
