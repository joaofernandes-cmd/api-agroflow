<%- include('../partials/capataz-head', { titulo: 'Alow · Nova Movimentação' }) %>

<%
  var RETIROS = ['Acurizal','Aroeira','Baia Bonita','Bodoquena 1','Bodoquena 2',
    'Boqueirão','Caieira','CMB','Confinamento','Cristo','Morada Nova','Morro Azul',
    'Puga','São Miguel','Vista Alegre'];
  var TIPOS = [
    { value: 'nascimento', label: 'Nascimento' },
    { value: 'morte', label: 'Morte' },
    { value: 'transferencia', label: 'Transferência' },
    { value: 'compra', label: 'Compra' },
    { value: 'venda', label: 'Venda' },
    { value: 'outros', label: 'Outros' }
  ];
  var ESTAGIOS = [
    'BEZERRO 0 A 7 MESES',
    'GARROTE 8 A 12 MESES',
    'NOVILHA 8 A 12 MESES',
    'GARROTE 13 A 24 MESES',
    'NOVILHA 13 A 24 MESES',
    'BOI 25 A 36 MESES',
    'NOVILHA 25 A 36 MESES',
    'TOURO 25 A 36 MESES',
    'VACA ACIMA 36 MESES',
    'BOI ACIMA 36 MESES',
    'TOURO ACIMA 36 MESES'
  ];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/home" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Nova Movimentação</span>
    </div>
  </header>

  <form class="conteudo" id="form-movimentacao" novalidate>
    <p id="mov-feedback" style="margin: 0 0 12px; font-size: 14px; line-height: 1.4;"></p>

    <div class="campo">
      <label class="campo__rotulo" for="tipoMov">Tipo de movimentação</label>
      <select class="select" id="tipoMov" required>
        <option value="" disabled selected>Selecione o tipo</option>
        <% TIPOS.forEach(function (t) { %><option value="<%= t.value %>"><%= t.label %></option><% }) %>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo" id="rotuloOrigem" for="origemMov">Retiro</label>
      <select class="select" id="origemMov" required>
        <option value="" disabled selected>Selecione o retiro</option>
        <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
      </select>
    </div>

    <div class="campo" id="campoDestino" style="display: none;">
      <label class="campo__rotulo" for="destinoMov">Retiro de destino</label>
      <select class="select" id="destinoMov">
        <option value="" disabled selected>Selecione o retiro</option>
        <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="quantidadeMov">Quantidade de animais</label>
      <input class="input" id="quantidadeMov" type="number" min="1" step="1" placeholder="Ex: 12" />
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="estagioMov">Estágio da vida</label>
      <select class="select" id="estagioMov" required>
        <option value="" disabled selected>Selecione o estágio</option>
        <% ESTAGIOS.forEach(function (e) { %><option value="<%= e %>"><%= e %></option><% }) %>
      </select>
    </div>

    <div class="campo" id="campoCausa" style="display: none;">
      <label class="campo__rotulo" for="causaObito">Causa do óbito <span class="obrigatorio">*</span></label>
      <select class="select" id="causaObito">
        <option value="" disabled selected>Selecione a causa</option>
        <option value="Doença">Doença</option>
        <option value="Acidente">Acidente</option>
        <option value="Predador">Predador</option>
        <option value="Causa natural">Causa natural</option>
        <option value="Desconhecida">Desconhecida</option>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo">Evidência</label>
      <div class="evidencia">
        <button type="button" class="evidencia__btn evidencia__btn--foto" data-evidencia="foto">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
          Foto
        </button>
        <button type="button" class="evidencia__btn evidencia__btn--audio" data-evidencia="audio">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0 0 14 0"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
          Áudio
        </button>
        <button type="button" class="evidencia__btn evidencia__btn--texto" data-evidencia="mensagem">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
          Texto
        </button>
      </div>
    </div>

    <input type="hidden" id="tipoEvidencia" value="mensagem" />

    <div class="campo" id="evidenciaMensagemCampo">
      <label class="campo__rotulo" for="conteudoEvidencia">Texto da evidência</label>
      <textarea class="input" id="conteudoEvidencia" rows="3" placeholder="Descreva a ocorrência com ao menos 10 caracteres"></textarea>
    </div>

    <div class="campo" id="evidenciaAudioCampo" style="display: none;">
      <label class="campo__rotulo" for="urlArquivoAudio">URL do áudio</label>
      <input class="input" id="urlArquivoAudio" type="text" placeholder="https://..." />
      <label class="campo__rotulo" for="duracaoAudio" style="margin-top: 8px;">Duração em segundos</label>
      <input class="input" id="duracaoAudio" type="number" min="3" step="1" placeholder="3" />
    </div>

    <div class="campo" id="evidenciaFotoCampo" style="display: none;">
      <label class="campo__rotulo" for="urlArquivoFoto">URL da foto</label>
      <input class="input" id="urlArquivoFoto" type="text" placeholder="https://..." />
      <label class="campo__rotulo" for="latitudeFoto" style="margin-top: 8px;">Latitude</label>
      <input class="input" id="latitudeFoto" type="number" step="any" placeholder="-16.5" />
      <label class="campo__rotulo" for="longitudeFoto" style="margin-top: 8px;">Longitude</label>
      <input class="input" id="longitudeFoto" type="number" step="any" placeholder="-55.7" />
    </div>

    <button type="submit" class="btn-primario" id="btnSalvar" style="margin-top: 6px;">
      Salvar movimentação
    </button>
  </form>

  <%- include('../partials/bottomnav-capataz', { ativa: 'movimentacao' }) %>
</main>

<script>
  const CAPATAZ_DEMO = {
    id: '11111111-1111-1111-1111-111111111111',
    nome: 'Capataz Daniel',
    cargo: 'capataz',
    retiro_id: '00000000-0000-4000-8000-000000000001',
  };

  const form = document.getElementById('form-movimentacao');
  const feedback = document.getElementById('mov-feedback');
  const tipoMov = document.getElementById('tipoMov');
  const campoDestino = document.getElementById('campoDestino');
  const campoCausa = document.getElementById('campoCausa');
  const rotuloOrigem = document.getElementById('rotuloOrigem');
  const origemMov = document.getElementById('origemMov');
  const destinoMov = document.getElementById('destinoMov');
  const quantidadeMov = document.getElementById('quantidadeMov');
  const estagioMov = document.getElementById('estagioMov');
  const causaObito = document.getElementById('causaObito');
  const tipoEvidencia = document.getElementById('tipoEvidencia');
  const evidenciaMensagemCampo = document.getElementById('evidenciaMensagemCampo');
  const evidenciaAudioCampo = document.getElementById('evidenciaAudioCampo');
  const evidenciaFotoCampo = document.getElementById('evidenciaFotoCampo');

  function getSession() {
    try {
      const token = localStorage.getItem('agroflow.token');
      const usuarioRaw = localStorage.getItem('agroflow.usuario');

      if (!usuarioRaw) {
        return null;
      }

      return {
        token,
        usuario: JSON.parse(usuarioRaw),
      };
    } catch {
      return null;
    }
  }

  function mostrarFeedback(mensagem, tipo) {
    if (!feedback) return;
    feedback.textContent = mensagem;
    feedback.style.color = tipo === 'error' ? '#b42318' : '#146c43';
  }

  function atualizarEstadoEvidencia() {
    const tipo = tipoEvidencia.value;
    evidenciaMensagemCampo.style.display = tipo === 'mensagem' ? 'block' : 'none';
    evidenciaAudioCampo.style.display = tipo === 'audio' ? 'block' : 'none';
    evidenciaFotoCampo.style.display = tipo === 'foto' ? 'block' : 'none';
  }

  function atualizarCampos() {
    const tipo = tipoMov.value;
    const ehTransferencia = tipo === 'transferencia';
    const ehMorte = tipo === 'morte';

    campoDestino.style.display = ehTransferencia ? 'block' : 'none';
    campoCausa.style.display = ehMorte ? 'block' : 'none';
    rotuloOrigem.textContent = ehTransferencia ? 'Retiro de origem' : 'Retiro';

    if (!ehTransferencia) {
      destinoMov.value = '';
    }

    if (!ehMorte) {
      causaObito.value = '';
    }
  }

  function selecionarEvidencia(tipo) {
    tipoEvidencia.value = tipo;
    document.querySelectorAll('.evidencia__btn').forEach(btn => {
      btn.classList.toggle('evidencia__btn--ativo', btn.dataset.evidencia === tipo);
    });
    atualizarEstadoEvidencia();
  }

  function obterEvidencia() {
    const tipo = tipoEvidencia.value;

    if (tipo === 'mensagem') {
      const conteudo = document.getElementById('conteudoEvidencia').value.trim();
      if (conteudo.length < 10) {
        throw new Error('A evidência em texto precisa ter ao menos 10 caracteres.');
      }
      return { tipo: 'mensagem', conteudo };
    }

    if (tipo === 'audio') {
      const urlArquivo = document.getElementById('urlArquivoAudio').value.trim();
      const duracao = Number(document.getElementById('duracaoAudio').value);

      if (!urlArquivo) {
        throw new Error('Informe a URL do áudio.');
      }

      if (!Number.isFinite(duracao) || duracao < 3) {
        throw new Error('A duração do áudio precisa ser de pelo menos 3 segundos.');
      }

      return { tipo: 'audio', urlArquivo, duracao };
    }

    const urlArquivo = document.getElementById('urlArquivoFoto').value.trim();
    const latitude = Number(document.getElementById('latitudeFoto').value);
    const longitude = Number(document.getElementById('longitudeFoto').value);

    if (!urlArquivo) {
      throw new Error('Informe a URL da foto.');
    }

    if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) {
      throw new Error('Latitude e longitude são obrigatórias para foto.');
    }

    return { tipo: 'foto', urlArquivo, latitude, longitude };
  }

  tipoMov.addEventListener('change', atualizarCampos);
  document.querySelectorAll('.evidencia__btn').forEach(btn => {
    btn.addEventListener('click', () => selecionarEvidencia(btn.dataset.evidencia));
  });

  atualizarCampos();
  selecionarEvidencia('mensagem');

  form.addEventListener('submit', async event => {
    event.preventDefault();

    const session = getSession();
    const usuario = session?.usuario ?? CAPATAZ_DEMO;
    const tipo = tipoMov.value;
    const origem = origemMov.value;
    const destino = destinoMov.value;
    const quantidade = quantidadeMov.value ? Number(quantidadeMov.value) : null;
    const estagio = estagioMov.value;

    if (!tipo || !origem || !estagio) {
      mostrarFeedback('Preencha tipo, retiro e estágio da vida.', 'error');
      return;
    }

    if (tipo === 'transferencia' && !destino) {
      mostrarFeedback('Selecione o retiro de destino.', 'error');
      return;
    }

    if ((tipo === 'compra' || tipo === 'venda' || tipo === 'transferencia' || tipo === 'nascimento') && (!quantidade || quantidade <= 0)) {
      mostrarFeedback('Informe uma quantidade válida de animais.', 'error');
      return;
    }

    if (tipo === 'morte' && !causaObito.value) {
      mostrarFeedback('Informe a causa do óbito.', 'error');
      return;
    }

    let evidencia;

    try {
      evidencia = obterEvidencia();
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Evidência inválida.', 'error');
      return;
    }

    const botao = document.getElementById('btnSalvar');
    if (botao) {
      botao.disabled = true;
      botao.textContent = 'Salvando...';
    }

    try {
      const payload = {
        retiro_id: usuario.retiro_id ?? CAPATAZ_DEMO.retiro_id,
        capataz_id: usuario.id ?? CAPATAZ_DEMO.id,
        tipo,
        origem: origem || null,
        destino: tipo === 'transferencia' ? destino : null,
        quantidade,
        causa_obito: tipo === 'morte' ? causaObito.value : null,
        estagio_vida: estagio,
        evidencia,
      };

      const response = await fetch('/movimentacoes', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(session?.token ? { Authorization: `Bearer ${session.token}` } : {}),
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data.error || 'Não foi possível salvar a movimentação.');
      }

      mostrarFeedback('Movimentação salva com sucesso.', 'success');
      form.reset();
      atualizarCampos();
      selecionarEvidencia('mensagem');
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao salvar movimentação.', 'error');
    } finally {
      if (botao) {
        botao.disabled = false;
        botao.textContent = 'Salvar movimentação';
      }
    }
  });
</script>

</body>
</html>
