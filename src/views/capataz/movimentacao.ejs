<%- include('../partials/capataz-head', { titulo: 'Alow · Nova Movimentação' }) %>

<%
  var RETIROS = ['Acurizal','Aroeira','Baia Bonita','Bodoquena 1','Bodoquena 2','Boqueirão','Caieira','CMB','Confinamento','Cristo','Morada Nova','Morro Azul','Puga','São Miguel','Vista Alegre'];
  var TIPOS = [
    { value: 'nascimento', label: 'Nascimento' },
    { value: 'morte', label: 'Morte' },
    { value: 'transferencia', label: 'Transferência' }
  ];
  var ESTAGIOS = [
    'BEZERRO 0 A 7 MESES',
    'GARROTE 8 A 12 MESES',
    'NOVILHA 8 A 12 MESES',
    'GARROTE 13 A 24 MESES',
    'NOVILHA 13 A 24 MESES',
    'BOI 25 A 36 MESES',
    'NOVILHA 25 A 36 MESES',
    'TOURO 25 A 36 MESES',
    'VACA ACIMA 36 MESES',
    'BOI ACIMA 36 MESES',
    'TOURO ACIMA 36 MESES'
  ];
  var CAUSAS = ['Doença','Acidente','Predador','Causa natural','Desconhecida'];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/home" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Nova Movimentação</span>
    </div>
  </header>

  <p id="mov-feedback" style="margin: 12px 16px 0; font-size: 14px; line-height: 1.4;"></p>

  <div class="conteudo">
    <div class="campo">
      <label class="campo__rotulo" for="tipoMov">Tipo de movimentação</label>
      <select class="select" id="tipoMov" required>
        <option value="" disabled selected>Selecione o tipo</option>
        <% TIPOS.forEach(function (item) { %>
          <option value="<%= item.value %>"><%= item.label %></option>
        <% }) %>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="retiroMov">Retiro</label>
      <select class="select" id="retiroMov" required>
        <option value="" disabled selected>Selecione o retiro</option>
        <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
      </select>
    </div>

    <div id="camposPadrao">
      <div class="campo">
        <label class="campo__rotulo" for="origemMov">Retiro de origem</label>
        <select class="select" id="origemMov">
          <option value="">Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
        </select>
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="destinoMov">Retiro de destino</label>
        <select class="select" id="destinoMov">
          <option value="">Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
        </select>
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="quantidadeMov">Quantidade de animais</label>
        <input class="input" type="number" id="quantidadeMov" min="1" placeholder="Ex: 12" />
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="estagioMov">Estágio da vida</label>
        <select class="select" id="estagioMov">
          <option value="" disabled selected>Selecione o estágio</option>
          <% ESTAGIOS.forEach(function (e) { %><option value="<%= e %>"><%= e %></option><% }) %>
        </select>
      </div>
    </div>

    <div id="camposMorte" style="display: none;">
      <div class="campo">
        <label class="campo__rotulo" for="origemMorte">Retiro de origem</label>
        <select class="select" id="origemMorte">
          <option value="">Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
        </select>
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="quantidadeMorte">Quantidade</label>
        <input class="input" type="number" id="quantidadeMorte" min="1" placeholder="Ex: 3" />
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="estagioMorte">Estágio da vida</label>
        <select class="select" id="estagioMorte">
          <option value="" disabled selected>Selecione o estágio</option>
          <% ESTAGIOS.forEach(function (e) { %><option value="<%= e %>"><%= e %></option><% }) %>
        </select>
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="causaObito">Causa do óbito <span class="obrigatorio">*</span></label>
        <select class="select" id="causaObito">
          <option value="" disabled selected>Selecione a causa</option>
          <% CAUSAS.forEach(function (c) { %><option value="<%= c %>"><%= c %></option><% }) %>
        </select>
      </div>
    </div>

    <div class="campo">
      <label class="campo__rotulo">Evidência</label>
      <div class="evidencia">
        <button type="button" class="evidencia__btn evidencia__btn--foto">Foto</button>
        <button type="button" class="evidencia__btn evidencia__btn--audio">Áudio</button>
        <button type="button" class="evidencia__btn evidencia__btn--texto">Texto</button>
      </div>
    </div>

    <button type="button" class="btn-primario" id="btnSalvar" style="margin-top: 6px;">
      Salvar movimentação
    </button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'movimentacao' }) %>
</main>

<script>
  const CAPATAZ_DEMO = {
    id: '11111111-1111-1111-1111-111111111111',
  };

  const tipoMov = document.getElementById('tipoMov');
  const camposPadrao = document.getElementById('camposPadrao');
  const camposMorte = document.getElementById('camposMorte');
  const feedback = document.getElementById('mov-feedback');
  const botaoSalvar = document.getElementById('btnSalvar');

  function mostrarFeedback(mensagem, tipo) {
    if (!feedback) return;
    feedback.textContent = mensagem;
    feedback.style.color = tipo === 'error' ? '#b42318' : '#146c43';
  }

  function atualizarVisibilidadeCampos() {
    const ehMorte = tipoMov.value === 'morte';
    camposMorte.style.display = ehMorte ? 'block' : 'none';
    camposPadrao.style.display = ehMorte ? 'none' : 'block';
  }

  function obterValorPrimeiro(ids) {
    for (const id of ids) {
      const el = document.getElementById(id);
      if (el && String(el.value || '').trim()) {
        return String(el.value).trim();
      }
    }
    return '';
  }

  function obterNumeroOuNulo(ids) {
    const valor = obterValorPrimeiro(ids);
    if (!valor) return null;
    const numero = Number(valor);
    return Number.isNaN(numero) ? null : numero;
  }

  function montarPayload() {
    const tipo = tipoMov.value;
    const retiro = document.getElementById('retiroMov').value;

    if (!tipo || !retiro) {
      throw new Error('Selecione o tipo e o retiro.');
    }

    const payload = {
      retiro_id: 1,
      capataz_id: CAPATAZ_DEMO.id,
      tipo,
      estagio_vida: tipo === 'morte'
        ? obterValorPrimeiro(['estagioMorte'])
        : obterValorPrimeiro(['estagioMov']),
      origem: tipo === 'morte'
        ? obterValorPrimeiro(['origemMorte'])
        : obterValorPrimeiro(['origemMov']),
      destino: tipo === 'transferencia'
        ? obterValorPrimeiro(['destinoMov'])
        : undefined,
      quantidade: tipo === 'morte'
        ? null
        : obterNumeroOuNulo(['quantidadeMov', 'quantidadeMorte']),
      causa_obito: tipo === 'morte' ? obterValorPrimeiro(['causaObito']) : undefined,
      sincronizado: false,
    };

    if (!payload.estagio_vida) {
      throw new Error('Selecione o estágio da vida.');
    }

    if (tipo === 'morte') {
      if (!payload.origem || !payload.causa_obito) {
        throw new Error('Preencha origem e causa do óbito.');
      }
    }

    if (tipo === 'nascimento') {
      if (!payload.origem || !payload.quantidade) {
        throw new Error('Preencha origem e quantidade.');
      }
      payload.destino = undefined;
      payload.causa_obito = undefined;
    }

    if (tipo === 'transferencia') {
      if (!payload.origem || !payload.destino || !payload.quantidade) {
        throw new Error('Preencha origem, destino e quantidade.');
      }
      payload.causa_obito = undefined;
    }

    return payload;
  }

  async function salvarMovimentacao() {
    try {
      botaoSalvar.disabled = true;
      botaoSalvar.textContent = 'Enviando...';

      const payload = montarPayload();
      const response = await fetch('/movimentacoes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(data.error || 'Não foi possível salvar a movimentação');
      }

      mostrarFeedback('Movimentação registrada com sucesso.', 'success');
      document.querySelectorAll('.select, .input').forEach(el => {
        if (el instanceof HTMLInputElement) {
          el.value = '';
        } else {
          el.selectedIndex = 0;
        }
      });
      atualizarVisibilidadeCampos();
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao salvar movimentação', 'error');
    } finally {
      botaoSalvar.disabled = false;
      botaoSalvar.textContent = 'Salvar movimentação';
    }
  }

  tipoMov.addEventListener('change', atualizarVisibilidadeCampos);
  botaoSalvar.addEventListener('click', salvarMovimentacao);

  atualizarVisibilidadeCampos();
</script>

</body>
</html>
