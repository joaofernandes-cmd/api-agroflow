<%- include('../partials/capataz-head', { titulo: 'Alow · Nova Movimentação' }) %>

<%
  /* Listas hardcoded — depois podem vir do back-end. */
  var RETIROS = ['Acurizal','Aroeira','Baia Bonita','Bodoquena 1','Bodoquena 2',
    'Boqueirão','Caieira','CMB','Confinamento','Cristo','Morada Nova','Morro Azul',
    'Puga','São Miguel','Vista Alegre'];
  var TIPOS = ['Nascimento','Morte','Transferência'];
  var ESTAGIOS = ['Bezerro','Novilho','Adulto'];
  var CAUSAS = ['Doença','Acidente','Predador','Causa natural','Desconhecida'];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/home" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Nova Movimentação</span>
    </div>
  </header>

  <div class="conteudo">
    <div class="campo">
      <label class="campo__rotulo">Tipo de movimentação</label>
      <select class="select" id="tipoMov" required>
        <option value="" disabled selected>Nascimento / Morte / Transferência...</option>
        <% TIPOS.forEach(function (t) { %><option value="<%= t %>"><%= t %></option><% }) %>
      </select>
    </div>

    <!-- Campos para Nascimento / Transferência -->
    <div id="camposPadrao">
      <div class="campo">
        <label class="campo__rotulo">Retiro de origem</label>
        <select class="select" required>
          <option value="" disabled selected>Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option><%= r %></option><% }) %>
        </select>
      </div>
      <div class="campo">
        <label class="campo__rotulo">Retiro de destino</label>
        <select class="select" required>
          <option value="" disabled selected>Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option><%= r %></option><% }) %>
        </select>
      </div>
      <div class="campo">
        <label class="campo__rotulo">Quantidade de animais</label>
        <input class="input" type="number" placeholder="Ex: 12" />
      </div>
      <div class="campo">
        <label class="campo__rotulo">Estágio da vida</label>
        <select class="select" required>
          <option value="" disabled selected>Bezerro / Novilho / Adulto</option>
          <% ESTAGIOS.forEach(function (e) { %><option><%= e %></option><% }) %>
        </select>
      </div>
    </div>

    <!-- Campos específicos de Morte (escondidos por padrão) -->
    <div id="camposMorte" style="display: none;">
      <div class="campo">
        <label class="campo__rotulo">Retiro</label>
        <select class="select" required>
          <option value="" disabled selected>Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option><%= r %></option><% }) %>
        </select>
      </div>
      <div class="campo">
        <label class="campo__rotulo">Quantidade</label>
        <input class="input" type="number" placeholder="Ex: 3" />
      </div>
      <div class="campo">
        <label class="campo__rotulo">Estágio da vida</label>
        <select class="select" required>
          <option value="" disabled selected>Bezerro / Novilho / Adulto</option>
          <% ESTAGIOS.forEach(function (e) { %><option><%= e %></option><% }) %>
        </select>
      </div>
      <div class="campo">
        <label class="campo__rotulo">Causa do óbito <span class="obrigatorio">*</span></label>
        <select class="select" id="causaObito" required>
          <option value="" disabled selected>Selecione a causa...</option>
          <% CAUSAS.forEach(function (c) { %><option><%= c %></option><% }) %>
        </select>
      </div>
    </div>

    <div class="campo">
      <label class="campo__rotulo">Evidência (obrigatório)</label>
      <div class="evidencia">
        <button type="button" class="evidencia__btn evidencia__btn--foto">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
          Foto
        </button>
        <button type="button" class="evidencia__btn evidencia__btn--audio">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0 0 14 0"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
          Áudio
        </button>
        <button type="button" class="evidencia__btn evidencia__btn--texto">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
          Texto
        </button>
      </div>
    </div>

    <button type="button" class="btn-primario" id="btnSalvar" style="margin-top: 6px;">
      Salvar movimentação
    </button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'movimentacao' }) %>
</main>

<script>
  // Alterna os campos conforme o tipo selecionado (Morte tem formulário próprio).
  var tipoMov = document.getElementById('tipoMov');
  var camposPadrao = document.getElementById('camposPadrao');
  var camposMorte = document.getElementById('camposMorte');

  tipoMov.addEventListener('change', function () {
    var ehMorte = tipoMov.value === 'Morte';
    camposMorte.style.display = ehMorte ? 'block' : 'none';
    camposPadrao.style.display = ehMorte ? 'none' : 'block';
  });

  // Validação visual do campo obrigatório (Causa do óbito) ao salvar.
  document.getElementById('btnSalvar').addEventListener('click', function () {
    if (tipoMov.value === 'Morte') {
      var causa = document.getElementById('causaObito');
      if (!causa.value) causa.classList.add('erro');
      else causa.classList.remove('erro');
    }
  });
</script>

</body>
</html>
