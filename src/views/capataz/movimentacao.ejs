<%- include('../partials/capataz-head', { titulo: 'Alow · Nova Movimentação' }) %>

<%
  var RETIROS = ['Acurizal','Aroeira','Baia Bonita','Bodoquena 1','Bodoquena 2','Boqueirão','Caieira','CMB','Confinamento','Cristo','Morada Nova','Morro Azul','Puga','São Miguel','Vista Alegre'];
  var TIPOS = [
    { value: 'nascimento', label: 'Nascimento' },
    { value: 'morte', label: 'Morte' },
    { value: 'transferencia', label: 'Transferência' }
  ];
  var ESTAGIOS = [
    'BEZERRO 0 A 7 MESES',
    'GARROTE 8 A 12 MESES',
    'NOVILHA 8 A 12 MESES',
    'GARROTE 13 A 24 MESES',
    'NOVILHA 13 A 24 MESES',
    'BOI 25 A 36 MESES',
    'NOVILHA 25 A 36 MESES',
    'TOURO 25 A 36 MESES',
    'VACA ACIMA 36 MESES',
    'BOI ACIMA 36 MESES',
    'TOURO ACIMA 36 MESES'
  ];
  var CAUSAS = ['Doença','Acidente','Predador','Causa natural','Desconhecida'];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/home" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Nova Movimentação</span>
    </div>
  </header>

  <p id="mov-feedback" style="margin: 12px 16px 0; font-size: 14px; line-height: 1.4;"></p>

  <div class="conteudo">
    <div class="campo">
      <label class="campo__rotulo" for="tipoMov">Tipo de movimentação</label>
      <select class="select" id="tipoMov" required>
        <option value="" disabled selected>Selecione o tipo</option>
        <% TIPOS.forEach(function (item) { %>
          <option value="<%= item.value %>"><%= item.label %></option>
        <% }) %>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="retiroMov">Retiro</label>
      <select class="select" id="retiroMov" required>
        <option value="" disabled selected>Selecione o retiro</option>
        <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
      </select>
    </div>

    <div id="camposPadrao">
      <div class="campo">
        <label class="campo__rotulo" for="origemMov">Retiro de origem</label>
        <select class="select" id="origemMov">
          <option value="">Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
        </select>
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="destinoMov">Retiro de destino</label>
        <select class="select" id="destinoMov">
          <option value="">Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
        </select>
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="quantidadeMov">Quantidade de animais</label>
        <input class="input" type="number" id="quantidadeMov" min="1" placeholder="Ex: 12" />
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="estagioMov">Estágio da vida</label>
        <select class="select" id="estagioMov">
          <option value="" disabled selected>Selecione o estágio</option>
          <% ESTAGIOS.forEach(function (e) { %><option value="<%= e %>"><%= e %></option><% }) %>
        </select>
      </div>
    </div>

    <div id="camposMorte" style="display: none;">
      <div class="campo">
        <label class="campo__rotulo" for="origemMorte">Retiro de origem</label>
        <select class="select" id="origemMorte">
          <option value="">Selecione o retiro</option>
          <% RETIROS.forEach(function (r) { %><option value="<%= r %>"><%= r %></option><% }) %>
        </select>
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="quantidadeMorte">Quantidade</label>
        <input class="input" type="number" id="quantidadeMorte" min="1" placeholder="Ex: 3" />
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="estagioMorte">Estágio da vida</label>
        <select class="select" id="estagioMorte">
          <option value="" disabled selected>Selecione o estágio</option>
          <% ESTAGIOS.forEach(function (e) { %><option value="<%= e %>"><%= e %></option><% }) %>
        </select>
      </div>

      <div class="campo">
        <label class="campo__rotulo" for="causaObito">Causa do óbito <span class="obrigatorio">*</span></label>
        <select class="select" id="causaObito">
          <option value="" disabled selected>Selecione a causa</option>
          <% CAUSAS.forEach(function (c) { %><option value="<%= c %>"><%= c %></option><% }) %>
        </select>
      </div>
    </div>

    <div class="campo">
      <label class="campo__rotulo">Evidência</label>
      <div class="evidencia">
        <button type="button" class="evidencia__btn evidencia__btn--foto" data-evidencia="foto">Foto</button>
        <button type="button" class="evidencia__btn evidencia__btn--audio" data-evidencia="audio">Áudio</button>
        <button type="button" class="evidencia__btn evidencia__btn--texto" data-evidencia="texto">Texto</button>
      </div>
    </div>

    <div id="painelEvidencia" class="painel-evidencia" hidden>
      <div class="campo" id="campoTextoEvidencia" hidden>
        <label class="campo__rotulo" for="textoEvidencia">Mensagem da evidência</label>
        <textarea class="input" id="textoEvidencia" rows="4" placeholder="Descreva a movimentação com pelo menos 10 caracteres"></textarea>
      </div>

      <div class="campo" id="campoArquivoEvidencia" hidden>
        <label class="campo__rotulo" id="rotuloArquivoEvidencia" for="arquivoEvidencia">Arquivo</label>
        <input class="input" type="file" id="arquivoEvidencia" />
        <p class="ajuda-evidencia" id="arquivoSelecionado">Nenhum arquivo selecionado.</p>
      </div>

      <div id="camposFotoEvidencia" hidden>
        <div class="campo">
          <label class="campo__rotulo" for="latitudeFoto">Latitude</label>
          <input class="input" type="number" id="latitudeFoto" step="any" placeholder="Ex: -19.9234" />
        </div>

        <div class="campo">
          <label class="campo__rotulo" for="longitudeFoto">Longitude</label>
          <input class="input" type="number" id="longitudeFoto" step="any" placeholder="Ex: -57.1234" />
        </div>

        <button type="button" class="btn-secundario" id="btnLocalizacaoFoto" style="margin-bottom: 12px;">
          Usar localização atual
        </button>
      </div>

      <div class="preview-evidencia" id="previewEvidencia" hidden></div>
    </div>

    <button type="button" class="btn-primario" id="btnSalvar" style="margin-top: 6px;">
      Salvar movimentação
    </button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'movimentacao' }) %>
</main>

<script>
  const CAPATAZ_DEMO = {
    id: '11111111-1111-1111-1111-111111111111',
  };

  const RETIROS = <%- JSON.stringify(RETIROS) %>;
  const tipoMov = document.getElementById('tipoMov');
  const retiroMov = document.getElementById('retiroMov');
  const camposPadrao = document.getElementById('camposPadrao');
  const camposMorte = document.getElementById('camposMorte');
  const feedback = document.getElementById('mov-feedback');
  const botaoSalvar = document.getElementById('btnSalvar');
  const painelEvidencia = document.getElementById('painelEvidencia');
  const campoTextoEvidencia = document.getElementById('campoTextoEvidencia');
  const campoArquivoEvidencia = document.getElementById('campoArquivoEvidencia');
  const camposFotoEvidencia = document.getElementById('camposFotoEvidencia');
  const textoEvidencia = document.getElementById('textoEvidencia');
  const arquivoEvidencia = document.getElementById('arquivoEvidencia');
  const arquivoSelecionado = document.getElementById('arquivoSelecionado');
  const previewEvidencia = document.getElementById('previewEvidencia');
  const rotuloArquivoEvidencia = document.getElementById('rotuloArquivoEvidencia');
  const btnLocalizacaoFoto = document.getElementById('btnLocalizacaoFoto');
  const latitudeFoto = document.getElementById('latitudeFoto');
  const longitudeFoto = document.getElementById('longitudeFoto');
  const botoesEvidencia = Array.from(document.querySelectorAll('[data-evidencia]'));

  let modoEvidencia = '';
  let arquivoEmBase64 = '';
  let duracaoAudio = null;

  function mostrarFeedback(mensagem, tipo) {
    if (!feedback) return;
    feedback.textContent = mensagem;
    feedback.style.color = tipo === 'error' ? '#b42318' : '#146c43';
  }

  function atualizarVisibilidadeCampos() {
    const ehMorte = tipoMov.value === 'morte';
    camposMorte.style.display = ehMorte ? 'block' : 'none';
    camposPadrao.style.display = ehMorte ? 'none' : 'block';
  }

  function limparEvidencia() {
    textoEvidencia.value = '';
    arquivoEvidencia.value = '';
    arquivoEmBase64 = '';
    duracaoAudio = null;
    arquivoSelecionado.textContent = 'Nenhum arquivo selecionado.';
    previewEvidencia.hidden = true;
    previewEvidencia.innerHTML = '';
    latitudeFoto.value = '';
    longitudeFoto.value = '';
  }

  function atualizarModoEvidencia(novoModo) {
    modoEvidencia = modoEvidencia === novoModo ? '' : novoModo;

    botoesEvidencia.forEach(botao => {
      botao.classList.toggle('ativo', botao.dataset.evidencia === modoEvidencia);
    });

    painelEvidencia.hidden = !modoEvidencia;
    campoTextoEvidencia.hidden = modoEvidencia !== 'texto';
    campoArquivoEvidencia.hidden = modoEvidencia === '' || modoEvidencia === 'texto';
    camposFotoEvidencia.hidden = modoEvidencia !== 'foto';

    limparEvidencia();

    if (modoEvidencia === 'texto') {
      previewEvidencia.hidden = false;
      previewEvidencia.textContent = 'Digite a mensagem da evidência abaixo.';
      arquivoEvidencia.removeAttribute('accept');
      rotuloArquivoEvidencia.textContent = 'Arquivo';
      return;
    }

    if (modoEvidencia === 'audio') {
      previewEvidencia.hidden = false;
      previewEvidencia.textContent = 'Selecione um arquivo de áudio para anexar.';
      arquivoEvidencia.accept = 'audio/*';
      rotuloArquivoEvidencia.textContent = 'Arquivo de áudio';
      return;
    }

    if (modoEvidencia === 'foto') {
      previewEvidencia.hidden = false;
      previewEvidencia.textContent = 'Selecione uma foto para anexar e informe as coordenadas.';
      arquivoEvidencia.accept = 'image/*';
      rotuloArquivoEvidencia.textContent = 'Arquivo de foto';
    }
  }

  function obterValorPrimeiro(ids) {
    for (const id of ids) {
      const el = document.getElementById(id);
      if (el && String(el.value || '').trim()) {
        return String(el.value).trim();
      }
    }
    return '';
  }

  function obterNumeroOuNulo(ids) {
    const valor = obterValorPrimeiro(ids);
    if (!valor) return null;
    const numero = Number(valor);
    return Number.isNaN(numero) ? null : numero;
  }

  function arquivoParaBase64(file) {
    return new Promise((resolve, reject) => {
      const leitor = new FileReader();
      leitor.onload = () => resolve(String(leitor.result || ''));
      leitor.onerror = () => reject(new Error('Não foi possível ler o arquivo selecionado.'));
      leitor.readAsDataURL(file);
    });
  }

  function obterDuracaoAudio(file) {
    return new Promise((resolve, reject) => {
      const audio = document.createElement('audio');
      const url = URL.createObjectURL(file);

      audio.preload = 'metadata';
      audio.onloadedmetadata = () => {
        URL.revokeObjectURL(url);
        resolve(audio.duration);
      };
      audio.onerror = () => {
        URL.revokeObjectURL(url);
        reject(new Error('Não foi possível ler a duração do áudio.'));
      };
      audio.src = url;
    });
  }

  function preencherLocalizacaoAtual() {
    if (!navigator.geolocation) {
      mostrarFeedback('Seu navegador não suporta localização automática.', 'error');
      return;
    }

    navigator.geolocation.getCurrentPosition(
      position => {
        latitudeFoto.value = String(position.coords.latitude);
        longitudeFoto.value = String(position.coords.longitude);
        mostrarFeedback('Localização atual preenchida.', 'success');
      },
      () => {
        mostrarFeedback('Não foi possível obter a localização atual.', 'error');
      },
      { enableHighAccuracy: true, timeout: 10000 }
    );
  }

  async function prepararArquivoSelecionado(file) {
    if (!file) {
      arquivoSelecionado.textContent = 'Nenhum arquivo selecionado.';
      arquivoEmBase64 = '';
      duracaoAudio = null;
      return;
    }

    arquivoEmBase64 = await arquivoParaBase64(file);
    arquivoSelecionado.textContent = `Selecionado: ${file.name}`;

    if (modoEvidencia === 'audio') {
      duracaoAudio = await obterDuracaoAudio(file);
      previewEvidencia.textContent = `Áudio pronto para envio. Duração aproximada: ${duracaoAudio.toFixed(1)} segundos.`;
      return;
    }

    if (modoEvidencia === 'foto') {
      previewEvidencia.textContent = `Foto pronta para envio: ${file.name}`;
    }
  }

  async function montarEvidencia() {
    if (!modoEvidencia) {
      return null;
    }

    if (modoEvidencia === 'texto') {
      const conteudo = textoEvidencia.value.trim();
      if (!conteudo) {
        throw new Error('Digite a mensagem da evidência.');
      }

      return {
        tipo: 'mensagem',
        conteudo,
      };
    }

    if (!arquivoEvidencia.files || arquivoEvidencia.files.length === 0) {
      throw new Error('Selecione um arquivo para a evidência.');
    }

    if (!arquivoEmBase64) {
      await prepararArquivoSelecionado(arquivoEvidencia.files[0]);
    }

    if (modoEvidencia === 'audio') {
      if (duracaoAudio === null) {
        duracaoAudio = await obterDuracaoAudio(arquivoEvidencia.files[0]);
      }

      return {
        tipo: 'audio',
        urlArquivo: arquivoEmBase64,
        duracao: Number(duracaoAudio),
      };
    }

    if (modoEvidencia === 'foto') {
      const latitude = Number(latitudeFoto.value);
      const longitude = Number(longitudeFoto.value);

      if (Number.isNaN(latitude) || Number.isNaN(longitude)) {
        throw new Error('Preencha latitude e longitude da foto ou use a localização atual.');
      }

      return {
        tipo: 'foto',
        urlArquivo: arquivoEmBase64,
        latitude,
        longitude,
      };
    }

    return null;
  }

  function montarPayloadBase() {
    const tipo = tipoMov.value;
    const retiro = retiroMov.value;

    if (!tipo || !retiro) {
      throw new Error('Selecione o tipo e o retiro.');
    }

    const payload = {
      retiro_id: 1,
      capataz_id: CAPATAZ_DEMO.id,
      tipo,
      estagio_vida: tipo === 'morte'
        ? obterValorPrimeiro(['estagioMorte'])
        : obterValorPrimeiro(['estagioMov']),
      origem: tipo === 'morte'
        ? obterValorPrimeiro(['origemMorte'])
        : obterValorPrimeiro(['origemMov']),
      destino: tipo === 'transferencia'
        ? obterValorPrimeiro(['destinoMov'])
        : undefined,
      quantidade: tipo === 'morte'
        ? null
        : obterNumeroOuNulo(['quantidadeMov', 'quantidadeMorte']),
      causa_obito: tipo === 'morte' ? obterValorPrimeiro(['causaObito']) : undefined,
      sincronizado: false,
    };

    if (!payload.estagio_vida) {
      throw new Error('Selecione o estágio da vida.');
    }

    if (tipo === 'morte') {
      if (!payload.origem || !payload.causa_obito) {
        throw new Error('Preencha origem e causa do óbito.');
      }
    }

    if (tipo === 'nascimento') {
      if (!payload.origem || !payload.quantidade) {
        throw new Error('Preencha origem e quantidade.');
      }
      payload.destino = undefined;
      payload.causa_obito = undefined;
    }

    if (tipo === 'transferencia') {
      if (!payload.origem || !payload.destino || !payload.quantidade) {
        throw new Error('Preencha origem, destino e quantidade.');
      }
      payload.causa_obito = undefined;
    }

    return payload;
  }

  async function salvarMovimentacao() {
    try {
      botaoSalvar.disabled = true;
      botaoSalvar.textContent = 'Enviando...';

      const payload = montarPayloadBase();
      const evidencia = await montarEvidencia();
      if (evidencia) {
        payload.evidencia = evidencia;
      }

      const response = await fetch('/movimentacoes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(data.error || 'Não foi possível salvar a movimentação');
      }

      mostrarFeedback('Movimentação registrada com sucesso.', 'success');
      document.querySelectorAll('.select, .input, textarea').forEach(el => {
        if (el instanceof HTMLInputElement) {
          if (el.type === 'file') {
            el.value = '';
          } else {
            el.value = '';
          }
        } else if (el instanceof HTMLTextAreaElement) {
          el.value = '';
        } else if (el instanceof HTMLSelectElement) {
          el.selectedIndex = 0;
        }
      });
      modoEvidencia = '';
      botoesEvidencia.forEach(botao => botao.classList.remove('ativo'));
      painelEvidencia.hidden = true;
      limparEvidencia();
      atualizarVisibilidadeCampos();
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao salvar movimentação', 'error');
    } finally {
      botaoSalvar.disabled = false;
      botaoSalvar.textContent = 'Salvar movimentação';
    }
  }

  tipoMov.addEventListener('change', atualizarVisibilidadeCampos);
  botoesEvidencia.forEach(botao => {
    botao.addEventListener('click', () => atualizarModoEvidencia(String(botao.dataset.evidencia || '')));
  });
  arquivoEvidencia.addEventListener('change', async () => {
    try {
      await prepararArquivoSelecionado(arquivoEvidencia.files && arquivoEvidencia.files[0] ? arquivoEvidencia.files[0] : null);
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao ler arquivo selecionado', 'error');
    }
  });
  btnLocalizacaoFoto.addEventListener('click', preencherLocalizacaoAtual);
  botaoSalvar.addEventListener('click', salvarMovimentacao);

  atualizarVisibilidadeCampos();
</script>

</body>
</html>
