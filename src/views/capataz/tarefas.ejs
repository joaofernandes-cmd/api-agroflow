<%- include('../partials/capataz-head', { titulo: 'Alow · Minhas Tarefas' }) %>

<%
  var tarefas = [
    { cor: 'var(--alerta)', titulo: 'Vacinação lote B - Aroeira', sub: 'Supervisor Luiz • Amanhã 08:00', nivel: 'Alta', classe: 'alta' },
    { cor: 'var(--info)', titulo: 'Conferência do rebanho - CMB', sub: 'Supervisor Luiz • Hoje 14:00', nivel: 'Média', classe: 'media' },
    { cor: 'var(--texto-sec)', titulo: 'Inspeção sanitária - Puga', sub: 'Supervisor Luiz • Sex 10:00', nivel: 'Baixa', classe: 'baixa' },
    { cor: 'var(--primaria)', titulo: 'Alimentação suplementar - Cristo', sub: 'Supervisor Alberto • há 2 dias', nivel: 'Concluída', classe: 'concluida' },
    { cor: 'var(--primaria)', titulo: 'Movimentação - Bodoquena', sub: 'Supervisor José • há 3 dias', nivel: 'Concluída', classe: 'concluida' }
  ];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <span class="cabecalho__titulo">Minhas Tarefas</span>
    </div>
  </header>

  <div class="conteudo">
    <div class="busca-barra">
      <span class="busca-barra__texto">Pesquisar tarefas</span>
      <span class="etiqueta etiqueta--pendente">Pendente</span>
    </div>

    <div id="lista-tarefas">
      <% tarefas.forEach(function (t, index) { %>
        <a href="/capataz/detalhe-tarefa?id=<%= index + 1 %>" class="card">
          <span class="card__barra" style="background: <%= t.cor %>;"></span>
          <div class="card__corpo">
            <div class="card__titulo"><%= t.titulo %></div>
            <div class="card__sub"><%= t.sub %></div>
          </div>
          <span class="etiqueta etiqueta--<%= t.classe %>"><%= t.nivel %></span>
          <svg class="card__seta" width="18" height="18" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 6 6 6-6 6"/>
          </svg>
        </a>
      <% }) %>
    </div>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tarefas' }) %>
</main>

<script>
  function formatarData(valor) {
    if (!valor) return 'Sem data';
    const data = new Date(valor);
    if (Number.isNaN(data.getTime())) return 'Sem data';

    return data.toLocaleDateString('pt-BR', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
    });
  }

  function prioridadeParaClasse(prioridade) {
    if (prioridade === 'alta') return 'alta';
    if (prioridade === 'media') return 'media';
    return 'baixa';
  }

  async function carregarTarefas() {
    const lista = document.getElementById('lista-tarefas');
    if (!lista) return;

    try {
      const response = await fetch('/tarefas');
      const tarefasBackend = await response.json();

      if (!response.ok || !Array.isArray(tarefasBackend) || tarefasBackend.length === 0) {
        return;
      }

      lista.innerHTML = tarefasBackend.slice(0, 8).map(tarefa => {
        const classe = prioridadeParaClasse(tarefa.prioridade);
        const rotulo = tarefa.prioridade === 'alta'
          ? 'Alta'
          : tarefa.prioridade === 'media'
            ? 'Média'
            : 'Baixa';

        return `
          <a href="/capataz/detalhe-tarefa?id=${tarefa.id}" class="card">
            <span class="card__barra" style="background: var(--primaria);"></span>
            <div class="card__corpo">
              <div class="card__titulo">${tarefa.descricao}</div>
              <div class="card__sub">Retiro ${tarefa.retiro_id} • ${tarefa.categoria} • ${formatarData(tarefa.data_criacao)}</div>
            </div>
            <span class="etiqueta etiqueta--${classe}">${rotulo}</span>
            <svg class="card__seta" width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 6 6 6-6 6"/>
            </svg>
          </a>
        `;
      }).join('');
    } catch {
      // Mantém o conteúdo estático se a API não responder.
    }
  }

  carregarTarefas();
</script>

</body>
</html>
