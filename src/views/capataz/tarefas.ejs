<%- include('../partials/capataz-head', { titulo: 'Alow · Minhas Tarefas' }) %>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <span class="cabecalho__titulo">Minhas Tarefas</span>
    </div>
  </header>

  <div class="conteudo">
    <div class="busca-barra">
      <input type="search" id="busca-tarefas" class="busca-barra__input"
             placeholder="Pesquisar tarefas" aria-label="Pesquisar tarefas" autocomplete="off">
    </div>

    <div class="filtro-tarefas" role="tablist" aria-label="Filtrar tarefas">
      <button type="button" class="filtro-chip" data-filtro="todas">Todas</button>
      <button type="button" class="filtro-chip filtro-chip--ativo" data-filtro="pendente">Pendentes</button>
      <button type="button" class="filtro-chip" data-filtro="concluida">Concluídas</button>
    </div>

    <div id="lista-tarefas">
      <% tarefas.forEach(function (t, index) { %>
        <a href="/capataz/detalhe-tarefa?id=<%= index + 1 %>" class="card" data-status="<%= t.status %>">
          <span class="card__barra" style="background: <%= t.cor %>;"></span>
          <div class="card__corpo">
            <div class="card__titulo"><%= t.titulo %> - <%= t.retiro %></div>
            <div class="card__sub">Supervisor <%= t.supervisor %> • <%= t.prazo %></div>
          </div>
          <span class="etiqueta etiqueta--<%= t.classe %>"><%= t.nivel %></span>
          <svg class="card__seta" width="18" height="18" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 6 6 6-6 6"/>
          </svg>
        </a>
      <% }) %>
    </div>

    <p id="busca-vazia" class="busca-vazia" hidden>Nenhuma tarefa encontrada.</p>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tarefas' }) %>
</main>

<script>
  (function () {
    var input = document.getElementById('busca-tarefas');
    var lista = document.getElementById('lista-tarefas');
    var vazia = document.getElementById('busca-vazia');
    var chips = Array.prototype.slice.call(document.querySelectorAll('.filtro-chip'));
    if (!lista) return;

    var cards = Array.prototype.slice.call(lista.querySelectorAll('.card'));
    var filtroAtivo = 'pendente';

    function aplicarFiltros() {
      var termo = input ? input.value.trim().toLowerCase() : '';
      var buscando = termo.length > 0;
      var visiveis = 0;
      cards.forEach(function (card) {
        var status = card.getAttribute('data-status');
        var combinaBusca = card.textContent.toLowerCase().indexOf(termo) !== -1;
        // Ao pesquisar, procura em TODAS as tarefas (ignora o filtro de status).
        var combinaFiltro = buscando || filtroAtivo === 'todas' || status === filtroAtivo;
        var mostra = combinaBusca && combinaFiltro;
        card.style.display = mostra ? '' : 'none';
        if (mostra) visiveis++;
      });
      if (vazia) vazia.hidden = visiveis !== 0;

      // Enquanto pesquisa (mostra todas), nenhum filtro fica marcado como selecionado.
      chips.forEach(function (c) {
        var ativo = !buscando && c.getAttribute('data-filtro') === filtroAtivo;
        c.classList.toggle('filtro-chip--ativo', ativo);
      });
    }

    if (input) input.addEventListener('input', aplicarFiltros);

    chips.forEach(function (chip) {
      chip.addEventListener('click', function () {
        if (input) input.value = '';
        filtroAtivo = chip.getAttribute('data-filtro');
        aplicarFiltros();
      });
    });

    // Já abre filtrando pelas pendentes.
    aplicarFiltros();
  })();
</script>

</body>
</html>
