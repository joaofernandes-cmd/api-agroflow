<%- include('../partials/capataz-head', { titulo: 'Alow · Detalhe da Tarefa' }) %>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/tarefas" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Detalhe da Tarefa</span>
    </div>
  </header>

  <div class="conteudo">
    <div class="detalhe-card">
      <span class="detalhe-card__barra"></span>
      <div class="detalhe-card__conteudo">
        <div class="detalhe-card__titulo" id="tarefaTitulo"><%= tarefa.titulo %> — <%= tarefa.retiro %></div>
        <div class="detalhe-card__autor" id="tarefaAutor"><%= tarefa.autor %></div>
        <div class="detalhe-card__meta">
          <span class="etiqueta etiqueta--<%= tarefa.classe %>" id="tarefaNivel"><%= tarefa.nivel %></span>
          <span id="tarefaPrazo"><%= tarefa.prazo %></span>
        </div>
        <div class="detalhe-card__cat" id="tarefaCategoria"><%= tarefa.categoria %></div>
      </div>
    </div>

    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Retiro</span>
      <span class="detalhe-linha__valor" id="tarefaRetiro"><%= tarefa.retiro %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Data</span>
      <span class="detalhe-linha__valor" id="tarefaData"><%= tarefa.data %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Status</span>
      <span class="detalhe-linha__valor" id="statusTarefa"><%= tarefa.statusRotulo %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Supervisor</span>
      <span class="detalhe-linha__valor" id="tarefaSupervisor"><%= tarefa.supervisor %></span>
    </div>

    <label class="detalhe-descricao-rotulo">Descrição</label>
    <div class="detalhe-descricao" id="tarefaDescricao"><%= tarefa.descricao %></div>

    <!-- Evidências já registradas (aparece quando a tarefa está concluída) -->
    <div id="evidenciasSalvas" hidden style="margin-bottom: 12px;"></div>

    <button type="button" class="btn-secundario" id="btnEvidencia" style="margin-bottom: 12px;">Anexar evidência</button>

    <div id="painelEvidencia" hidden style="margin-bottom: 12px;">
      <%- include('evidencia', { ns: 'ev' }) %>
    </div>

    <p id="evidenciaErro" class="evidencia-erro" hidden>Anexe uma evidência (foto, áudio ou texto) para marcar como concluída.</p>
    <p id="tarefaSyncFeedback" class="evidencia-info" hidden></p>
    <button type="button" class="btn-primario" id="btnConcluir" <%= tarefa.status === 'concluida' ? 'disabled' : '' %>>
      <%= tarefa.status === 'concluida' ? 'Concluída' : 'Marcar como concluída' %>
    </button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tarefas' }) %>
</main>

<div id="dadosTarefa" hidden
     data-titulo="<%= tarefa.titulo %>"
     data-retiro="<%= tarefa.retiro %>"
     data-supervisor="<%= tarefa.supervisor %>"
     data-categoria="<%= tarefa.categoria %>"
     data-prioridade="<%= tarefa.classe %>"></div>
<script src="/js/tarefas-store.js"></script>
<script>
  var _el = document.getElementById('dadosTarefa');
  var DADOS_TAREFA = {
    id: new URLSearchParams(location.search).get('id') || '1',
    titulo: _el.dataset.titulo,
    retiro: _el.dataset.retiro,
    supervisor: _el.dataset.supervisor,
    categoria: _el.dataset.categoria,
    prioridade: _el.dataset.prioridade
  };

  var CAPATAZ_DEMO = {
    id: '11111111-1111-1111-1111-111111111111',
    retiro_id: '00000000-0000-4000-8000-000000000001'
  };

  (function () {
    var btnEvidencia = document.getElementById('btnEvidencia');
    var painel = document.getElementById('painelEvidencia');
    var evidenciaErro = document.getElementById('evidenciaErro');
    var btnConcluir = document.getElementById('btnConcluir');
    var status = document.getElementById('statusTarefa');
    var listaEvidencia = document.getElementById('evLista');
    var evidenciasSalvas = document.getElementById('evidenciasSalvas');
    var syncFeedback = document.getElementById('tarefaSyncFeedback');

    function evidenciasCapturadas() {
      var api = window.__evidencias && window.__evidencias['ev'];
      return api ? api.obter() : [];
    }

    // Mostra a tarefa como concluída + evidências (read-only).
    function mostrarConcluida(evidencias) {
      if (status) status.textContent = 'Concluída';
      if (btnConcluir) { btnConcluir.textContent = 'Concluída'; btnConcluir.disabled = true; }
      if (btnEvidencia) btnEvidencia.style.display = 'none';
      if (painel) painel.hidden = true;
      if (evidenciaErro) evidenciaErro.hidden = true;
      if (evidenciasSalvas && evidencias && evidencias.length && window.TarefasStore) {
        TarefasStore.renderEvidencias(evidencias, evidenciasSalvas);
        evidenciasSalvas.hidden = false;
      }
    }

    // Já estava concluída (salva antes)? Mostra o estado concluído.
    var salva = window.TarefasStore ? TarefasStore.obter(DADOS_TAREFA.id) : null;
    if (salva) {
      mostrarConcluida(salva.evidencias);
    }

    // "Anexar evidência" mostra/esconde o painel com os 3 tipos.
    if (btnEvidencia && painel) {
      btnEvidencia.addEventListener('click', function () {
        painel.hidden = !painel.hidden;
      });
    }

    // Some com o erro assim que o capataz anexa qualquer evidência.
    if (listaEvidencia) {
      new MutationObserver(function () {
        if (evidenciasCapturadas().length && evidenciaErro) evidenciaErro.hidden = true;
      }).observe(listaEvidencia, { childList: true });
    }

    function gerarUuidLocal() {
      if (window.crypto && typeof window.crypto.randomUUID === 'function') {
        return window.crypto.randomUUID();
      }
      return '00000000-0000-4000-8000-' + String(Date.now()).slice(-12).padStart(12, '0');
    }

    function prioridadeApi(valor) {
      return ['alta', 'media', 'baixa'].indexOf(valor) >= 0 ? valor : 'baixa';
    }

    function sincronizarConclusao(dataConclusao, evidencias) {
      if (!window.AgroFlowCapataz) return;

      var payload = {
        id: gerarUuidLocal(),
        retiro_id: CAPATAZ_DEMO.retiro_id,
        criada_por: CAPATAZ_DEMO.id,
        atribuida_a: CAPATAZ_DEMO.id,
        descricao: 'Conclusao da tarefa "' + DADOS_TAREFA.titulo + '" no retiro ' + DADOS_TAREFA.retiro + '. Evidencias anexadas: ' + evidencias.length + '.',
        categoria: DADOS_TAREFA.categoria || 'Operacional',
        prioridade: prioridadeApi(DADOS_TAREFA.prioridade),
        data_criacao: new Date().toISOString(),
        status: 'aprovado',
        aprovado_por: null,
        sincronizado: false
      };

      window.AgroFlowCapataz.fetchOrQueueOperation({
        kind: 'tarefa',
        url: '/tarefas/sincronizar',
        method: 'POST',
        body: payload,
        queueBody: payload
      }).then(function (resultado) {
        if (!syncFeedback) return;
        syncFeedback.textContent = resultado.queued
          ? 'Tarefa salva offline. Ela sera sincronizada automaticamente quando houver conexao.'
          : 'Tarefa concluida e sincronizada com sucesso.';
        syncFeedback.hidden = false;
      }).catch(function () {
        if (!syncFeedback) return;
        syncFeedback.textContent = 'Tarefa concluida localmente. A sincronizacao sera tentada novamente quando houver conexao.';
        syncFeedback.hidden = false;
      });
    }

    // Só conclui se houver pelo menos uma evidência (foto, áudio ou texto).
    if (btnConcluir && !salva) {
      btnConcluir.addEventListener('click', function () {
        var evid = evidenciasCapturadas();
        if (!evid.length) {
          if (evidenciaErro) evidenciaErro.hidden = false;
          if (painel) painel.hidden = false;
          return;
        }
        var dataConclusao = new Date().toLocaleString('pt-BR', {
          day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
        });
        if (window.TarefasStore) {
          TarefasStore.concluir(DADOS_TAREFA.id, {
            titulo: DADOS_TAREFA.titulo,
            retiro: DADOS_TAREFA.retiro,
            supervisor: DADOS_TAREFA.supervisor,
            prioridade: DADOS_TAREFA.prioridade,
            dataConclusao: dataConclusao,
            evidencias: evid
          });
        }
        mostrarConcluida(evid);
        sincronizarConclusao(dataConclusao, evid);
      });
    }
  })();
</script>

</body>
</html>
