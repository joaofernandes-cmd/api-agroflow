<%- include('../partials/capataz-head', { titulo: 'Alow · Detalhe da Tarefa' }) %>

<%
  var tarefa = {
    titulo: 'Vacinação lote B — Aroeira',
    autor: 'Criada por Supervisor Luiz',
    nivel: 'Alta',
    prazo: 'Amanhã, 08:00',
    categoria: 'Saúde animal',
    retiro: 'Fazenda Aroeira',
    data: '30/05/2026 às 08:00',
    status: 'Pendente',
    supervisor: 'Luiz Ferreira',
    descricao: 'Aplicar vacina contra febre aftosa no lote B. Usar EPI completo.'
  };
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/tarefas" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Detalhe da Tarefa</span>
    </div>
  </header>

  <div class="conteudo">
    <div class="detalhe-card">
      <span class="detalhe-card__barra"></span>
      <div class="detalhe-card__conteudo">
        <div class="detalhe-card__titulo" id="tarefaTitulo"><%= tarefa.titulo %></div>
        <div class="detalhe-card__autor" id="tarefaAutor"><%= tarefa.autor %></div>
        <div class="detalhe-card__meta">
          <span class="etiqueta etiqueta--alta" id="tarefaNivel"><%= tarefa.nivel %></span>
          <span id="tarefaPrazo"><%= tarefa.prazo %></span>
        </div>
        <div class="detalhe-card__cat" id="tarefaCategoria"><%= tarefa.categoria %></div>
      </div>
    </div>

    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Retiro</span>
      <span class="detalhe-linha__valor" id="tarefaRetiro"><%= tarefa.retiro %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Data</span>
      <span class="detalhe-linha__valor" id="tarefaData"><%= tarefa.data %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Status</span>
      <span class="detalhe-linha__valor" id="statusTarefa"><%= tarefa.status %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Supervisor</span>
      <span class="detalhe-linha__valor" id="tarefaSupervisor"><%= tarefa.supervisor %></span>
    </div>

    <label class="detalhe-descricao-rotulo">Descrição</label>
    <div class="detalhe-descricao" id="tarefaDescricao"><%= tarefa.descricao %></div>

    <button type="button" class="btn-primario" id="btnConcluir" style="margin-bottom: 12px;">
      Marcar como concluída
    </button>
    <button type="button" class="btn-secundario">Anexar evidência</button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tarefas' }) %>
</main>

<script>
  function formatarData(valor) {
    if (!valor) return 'Sem data';
    const data = new Date(valor);
    if (Number.isNaN(data.getTime())) return 'Sem data';

    return data.toLocaleString('pt-BR', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function prioridadeParaRotulo(prioridade) {
    if (prioridade === 'alta') return 'Alta';
    if (prioridade === 'media') return 'Média';
    return 'Baixa';
  }

  async function carregarTarefa() {
    const params = new URLSearchParams(window.location.search);
    const tarefaId = params.get('id');

    try {
      const response = tarefaId
        ? await fetch(`/tarefas/${tarefaId}`)
        : await fetch('/tarefas');

      const data = await response.json();
      const tarefa = Array.isArray(data) ? data[0] : data;

      if (!response.ok || !tarefa) {
        return;
      }

      document.getElementById('tarefaTitulo').textContent = tarefa.descricao;
      document.getElementById('tarefaAutor').textContent = `Criada por ${tarefa.criada_por}`;
      document.getElementById('tarefaNivel').textContent = prioridadeParaRotulo(tarefa.prioridade);
      document.getElementById('tarefaPrazo').textContent = tarefa.status === 'aprovado' ? 'Concluída' : 'Pendente';
      document.getElementById('tarefaCategoria').textContent = tarefa.categoria;
      document.getElementById('tarefaRetiro').textContent = `Retiro ${tarefa.retiro_id}`;
      document.getElementById('tarefaData').textContent = formatarData(tarefa.data_criacao);
      document.getElementById('statusTarefa').textContent = tarefa.status === 'aprovado' ? 'Concluída' : 'Pendente';
      document.getElementById('tarefaSupervisor').textContent = `Usuário ${tarefa.criada_por}`;
      document.getElementById('tarefaDescricao').textContent = tarefa.descricao;

      const botao = document.getElementById('btnConcluir');
      if (tarefa.status === 'aprovado' && botao) {
        botao.textContent = 'Concluída';
        botao.disabled = true;
      }
    } catch {
      // Mantém o conteúdo estático se a API não responder.
    }
  }

  document.getElementById('btnConcluir').addEventListener('click', function () {
    const status = document.getElementById('statusTarefa');
    if (status) status.textContent = 'Concluída';
    this.textContent = 'Concluída';
    this.disabled = true;
  });

  carregarTarefa();
</script>

</body>
</html>
