<%- include('../partials/capataz-head', { titulo: 'Alow · Detalhe da Tarefa' }) %>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/tarefas" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Detalhe da Tarefa</span>
    </div>
  </header>

  <div class="conteudo">
    <div class="detalhe-card">
      <span class="detalhe-card__barra"></span>
      <div class="detalhe-card__conteudo">
        <div class="detalhe-card__titulo" id="tarefaTitulo"><%= tarefa.titulo %> — <%= tarefa.retiro %></div>
        <div class="detalhe-card__autor" id="tarefaAutor"><%= tarefa.autor %></div>
        <div class="detalhe-card__meta">
          <span class="etiqueta etiqueta--<%= tarefa.classe %>" id="tarefaNivel"><%= tarefa.nivel %></span>
          <span id="tarefaPrazo"><%= tarefa.prazo %></span>
        </div>
        <div class="detalhe-card__cat" id="tarefaCategoria"><%= tarefa.categoria %></div>
      </div>
    </div>

    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Retiro</span>
      <span class="detalhe-linha__valor" id="tarefaRetiro"><%= tarefa.retiro %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Data</span>
      <span class="detalhe-linha__valor" id="tarefaData"><%= tarefa.data %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Status</span>
      <span class="detalhe-linha__valor" id="statusTarefa"><%= tarefa.statusRotulo %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Supervisor</span>
      <span class="detalhe-linha__valor" id="tarefaSupervisor"><%= tarefa.supervisor %></span>
    </div>

    <label class="detalhe-descricao-rotulo">Descrição</label>
    <div class="detalhe-descricao" id="tarefaDescricao"><%= tarefa.descricao %></div>

    <button type="button" class="btn-secundario" id="btnEvidencia" style="margin-bottom: 12px;">Anexar evidência</button>

    <div id="painelEvidencia" hidden style="margin-bottom: 12px;">
      <%- include('evidencia', { ns: 'ev' }) %>
    </div>

    <p id="evidenciaErro" class="evidencia-erro" hidden>Anexe uma evidência (foto, áudio ou texto) para marcar como concluída.</p>
    <button type="button" class="btn-primario" id="btnConcluir" <%= tarefa.status === 'concluida' ? 'disabled' : '' %>>
      <%= tarefa.status === 'concluida' ? 'Concluída' : 'Marcar como concluída' %>
    </button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tarefas' }) %>
</main>

<script>
  (function () {
    var btnEvidencia = document.getElementById('btnEvidencia');
    var painel = document.getElementById('painelEvidencia');
    var evidenciaErro = document.getElementById('evidenciaErro');
    var btnConcluir = document.getElementById('btnConcluir');
    var status = document.getElementById('statusTarefa');
    var listaEvidencia = document.getElementById('evLista'); // <ul> do partial (ns='ev')

    // "Anexar evidência" mostra/esconde o painel com os 3 tipos.
    if (btnEvidencia && painel) {
      btnEvidencia.addEventListener('click', function () {
        painel.hidden = !painel.hidden;
      });
    }

    function temEvidencia() {
      return !!listaEvidencia && listaEvidencia.querySelectorAll('.evidencia-item').length > 0;
    }

    // Some com o erro assim que o capataz anexa qualquer evidência.
    if (listaEvidencia) {
      new MutationObserver(function () {
        if (temEvidencia() && evidenciaErro) evidenciaErro.hidden = true;
      }).observe(listaEvidencia, { childList: true });
    }

    // Só conclui se houver pelo menos uma evidência (foto, áudio ou texto).
    if (btnConcluir) {
      btnConcluir.addEventListener('click', function () {
        if (!temEvidencia()) {
          if (evidenciaErro) evidenciaErro.hidden = false;
          if (painel) painel.hidden = false;
          return;
        }
        if (evidenciaErro) evidenciaErro.hidden = true;
        if (status) status.textContent = 'Concluída';
        btnConcluir.textContent = 'Concluída';
        btnConcluir.disabled = true;
      });
    }
  })();
</script>

</body>
</html>
