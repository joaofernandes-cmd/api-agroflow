<%- include('../partials/capataz-head', { titulo: 'Alow · Detalhe da Tarefa' }) %>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/tarefas" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Detalhe da Tarefa</span>
    </div>
  </header>

  <div class="conteudo">
    <div class="detalhe-card">
      <span class="detalhe-card__barra"></span>
      <div class="detalhe-card__conteudo">
        <div class="detalhe-card__titulo" id="tarefaTitulo"><%= tarefa.titulo %> — <%= tarefa.retiro %></div>
        <div class="detalhe-card__autor" id="tarefaAutor"><%= tarefa.autor %></div>
        <div class="detalhe-card__meta">
          <span class="etiqueta etiqueta--<%= tarefa.classe %>" id="tarefaNivel"><%= tarefa.nivel %></span>
          <span id="tarefaPrazo"><%= tarefa.prazo %></span>
        </div>
        <div class="detalhe-card__cat" id="tarefaCategoria"><%= tarefa.categoria %></div>
      </div>
    </div>

    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Retiro</span>
      <span class="detalhe-linha__valor" id="tarefaRetiro"><%= tarefa.retiro %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Data</span>
      <span class="detalhe-linha__valor" id="tarefaData"><%= tarefa.data %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Status</span>
      <span class="detalhe-linha__valor" id="statusTarefa"><%= tarefa.statusRotulo %></span>
    </div>
    <div class="detalhe-linha">
      <span class="detalhe-linha__rotulo">Supervisor</span>
      <span class="detalhe-linha__valor" id="tarefaSupervisor"><%= tarefa.supervisor %></span>
    </div>

    <label class="detalhe-descricao-rotulo">Descrição</label>
    <div class="detalhe-descricao" id="tarefaDescricao"><%= tarefa.descricao %></div>

    <!-- Evidências já registradas (aparece quando a tarefa está concluída) -->
    <div id="evidenciasSalvas" hidden style="margin-bottom: 12px;"></div>

    <button type="button" class="btn-secundario" id="btnEvidencia" style="margin-bottom: 12px;">Anexar evidência</button>

    <div id="painelEvidencia" hidden style="margin-bottom: 12px;">
      <%- include('evidencia', { ns: 'ev' }) %>
    </div>

    <p id="evidenciaErro" class="evidencia-erro" hidden>Anexe uma evidência (foto, áudio ou texto) para marcar como concluída.</p>
    <p id="tarefaSyncFeedback" class="evidencia-info" hidden></p>
    <button type="button" class="btn-primario" id="btnConcluir" <%= tarefa.status === 'concluida' ? 'disabled' : '' %>>
      <%= tarefa.status === 'concluida' ? 'Concluída' : 'Marcar como concluída' %>
    </button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tarefas' }) %>
  <%- include('../partials/aviso-sucesso') %>
</main>

<script src="/js/aviso-sucesso.js"></script>
<div id="dadosTarefa" hidden
     data-titulo="<%= tarefa.titulo %>"
     data-retiro="<%= tarefa.retiro %>"
     data-supervisor="<%= tarefa.supervisor %>"
     data-prioridade="<%= tarefa.classe %>"
     data-descricao="<%= tarefa.descricao %>"></div>
<script src="/js/tarefas-store.js"></script>
<script>
  var _el = document.getElementById('dadosTarefa');
  var DADOS_TAREFA = {
    id: new URLSearchParams(location.search).get('id') || '1',
    titulo: _el.dataset.titulo,
    retiro: _el.dataset.retiro,
    supervisor: _el.dataset.supervisor,
    prioridade: _el.dataset.prioridade,
    descricao: _el.dataset.descricao
  };

  var CAPATAZ_DEMO = {
    id: '11111111-1111-1111-1111-111111111111',
    retiro_id: '00000000-0000-4000-8000-000000000001' 
    
  };

  (function () {
    var btnEvidencia = document.getElementById('btnEvidencia');
    var painel = document.getElementById('painelEvidencia');
    var evidenciaErro = document.getElementById('evidenciaErro');
    var btnConcluir = document.getElementById('btnConcluir');
    var status = document.getElementById('statusTarefa');
    var listaEvidencia = document.getElementById('evLista');
    var evidenciasSalvas = document.getElementById('evidenciasSalvas');
    var syncFeedback = document.getElementById('tarefaSyncFeedback');

    function evidenciasCapturadas() {
      var api = window.__evidencias && window.__evidencias['ev'];
      return api ? api.obter() : [];
    }

    // Mostra a tarefa como concluída + evidências (read-only).
    function mostrarConcluida(evidencias) {
      if (status) status.textContent = 'Concluída';
      if (btnConcluir) { btnConcluir.textContent = 'Concluída'; btnConcluir.disabled = true; }
      if (btnEvidencia) btnEvidencia.style.display = 'none';
      if (painel) painel.hidden = true;
      if (evidenciaErro) evidenciaErro.hidden = true;
      if (evidenciasSalvas && evidencias && evidencias.length && window.TarefasStore) {
        TarefasStore.renderEvidencias(evidencias, evidenciasSalvas);
        evidenciasSalvas.hidden = false;
      }
    }

    // Já estava concluída (salva antes)? Mostra o estado concluído.
    var salva = window.TarefasStore ? TarefasStore.obter(DADOS_TAREFA.id) : null;
    if (salva) {
      mostrarConcluida(salva.evidencias);
    }

    // "Anexar evidência" mostra/esconde o painel com os 3 tipos.
    if (btnEvidencia && painel) {
      btnEvidencia.addEventListener('click', function () {
        painel.hidden = !painel.hidden;
      });
    }

    // Some com o erro assim que o capataz anexa qualquer evidência.
    if (listaEvidencia) {
      new MutationObserver(function () {
        if (evidenciasCapturadas().length && evidenciaErro) evidenciaErro.hidden = true;
      }).observe(listaEvidencia, { childList: true });
    }

    function gerarUuidLocal() {
      if (window.crypto && typeof window.crypto.randomUUID === 'function') {
        return window.crypto.randomUUID();
      }
      return '00000000-0000-4000-8000-' + String(Date.now()).slice(-12).padStart(12, '0');
    }

    function prioridadeApi(valor) {
      return ['alta', 'media', 'baixa'].indexOf(valor) >= 0 ? valor : 'baixa';
    }

    function mostrarSync(msg) {
      if (!syncFeedback) return;
      syncFeedback.textContent = msg;
      syncFeedback.hidden = false;
    }

    // Confirmação em tela cheia (o capataz precisa ver claramente que deu certo).
    function mostrarSucessoTela(titulo, msg) {
      if (!window.AvisoSucesso) { mostrarSync(msg); return; }
      window.AvisoSucesso.mostrar(msg, {
        titulo: titulo,
        botaoTexto: 'Voltar para tarefas',
        aoFechar: function () { window.location.href = '/capataz/tarefas'; },
      });
    }

    // Versão da evidência para o localStorage: sem o Blob (não serializa em JSON).
    function toEvidLocal(e) {
      return { tipo: e.tipo, dataUrl: e.dataUrl, conteudo: e.conteudo, latitude: e.latitude, longitude: e.longitude };
    }

    // POST autenticado por cookie (a página do capataz já carrega o agroflow_token).
    function postEvidencia(url, body) {
      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      }).then(function (resp) {
        if (window.AgroFlowSession?.tratarResposta(resp)) {
          throw new Error('Sessão expirada');
        }
        if (resp.ok) return resp.json().catch(function () { return {}; });
        return resp.json().catch(function () { return {}; }).then(function (d) {
          console.warn('Falha ao enviar evidência da tarefa', { status: resp.status, url: url });
          throw new Error((d && d.error) || 'Não foi possível enviar a evidência. Tente novamente.');
        });
      });
    }

    // Sobe foto/áudio pro Supabase e posta cada evidência ligada à tarefa.
    // O supervisor depois lê tudo por GET /evidencias/tarefa/:id.
    async function enviarEvidenciasBackend(tarefaId, evidencias) {
      var total = evidencias.length, enviadas = 0, aviso = '';
      var temSupabase = !!window.__SUPABASE__;

      for (var i = 0; i < evidencias.length; i++) {
        var ev = evidencias[i];
        try {
          if (ev.tipo === 'texto') {
            await postEvidencia('/evidencias/mensagens', {
              conteudo: ev.conteudo, tarefa_id: tarefaId, usuarioId: CAPATAZ_DEMO.id
            });
            enviadas++;
          } else if (ev.tipo === 'foto') {
            if (!temSupabase) { aviso = 'Não foi possível enviar foto ou áudio agora.'; continue; }
            if (ev.latitude == null || ev.longitude == null) { aviso = 'A foto precisa ter localização para ser enviada.'; continue; }
            var up = await window.AgroFlowCapataz.uploadBinary({ blob: ev.blob, mimeType: ev.mimeType || 'image/jpeg' }, CAPATAZ_DEMO.id, 'evidencias/foto');
            await postEvidencia('/evidencias/fotos', {
              urlArquivo: up.urlArquivo, latitude: ev.latitude, longitude: ev.longitude, tarefa_id: tarefaId, usuarioId: CAPATAZ_DEMO.id
            });
            enviadas++;
          } else if (ev.tipo === 'audio') {
            if (!temSupabase) { aviso = 'Não foi possível enviar foto ou áudio agora.'; continue; }
            var upA = await window.AgroFlowCapataz.uploadBinary({ blob: ev.blob, mimeType: ev.mimeType || 'audio/webm' }, CAPATAZ_DEMO.id, 'evidencias/audio');
            await postEvidencia('/evidencias/audios', {
              urlArquivo: upA.urlArquivo, duracao: ev.duracao || 3, tarefa_id: tarefaId, usuarioId: CAPATAZ_DEMO.id
            });
            enviadas++;
          }
        } catch (e) {
          console.warn('Falha ao sincronizar evidência da tarefa', e);
          aviso = (e && e.message) ? e.message : 'Não foi possível enviar a evidência.';
        }
      }
      return { total: total, enviadas: enviadas, aviso: aviso };
    }

    // Texto da descrição que o supervisor lê (a contagem reflete o que foi
    // REALMENTE enviado ao backend, não só o que o capataz capturou).
    function descricaoConclusao(qtdEvidencias) {
      return 'Conclusao da tarefa "' + DADOS_TAREFA.titulo + '" no retiro ' +
        DADOS_TAREFA.retiro + '. Evidencias anexadas: ' + qtdEvidencias + '.';
    }

    // Reverte a conclusão: a tarefa volta a ser 'pendente' (sem ficar como
    // concluída sem evidência). Usa o endpoint de status (permitido ao capataz).
    function reverterParaPendente(tarefaId) {
      return fetch('/tarefas/' + encodeURIComponent(tarefaId) + '/status', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'pendente' })
      }).then(function (resp) {
        if (window.AgroFlowSession?.tratarResposta(resp)) throw new Error('Sessão expirada');
        return resp.ok;
      }).catch(function () { return false; });
    }

    // Re-sincroniza a mesma tarefa (upsert por id) só para corrigir a descrição
    // quando parte das evidências não pôde ser enviada.
    function corrigirContagem(payload, qtdEnviada) {
      var corpo = Object.assign({}, payload, { descricao: descricaoConclusao(qtdEnviada) });
      return window.AgroFlowCapataz.fetchOrQueueOperation({
        kind: 'tarefa', url: '/tarefas/sincronizar', method: 'POST', body: corpo, queueBody: corpo
      }).catch(function () {});
    }

    // Conclui a tarefa GARANTINDO que a evidência obrigatória chegue ao supervisor.
    // A evidência precisa da tarefa já existente (FK), então a ordem é:
    //   1) cria a tarefa como 'concluido';
    //   2) envia a evidência ligada a ela;
    //   3) se NENHUMA evidência foi salva no backend, reverte a tarefa para
    //      'pendente' e avisa o capataz — assim o supervisor nunca vê tarefa
    //      concluída sem evidência.
    // Retorna true se concluiu de fato; false se não concluiu (offline/falha).
    async function sincronizarConclusao(tarefaId, dataConclusao, evidencias, evidLocais) {
      if (!window.AgroFlowCapataz) return false;

      // Sem internet não dá para enviar foto/áudio; como a evidência é obrigatória
      // e tem que ir junto, não concluímos agora (e não enfileiramos nada).
      if (!navigator.onLine) {
        mostrarSync('Você está sem internet. A evidência precisa ser enviada junto com a tarefa. Conecte-se à internet e conclua de novo.');
        return false;
      }

      var payload = {
        id: tarefaId,
        retiro_id: CAPATAZ_DEMO.retiro_id,
        criada_por: CAPATAZ_DEMO.id,
        atribuida_a: CAPATAZ_DEMO.id,
        descricao: descricaoConclusao(evidencias.length),
        categoria: DADOS_TAREFA.categoria || 'Operacional',
        prioridade: prioridadeApi(DADOS_TAREFA.prioridade),
        data_criacao: new Date().toISOString(),
        status: 'concluido',
        aprovado_por: null,
        sincronizado: false
      };
      // Se a rede cair na hora do envio, a tarefa vai pra fila como PENDENTE
      // (nunca como concluída sem evidência).
      var payloadFila = Object.assign({}, payload, { status: 'pendente', descricao: DADOS_TAREFA.descricao });

      var resultado;
      try {
        resultado = await window.AgroFlowCapataz.fetchOrQueueOperation({
          kind: 'tarefa', url: '/tarefas/sincronizar', method: 'POST', body: payload, queueBody: payloadFila
        });
      } catch (e) {
        mostrarSync('Não foi possível concluir a tarefa agora. Verifique a internet e tente de novo.');
        return false;
      }

      if (resultado.queued) {
        mostrarSync('Você está sem internet. A evidência precisa ser enviada junto com a tarefa. Conecte-se à internet e conclua de novo.');
        return false;
      }

      // Online: a tarefa existe no servidor → envia as evidências ligadas a ela.
      var r = await enviarEvidenciasBackend(tarefaId, evidencias);

      if (r.enviadas === 0) {
        // Nenhuma evidência salva → desfaz a conclusão para não deixar tarefa
        // concluída sem evidência. Volta a pendente para o capataz tentar de novo.
        await reverterParaPendente(tarefaId);
        mostrarSync((r.aviso || 'Não foi possível enviar a evidência.') + ' A tarefa continua pendente — tente concluir de novo.');
        return false;
      }

      // Pelo menos uma evidência foi salva → conclusão válida.
      if (r.enviadas < r.total) {
        await corrigirContagem(payload, r.enviadas);
      }

      // Confirma localmente e mostra o sucesso em tela cheia.
      if (window.TarefasStore) {
        TarefasStore.concluir(DADOS_TAREFA.id, {
          titulo: DADOS_TAREFA.titulo,
          retiro: DADOS_TAREFA.retiro,
          supervisor: DADOS_TAREFA.supervisor,
          prioridade: DADOS_TAREFA.prioridade,
          descricao: DADOS_TAREFA.descricao,
          dataConclusao: dataConclusao,
          evidencias: evidLocais
        });
      }
      mostrarConcluida(evidLocais);
      var msg = 'Sua Tarefa foi concluída e enviada para o supervisor.';
      if (r.enviadas < r.total) msg += ' (' + r.enviadas + ' de ' + r.total + ' evidências enviadas.)';
      mostrarSucessoTela('Tarefa concluída!', msg);
      return true;
    }

    // Mesmo id em todas as tentativas desta página: se reverter e o capataz
    // tentar de novo, o upsert atualiza a MESMA tarefa (não cria duplicada).
    var tarefaIdConclusao = null;

    // Só conclui se houver pelo menos uma evidência (foto, áudio ou texto) E
    // ela for de fato salva no backend.
    if (btnConcluir && !salva) {
      btnConcluir.addEventListener('click', function () {
        var evid = evidenciasCapturadas();
        if (!evid.length) {
          if (evidenciaErro) evidenciaErro.hidden = false;
          if (painel) painel.hidden = false;
          return;
        }
        if (btnConcluir.dataset.processando === '1') return;
        btnConcluir.dataset.processando = '1';
        btnConcluir.disabled = true;
        var textoOriginal = btnConcluir.textContent;
        btnConcluir.textContent = 'Enviando...';

        var dataConclusao = new Date().toLocaleString('pt-BR', {
          day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
        });
        if (!tarefaIdConclusao) tarefaIdConclusao = gerarUuidLocal();
        var evidLocais = evid.map(toEvidLocal);

        // A conclusão local + tela de sucesso só acontecem DENTRO de
        // sincronizarConclusao, e apenas quando a evidência foi mesmo salva.
        Promise.resolve(sincronizarConclusao(tarefaIdConclusao, dataConclusao, evid, evidLocais))
          .then(function (concluiu) {
            if (!concluiu) {
              // Não concluiu (sem evidência no backend / offline): reabilita o
              // botão para o capataz tentar de novo.
              btnConcluir.dataset.processando = '';
              btnConcluir.disabled = false;
              btnConcluir.textContent = textoOriginal;
              if (painel) painel.hidden = false;
            }
          });
      });
    }
  })();
</script>

</body>
</html>
