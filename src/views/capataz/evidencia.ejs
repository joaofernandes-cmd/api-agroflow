<%
  /* Caixa de evidência com captura real.
     - Foto: abre a câmera (input file image + capture).
     - Áudio: abre o gravador nativo do celular (input file audio + capture).
     - Texto: campo de observação que aparece ao clicar.
     "ns" é um prefixo para tornar os IDs únicos caso o partial seja
     incluído mais de uma vez na mesma página. */
  var ns = typeof ns !== 'undefined' ? ns : 'ev';
%>
<div class="campo">
  <label class="campo__rotulo">Evidência (obrigatório)</label>
  <div class="evidencia">
    <!-- Foto: abre a câmera no celular -->
    <label class="evidencia__btn evidencia__btn--foto" for="<%= ns %>Foto">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
      Foto
    </label>
    <input type="file" id="<%= ns %>Foto" accept="image/*" capture="environment" hidden />

    <!-- Áudio: abre o gravador nativo do celular -->
    <label class="evidencia__btn evidencia__btn--audio" for="<%= ns %>Audio">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0 0 14 0"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
      Áudio
    </label>
    <input type="file" id="<%= ns %>Audio" accept="audio/*" capture hidden />

    <!-- Texto: revela um campo de observação -->
    <button type="button" class="evidencia__btn evidencia__btn--texto" id="<%= ns %>BtnTexto">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
      Texto
    </button>
  </div>

  <!-- Lista de evidências anexadas (preenchida via JS) -->
  <ul class="evidencia-lista" id="<%= ns %>Lista"></ul>

  <!-- Bloco de escrita (oculto até clicar em "Texto") -->
  <div class="evidencia-bloco-texto" id="<%= ns %>BlocoTexto" style="display: none;">
    <label class="campo__rotulo" style="margin-top: 12px;">Observação por texto</label>
    <textarea class="input" id="<%= ns %>Texto" rows="4"
              placeholder="Descreva o que você observou..."></textarea>
  </div>
</div>

<script>
  (function () {
    var ns = "<%= ns %>";
    var inputFoto = document.getElementById(ns + 'Foto');
    var inputAudio = document.getElementById(ns + 'Audio');
    var btnTexto = document.getElementById(ns + 'BtnTexto');
    var campoTexto = document.getElementById(ns + 'Texto');
    var lista = document.getElementById(ns + 'Lista');

    // Ícone simples (check) para os itens anexados
    var iconeCheck =
      '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22a855" ' +
      'stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">' +
      '<path d="M20 6 9 17l-5-5"/></svg>';

    // Adiciona (ou substitui) um item na lista de evidências
    function registrar(tipo, nome) {
      var existente = lista.querySelector('[data-tipo="' + tipo + '"]');
      if (existente) existente.remove();

      var li = document.createElement('li');
      li.className = 'evidencia-item';
      li.setAttribute('data-tipo', tipo);
      li.innerHTML = iconeCheck + '<span>' + tipo + ': ' + nome + '</span>';
      lista.appendChild(li);
    }

    inputFoto.addEventListener('change', function () {
      if (inputFoto.files.length) registrar('Foto', inputFoto.files[0].name || 'imagem capturada');
    });

    inputAudio.addEventListener('change', function () {
      if (inputAudio.files.length) registrar('Áudio', inputAudio.files[0].name || 'áudio gravado');
    });

    var blocoTexto = document.getElementById(ns + 'BlocoTexto');

    btnTexto.addEventListener('click', function () {
      var visivel = blocoTexto.style.display !== 'none';
      blocoTexto.style.display = visivel ? 'none' : 'block';
      if (!visivel) campoTexto.focus();
    });

    campoTexto.addEventListener('input', function () {
      if (campoTexto.value.trim()) registrar('Texto', 'observação adicionada');
      else {
        var item = lista.querySelector('[data-tipo="Texto"]');
        if (item) item.remove();
      }
    });
  })();
</script>
