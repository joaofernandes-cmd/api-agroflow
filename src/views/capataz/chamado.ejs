<%- include('../partials/capataz-head', { titulo: 'Alow · Abrir Chamado' }) %>

<%
  var CATEGORIAS = [
    { value: 'cerca', label: 'Cerca' },
    { value: 'hidraulica', label: 'Água / Hidráulica' },
    { value: 'eletrica', label: 'Elétrica' },
    { value: 'edificacao', label: 'Edificação' },
    { value: 'abastecimento_agua', label: 'Abastecimento de água' },
    { value: 'outro', label: 'Outro' }
  ];
  var PRIORIDADES = [
    { value: 'alta', label: 'Alta' },
    { value: 'media', label: 'Média' },
    { value: 'baixa', label: 'Baixa' }
  ];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/home" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Ticket de Infraestrutura</span>
    </div>
  </header>

  <p id="ticket-feedback" style="margin: 12px 16px 0; font-size: 14px; line-height: 1.4;"></p>

  <div class="conteudo">
    <div class="campo">
      <label class="campo__rotulo" for="categoriaTicket">Categoria do problema</label>
      <select class="select" id="categoriaTicket" required>
        <option value="" disabled selected>Selecione a categoria</option>
        <% CATEGORIAS.forEach(function (c) { %><option value="<%= c.value %>"><%= c.label %></option><% }) %>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="prioridadeTicket">Prioridade</label>
      <select class="select" id="prioridadeTicket" required>
        <option value="" disabled selected>Selecione a prioridade</option>
        <% PRIORIDADES.forEach(function (p) { %><option value="<%= p.value %>"><%= p.label %></option><% }) %>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="localizacaoTicket">Localização</label>
      <input class="input" type="text" id="localizacaoTicket" placeholder="Ex: Curral principal" />
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="descricaoTicket">Descrição</label>
      <textarea class="input" rows="3" id="descricaoTicket" placeholder="Descreva o problema encontrado..."></textarea>
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="evidenciaTicket">Evidência descritiva</label>
      <textarea class="input" rows="3" id="evidenciaTicket" placeholder="Explique a evidência com pelo menos 10 caracteres"></textarea>
    </div>

    <div class="campo">
      <label class="campo__rotulo">Observação</label>
      <div class="aviso-local">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        O ticket será registrado como aberto pelo capataz de demonstração
      </div>
    </div>

    <button type="button" class="btn-primario" id="btnEnviarTicket">Enviar chamado</button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tickets' }) %>
</main>

<script>
  const CAPATAZ_DEMO = {
    id: '11111111-1111-1111-1111-111111111111',
    nome: 'Capataz Daniel',
    cargo: 'capataz',
    retiro_id: '00000000-0000-4000-8000-000000000001',
  };

  const feedback = document.getElementById('ticket-feedback');
  const botao = document.getElementById('btnEnviarTicket');

  function getSession() {
    try {
      const token = localStorage.getItem('agroflow.token');
      const usuarioRaw = localStorage.getItem('agroflow.usuario');

      if (!usuarioRaw) {
        return null;
      }

      return {
        token,
        usuario: JSON.parse(usuarioRaw),
      };
    } catch {
      return null;
    }
  }

  function mostrarFeedback(mensagem, tipo) {
    if (!feedback) return;
    feedback.textContent = mensagem;
    feedback.style.color = tipo === 'error' ? '#b42318' : '#146c43';
  }

  function montarPayload() {
    const session = getSession();
    const categoria = document.getElementById('categoriaTicket').value;
    const prioridade = document.getElementById('prioridadeTicket').value;
    const localizacao = document.getElementById('localizacaoTicket').value.trim();
    const descricao = document.getElementById('descricaoTicket').value.trim();
    const evidencia = document.getElementById('evidenciaTicket').value.trim();

    if (!categoria || !prioridade || !localizacao || !descricao) {
      throw new Error('Preencha categoria, prioridade, localização e descrição.');
    }

    return {
      retiro_id: session?.usuario?.retiro_id ?? CAPATAZ_DEMO.retiro_id,
      categoria,
      localizacao,
      descricao,
      prioridade,
      usuarioAbridorTicket: session?.usuario ?? CAPATAZ_DEMO,
      temEvidenciaDescritiva: evidencia.length >= 10 || descricao.length >= 10,
    };
  }

  async function enviarTicket() {
    try {
      botao.disabled = true;
      botao.textContent = 'Enviando...';

      const payload = montarPayload();
      const response = await fetch('/tickets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(data.error || 'Não foi possível criar o chamado');
      }

      mostrarFeedback('Chamado criado com sucesso.', 'success');
      document.querySelectorAll('.select, .input').forEach(el => {
        if (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
          el.value = '';
        } else {
          el.selectedIndex = 0;
        }
      });
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao criar chamado', 'error');
    } finally {
      botao.disabled = false;
      botao.textContent = 'Enviar chamado';
    }
  }

  botao.addEventListener('click', enviarTicket);
</script>

</body>
</html>
