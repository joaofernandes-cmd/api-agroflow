<%- include('../partials/capataz-head', { titulo: 'Alow · Abrir Chamado' }) %>

<%
  var CATEGORIAS = [
    { value: 'cerca', label: 'Cerca' },
    { value: 'hidraulica', label: 'Água / Hidráulica' },
    { value: 'eletrica', label: 'Elétrica' },
    { value: 'edificacao', label: 'Edificação' },
    { value: 'abastecimento_agua', label: 'Abastecimento de água' },
    { value: 'outro', label: 'Outro' }

  ];
  var PRIORIDADES = [
    { value: 'alta', label: 'Alta' },
    { value: 'media', label: 'Média' },
    { value: 'baixa', label: 'Baixa' }
  ];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/home" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Ticket de Infraestrutura</span>
    </div>
  </header>

  <p id="ticket-feedback" style="margin: 12px 16px 0; font-size: 14px; line-height: 1.4;"></p>

  <div class="conteudo">
    <div class="campo">
      <label class="campo__rotulo" for="categoriaTicket">Categoria do problema</label>
      <select class="select" id="categoriaTicket" required>
        <option value="" disabled selected>Selecione a categoria</option>
        <% CATEGORIAS.forEach(function (c) { %><option value="<%= c.value %>"><%= c.label %></option><% }) %>
      </select>
    </div>

    <div class="campo" id="campoCategoriaOutro" style="display: none;">
      <label class="campo__rotulo" for="categoriaOutro">Nome da categoria <span class="obrigatorio">*</span></label>
      <input class="input" type="text" id="categoriaOutro" placeholder="Diga qual é o problema" required />
    </div>

    <div class="campo">
      <label class="campo__rotulo">Prioridade</label>
      <div class="prio-seletor" role="radiogroup" aria-label="Prioridade">
        <button type="button" class="prio-opcao prio-opcao--alta" data-valor="alta">Alta</button>
        <button type="button" class="prio-opcao prio-opcao--media" data-valor="media">Média</button>
        <button type="button" class="prio-opcao prio-opcao--baixa" data-valor="baixa">Baixa</button>
        <input type="hidden" id="prioridadeTicket" value="" />
      </div>
    </div>

    <div class="campo">
      <label class="campo__rotulo" for="localizacaoTicket">Localização (automática)</label>
      <input class="input" type="text" id="localizacaoTicket" placeholder="Detectando sua localização..." readonly />
      <p id="localizacaoStatus" style="margin: 6px 0 0; font-size: 13px; color: var(--texto-sec);"></p>
    </div>

    <%- include('evidencia', { ns: 'tk' }) %>

    <button type="button" class="btn-primario" id="btnEnviarTicket">Enviar chamado</button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tickets' }) %>
</main>

<script src="/js/prioridade-seletor.js"></script>
<script>
  const CAPATAZ_DEMO = {
    id: '11111111-1111-1111-1111-111111111111',
    nome: 'Capataz Daniel',
    cargo: 'capataz',
    retiro_id: '00000000-0000-4000-8000-000000000001',
  };

  const feedback = document.getElementById('ticket-feedback');
  const botao = document.getElementById('btnEnviarTicket');

  // Quando a categoria for "Outro", revela o campo para nomear a categoria.
  const categoriaSelect = document.getElementById('categoriaTicket');
  const campoCategoriaOutro = document.getElementById('campoCategoriaOutro');
  const categoriaOutroInput = document.getElementById('categoriaOutro');

  function atualizarCategoriaOutro() {
    const ehOutro = categoriaSelect.value === 'outro';
    campoCategoriaOutro.style.display = ehOutro ? 'block' : 'none';
    if (!ehOutro) categoriaOutroInput.value = '';
  }
  categoriaSelect.addEventListener('change', atualizarCategoriaOutro);

  function getSession() {
    try {
      const token = localStorage.getItem('agroflow.token');
      const usuarioRaw = localStorage.getItem('agroflow.usuario');

      if (!usuarioRaw) {
        return null;
      }

      return {
        token,
        usuario: JSON.parse(usuarioRaw),
      };
    } catch {
      return null;
    }
  }

  function mostrarFeedback(mensagem, tipo) {
    if (!feedback) return;
    feedback.textContent = mensagem;
    feedback.style.color = tipo === 'error' ? '#b42318' : '#146c43';
  }

  function montarPayload() {
    const session = getSession();
    let categoria = document.getElementById('categoriaTicket').value;
    const prioridade = document.getElementById('prioridadeTicket').value;
    const localizacao = document.getElementById('localizacaoTicket').value.trim();
    const evidenciasApi = window.__evidencias && window.__evidencias['tk'];
    const evidencias = evidenciasApi ? evidenciasApi.obter() : [];

    if (!categoria || !prioridade || !localizacao) {
      throw new Error('Preencha categoria, prioridade e localização.');
    }

    if (!evidencias.length) {
      throw new Error('Anexe uma evidência (foto, áudio ou texto).');
    }

    // "Outro": mantém categoria='outro' (enum do banco) e guarda o nome digitado à parte.
    let categoriaOutro = null;
    if (categoria === 'outro') {
      categoriaOutro = document.getElementById('categoriaOutro').value.trim();
      if (!categoriaOutro) {
        throw new Error('Diga o nome da categoria.');
      }
    }

    // A descrição vem da evidência de texto; sem texto, usa a categoria como base.
    const textoEvid = evidencias.find(function (e) { return e.tipo === 'texto'; });
    const catLabel = categoriaOutro || categoriaSelect.options[categoriaSelect.selectedIndex].text;
    const descricao = (textoEvid && textoEvid.conteudo) ? textoEvid.conteudo : ('Chamado de ' + catLabel);

    return {
      retiro_id: session?.usuario?.retiro_id ?? CAPATAZ_DEMO.retiro_id,
      categoria,
      categoria_outro: categoriaOutro,
      localizacao,
      descricao,
      prioridade,
      usuarioAbridorTicket: session?.usuario ?? CAPATAZ_DEMO,
      temEvidenciaDescritiva: true,
    };
  }

  async function enviarTicket() {
    try {
      botao.disabled = true;
      botao.textContent = 'Enviando...';

      const payload = montarPayload();
      const response = await fetch('/tickets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(data.error || 'Não foi possível criar o chamado');
      }

      mostrarFeedback('Chamado criado com sucesso.', 'success');
      document.querySelectorAll('.select, .input').forEach(el => {
        if (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
          el.value = '';
        } else {
          el.selectedIndex = 0;
        }
      });
      atualizarCategoriaOutro();
      if (window.PrioSeletor) window.PrioSeletor.resetarTodos();
      obterLocalizacao();
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao criar chamado', 'error');
    } finally {
      botao.disabled = false;
      botao.textContent = 'Enviar chamado';
    }
  }

  // Localização automática por GPS (preenche sem o capataz precisar digitar).
  function obterLocalizacao() {
    const campo = document.getElementById('localizacaoTicket');
    const status = document.getElementById('localizacaoStatus');
    if (!navigator.geolocation) {
      campo.readOnly = false;
      campo.placeholder = 'Digite a localização';
      if (status) status.textContent = 'GPS indisponível — digite a localização.';
      return;
    }
    if (status) status.textContent = 'Obtendo sua localização...';
    navigator.geolocation.getCurrentPosition(
      function (pos) {
        campo.value = pos.coords.latitude.toFixed(6) + ', ' + pos.coords.longitude.toFixed(6);
        if (status) status.textContent = '📍 Localização capturada automaticamente.';
      },
      function () {
        campo.readOnly = false;
        campo.placeholder = 'Não foi possível pegar o GPS — digite a localização';
        if (status) status.textContent = 'Sem permissão de localização — digite manualmente.';
      }
    );
  }
  obterLocalizacao();

  botao.addEventListener('click', enviarTicket);
</script>

</body>
</html>
