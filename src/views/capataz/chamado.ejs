<%- include('../partials/capataz-head', { titulo: 'Alow · Abrir Chamado' }) %>

<%
  var CATEGORIAS = ['Cerca','Água','Equipamento','Veículo','Energia','Estoque','Outro'];
  var PRIORIDADES = ['Crítica','Alta','Média','Baixa'];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <a href="/capataz/home" class="cabecalho__voltar" aria-label="Voltar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
      <span class="cabecalho__titulo">Ticket de Infraestrutura</span>
    </div>
  </header>

  <div class="conteudo">
    <div class="campo">
      <label class="campo__rotulo">Categoria do problema</label>
      <select class="select" required>
        <option value="" disabled selected>Cerca / Água / Equipamento...</option>
        <% CATEGORIAS.forEach(function (c) { %><option><%= c %></option><% }) %>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo">Prioridade</label>
      <select class="select" required>
        <option value="" disabled selected>Alta / Média / Baixa / Crítica</option>
        <% PRIORIDADES.forEach(function (p) { %><option><%= p %></option><% }) %>
      </select>
    </div>

    <div class="campo">
      <label class="campo__rotulo">Descrição (mínimo 10 caracteres) <span class="obrigatorio">*</span></label>
      <textarea class="input" rows="3" placeholder="Descreva o problema encontrado..."></textarea>
    </div>

    <div class="campo">
      <label class="campo__rotulo">Evidência (obrigatório)</label>
      <div class="evidencia">
        <button type="button" class="evidencia__btn evidencia__btn--foto">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
          Foto
        </button>
        <button type="button" class="evidencia__btn evidencia__btn--audio">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0 0 14 0"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
          Áudio
        </button>
        <button type="button" class="evidencia__btn evidencia__btn--texto">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
          Texto
        </button>
      </div>
    </div>

    <div class="aviso-local">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Localização será registrada automaticamente
    </div>

    <button type="button" class="btn-primario">Enviar chamado</button>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'tickets' }) %>
</main>

</body>
</html>
