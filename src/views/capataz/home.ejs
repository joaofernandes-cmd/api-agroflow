<%- include('../partials/capataz-head', { titulo: 'Alow · Início' }) %>

<%
  var tarefas = [
    { cor: 'var(--alerta)', titulo: 'Transferência de gado lote B', sub: 'Supervisor Luiz • Alta • Amanhã 08h', nivel: 'Alta',  classe: 'alta'  },
    { cor: 'var(--info)',   titulo: 'Conferência do rebanho', sub: 'Supervisor Luiz • Média • Hoje 14h',  nivel: 'Média', classe: 'media' }
  ];
  var operacoes = [
    { cor: 'var(--primaria)', titulo: 'Registrar movimentação', sub: 'Nascimento, morte, transferência...',  href: '/capataz/movimentacao' },
    { cor: 'var(--atencao)',  titulo: 'Abrir chamado',          sub: 'Reportar problema de infraestrutura', href: '/capataz/chamado' }
  ];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <span class="cabecalho__titulo">Início</span>
    </div>
  </header>

  <div class="saudacao">
    <h2 class="saudacao__titulo">Bom dia, Daniel Carvalho!</h2>
    <p class="saudacao__data" id="data-hoje"></p>
    <span class="tag-sincronizado">✓ Sincronizado</span>
  </div>

  <div class="conteudo">
    <h3 class="secao-titulo">Minhas tarefas</h3>
    <% tarefas.forEach(function (t) { %>
      <a href="/capataz/detalhe-tarefa" class="card">
        <span class="card__barra" style="background: <%= t.cor %>;"></span>
        <div class="card__corpo">
          <div class="card__titulo"><%= t.titulo %></div>
          <div class="card__sub"><%= t.sub %></div>
        </div>
        <span class="etiqueta etiqueta--<%= t.classe %>"><%= t.nivel %></span>
        <svg class="card__seta" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 6 6 6-6 6"/>
        </svg>
      </a>
    <% }) %>

    <h3 class="secao-titulo secao-titulo--espaco">Operações de campo</h3>
    <% operacoes.forEach(function (o) { %>
      <a href="<%= o.href %>" class="card">
        <span class="card__barra" style="background: <%= o.cor %>;"></span>
        <div class="card__corpo">
          <div class="card__titulo"><%= o.titulo %></div>
          <div class="card__sub"><%= o.sub %></div>
        </div>
        <svg class="card__seta" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 6 6 6-6 6"/>
        </svg>
      </a>
    <% }) %>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'inicio' }) %>
</main>

<script>
  function formatarData(valor) {
    if (!valor) return 'Sem data';
    const data = new Date(valor);
    if (Number.isNaN(data.getTime())) return 'Sem data';

    return data.toLocaleDateString('pt-BR', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
    });
  }

  document.getElementById('data-hoje').textContent =
    new Date().toLocaleDateString('pt-BR', {
      weekday: 'long',
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    }).replace(/^\w/, function (letra) {
      return letra.toUpperCase();
    });

  async function carregarTarefas() {
    const cards = Array.from(document.querySelectorAll('.conteudo > a.card')).slice(0, 2);

    try {
      const response = await fetch('/tarefas');
      const tarefas = await response.json();

      if (!response.ok || !Array.isArray(tarefas)) {
        return;
      }

      cards.forEach((card, index) => {
        const tarefa = tarefas[index];
        if (!tarefa) return;

        const titulo = card.querySelector('.card__titulo');
        const sub = card.querySelector('.card__sub');
        const etiqueta = card.querySelector('.etiqueta');

        if (titulo) {
          titulo.textContent = tarefa.descricao;
        }

        if (sub) {
          sub.textContent = `Retiro ${tarefa.retiro_id} • ${tarefa.categoria} • ${formatarData(tarefa.data_criacao)}`;
        }

        if (etiqueta) {
          etiqueta.textContent = tarefa.prioridade === 'alta'
            ? 'Alta'
            : tarefa.prioridade === 'media'
              ? 'Média'
              : 'Baixa';

          etiqueta.className = `etiqueta etiqueta--${tarefa.prioridade === 'alta' ? 'alta' : tarefa.prioridade === 'media' ? 'media' : 'baixa'}`;
        }

        card.href = `/capataz/detalhe-tarefa?id=${tarefa.id}`;
      });
    } catch {
      // Mantém o conteúdo estático caso a API não responda.
    }
  }

  carregarTarefas();
</script>

</body>
</html>
