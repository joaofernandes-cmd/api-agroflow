<%- include('../partials/capataz-head', { titulo: 'Alow · Início' }) %>

<%
  var operacoes = [
    { cor: 'var(--info)', titulo: 'Registrar movimentação', sub: 'Nascimento, morte, transferência...',  href: '/capataz/movimentacao' },
    { cor: '#6b5b95',     titulo: 'Abrir chamado',          sub: 'Reportar problema de infraestrutura', href: '/capataz/chamado' }
  ];
%>

<main class="celular">
  <header class="cabecalho">
    <div class="cabecalho__barra">
      <span class="cabecalho__titulo">Início</span>
    </div>
  </header>

  <div class="saudacao">
    <h2 class="saudacao__titulo">Bom dia, Daniel Carvalho!</h2>
    <p class="saudacao__data" id="data-hoje"></p>
    <span class="tag-sincronizado">✓ Sincronizado</span>
  </div>

  <div class="conteudo">
    <h3 class="secao-titulo">Minhas tarefas pendentes</h3>
    <% tarefas.forEach(function (t) { %>
      <a href="/capataz/detalhe-tarefa?id=<%= t.id %>" class="card home-tarefa" data-status="<%= t.status %>">
        <span class="card__barra" style="background: <%= t.cor %>;"></span>
        <div class="card__corpo">
          <div class="card__titulo"><%= t.titulo %></div>
          <div class="card__sub">Supervisor <%= t.supervisor %> • <%= t.nivel %> • <%= t.prazo %></div>
        </div>
        <span class="etiqueta etiqueta--<%= t.classe %>"><%= t.nivel %></span>
        <svg class="card__seta" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 6 6 6-6 6"/>
        </svg>
      </a>
    <% }) %>
    <p id="sem-pendentes" class="busca-vazia" hidden>Nenhuma tarefa pendente no momento. 🎉</p>

    <h3 class="secao-titulo secao-titulo--espaco">Operações de campo</h3>
    <% operacoes.forEach(function (o) { %>
      <a href="<%= o.href %>" class="card">
        <span class="card__barra" style="background: <%= o.cor %>;"></span>
        <div class="card__corpo">
          <div class="card__titulo"><%= o.titulo %></div>
          <div class="card__sub"><%= o.sub %></div>
        </div>
        <svg class="card__seta" width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 6 6 6-6 6"/>
        </svg>
      </a>
    <% }) %>
  </div>

  <%- include('../partials/bottomnav-capataz', { ativa: 'inicio' }) %>
</main>

<script src="/js/tarefas-store.js"></script>
<script>
  document.getElementById('data-hoje').textContent =
    new Date().toLocaleDateString('pt-BR', {
      weekday: 'long',
      day: '2-digit',
      month: 'long',
      year: 'numeric'
    }).replace(/^\w/, function (letra) {
      return letra.toUpperCase();
    });

  // Mostra só as pendentes (no máx. 2). As concluídas pelo capataz saem daqui.
  (function () {
    var cards = Array.prototype.slice.call(document.querySelectorAll('.home-tarefa'));
    var vazio = document.getElementById('sem-pendentes');
    var mostrados = 0;
    cards.forEach(function (card) {
      var m = (card.getAttribute('href') || '').match(/[?&]id=(\d+)/);
      var concluida = m && window.TarefasStore && TarefasStore.estaConcluida(m[1]);
      if (concluida || mostrados >= 2) {
        card.style.display = 'none';
      } else {
        mostrados++;
      }
    });
    if (vazio) vazio.hidden = mostrados !== 0;
  })();
</script>

</body>
</html>
