<%- include('../partials/head', { title: title, css: css }) %>

<%#
  Variáveis esperadas pelo controller:
  - persona: 'supervisor' | 'gerente'
  - usuario: { nome: string }
  - paginaAtiva: 'relatorios' (fixo para essa view)
%>

<!-- ============================================================
     TELA: Relatórios (compartilhada entre Supervisor e Gerente)
     A sidebar muda conforme a persona passada pelo controller.
     Mobile  → TopNav + filtros + prévia skeleton + botão exportar + BottomNav
     Desktop → Sidebar (via partial) + TopBar com filtros inline + tabela + resumo
     ============================================================ -->

<!-- ════════════════════════════════════════════════════════
     LAYOUT MOBILE
     ════════════════════════════════════════════════════════ -->
<div class="layout-mobile">

  <!-- TopNav com botão voltar -->
  <header class="topnav topnav--back" role="banner">
    <a href="/<%= persona %>/home" class="topnav__back" aria-label="Voltar">
      <svg width="17" height="14" viewBox="0 0 17 14" fill="none" aria-hidden="true">
        <path d="M16 7H1M1 7L7 1M1 7L7 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <h1 class="topnav__title">Relatórios</h1>
  </header>

  <!-- Formulário de filtros -->
  <main class="relatorio-content" role="main">
    <form class="relatorio-form" id="form-relatorio">

      <!-- Período: escolha a data de início e a data final -->
      <div class="rfield">
        <label class="rfield__label">Período</label>
        <div class="rfield__daterange">
          <div class="rfield__date">
            <label class="rfield__date-label" for="data-inicio-mobile">De</label>
            <input class="rfield__input" type="date" id="data-inicio-mobile" name="dataInicio" value="2026-06-01" aria-label="Data de início" />
          </div>
          <div class="rfield__date">
            <label class="rfield__date-label" for="data-fim-mobile">Até</label>
            <input class="rfield__input" type="date" id="data-fim-mobile" name="dataFim" value="2026-07-01" aria-label="Data final" />
          </div>
        </div>
      </div>

      <!-- Retiro: Todos ou um/mais retiros (seleção múltipla) -->
      <div class="rfield">
        <label class="rfield__label" id="retiro-mobile-label">Retiro</label>
        <div class="multiselect" id="retiro-mobile" aria-labelledby="retiro-mobile-label">
          <button type="button" class="multiselect__toggle" aria-haspopup="listbox" aria-expanded="false">
            <span class="multiselect__summary">Todos</span>
          </button>
          <div class="multiselect__panel" role="listbox" hidden>
            <label class="multiselect__option multiselect__option--all">
              <input type="checkbox" class="multiselect__all" checked /> Todos os retiros
            </label>
            <% (typeof retiros !== 'undefined' ? retiros : []).forEach(function (r) { %>
            <label class="multiselect__option">
              <input type="checkbox" class="multiselect__item" value="<%= r.valor %>" data-rotulo="<%= r.rotulo %>" /> <%= r.rotulo %>
            </label>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Tipo de relatório (inclui a opção Todos) -->
      <div class="rfield">
        <label class="rfield__label" for="tipo-mobile">Tipo de relatório</label>
        <div class="rfield__select-wrap">
            <select class="rfield__select" id="tipo-mobile" name="tipo">
            <option value="todos">Todos</option>
            <option value="movimentacoes">Movimentações do rebanho</option>
            <option value="tarefas">Tarefas</option>
            <option value="tickets">Tickets de infraestrutura</option>
          </select>
        </div>
      </div>

      <div class="rfield">
        <label class="rfield__label" for="formato-mobile">Formato</label>
        <div class="rfield__select-wrap">
          <select class="rfield__select" id="formato-mobile" name="formato">
            <option value="xlsx">Excel (.xlsx)</option>
            <option value="csv">CSV (.csv)</option>
          </select>
        </div>
      </div>

      <!-- Prévia skeleton -->
      <div class="rfield">
        <p class="rfield__label">Prévia do relatório</p>
        <div class="preview-card" aria-label="Prévia do relatório" aria-busy="true">
          <div class="preview-line preview-line--200"></div>
          <div class="preview-line preview-line--160"></div>
          <div class="preview-line preview-line--220"></div>
          <div class="preview-line preview-line--140"></div>
          <div class="preview-line preview-line--180"></div>
          <div class="preview-line preview-line--200"></div>
          <div class="preview-line preview-line--100"></div>
        </div>
      </div>

      <!-- Botão exportar -->
      <button type="submit" class="btn btn--primary btn--exportar">
        Baixar arquivo
      </button>
      <p id="relatorio-feedback-mobile" style="margin: 8px 0 0; font-size: 14px; line-height: 1.4;"></p>

    </form>
  </main>

  <!-- BottomNav — só aparece no mobile do supervisor -->
  <% if (persona === 'supervisor') { %>
    <%- include('../partials/bottomnav-supervisor', { paginaAtiva: 'relatorios' }) %>
  <% } %>

  <% if (persona === 'gerente') { %>
    <%- include('../partials/bottomnav-gerente', { paginaAtiva: 'relatorios' }) %>
  <% } %>

</div><!-- /layout-mobile -->


<!-- ════════════════════════════════════════════════════════
     LAYOUT DESKTOP
     ════════════════════════════════════════════════════════ -->
<div class="layout-desktop">

  <!-- Sidebar via partial — muda conforme persona -->
  <% if (persona === 'gerente') { %>
    <%- include('../partials/sidebar-gerente', { usuario, paginaAtiva: 'relatorios' }) %>
  <% } else { %>
    <%- include('../partials/sidebar-supervisor', { usuario, paginaAtiva: 'relatorios' }) %>
  <% } %>

  <!-- Área principal -->
  <div class="desktop-main">

    <!-- TopBar com filtros inline -->
    <header class="topbar topbar--filters" role="banner">
      <div class="topbar__top-row">
        <h1 class="topbar__title">Relatórios</h1>
        <p class="topbar__date" id="data-hoje-desktop"></p>
      </div>
      <div class="topbar__filters" role="search" aria-label="Filtros de relatório">

        <div class="tfilter tfilter--daterange">
          <label class="tfilter__label">Período</label>
          <div class="tfilter__daterange">
            <input class="tfilter__input" type="date" id="data-inicio-desktop" value="2026-06-01" aria-label="Data de início" />
            <input class="tfilter__input" type="date" id="data-fim-desktop" value="2026-07-01" aria-label="Data final" />
          </div>
        </div>

        <div class="tfilter">
          <label class="tfilter__label" id="retiro-desktop-label">Retiro</label>
          <div class="multiselect" id="retiro-desktop" aria-labelledby="retiro-desktop-label">
            <button type="button" class="multiselect__toggle" aria-haspopup="listbox" aria-expanded="false">
              <span class="multiselect__summary">Todos</span>
            </button>
            <div class="multiselect__panel" role="listbox" hidden>
              <label class="multiselect__option multiselect__option--all">
                <input type="checkbox" class="multiselect__all" checked /> Todos os retiros
              </label>
              <% (typeof retiros !== 'undefined' ? retiros : []).forEach(function (r) { %>
              <label class="multiselect__option">
                <input type="checkbox" class="multiselect__item" value="<%= r.valor %>" data-rotulo="<%= r.rotulo %>" /> <%= r.rotulo %>
              </label>
              <% }) %>
            </div>
          </div>
        </div>

        <div class="tfilter">
          <label class="tfilter__label" for="tipo-desktop">Tipo de relatório</label>
          <div class="tfilter__select-wrap">
            <select class="tfilter__select" id="tipo-desktop" name="tipo">
              <option value="todos">Todos</option>
              <option value="movimentacoes">Movimentações do rebanho</option>
              <option value="tarefas">Tarefas</option>
              <option value="tickets">Tickets de infraestrutura</option>
            </select>
          </div>
        </div>

        <div class="tfilter">
          <label class="tfilter__label" for="formato-desktop">Formato</label>
          <div class="tfilter__select-wrap">
            <select class="tfilter__select" id="formato-desktop" name="formato">
              <option value="xlsx">Excel (.xlsx)</option>
              <option value="csv">CSV (.csv)</option>
            </select>
          </div>
        </div>

      </div>
    </header>

    <!-- Conteúdo desktop: tabela + resumo lado a lado -->
    <main class="desktop-content desktop-content--relatorio" role="main">
      <p id="relatorio-feedback" style="margin: 0 0 12px; font-size: 14px; line-height: 1.4;"></p>

      <!-- Coluna esquerda: Prévia tabela -->
      <section class="relatorio-preview" aria-labelledby="previa-title">
        <h2 class="section__title" id="previa-title">Prévia do relatório</h2>
        <div class="report-table-wrap">
          <table class="report-table" aria-label="Prévia do relatório">
            <%
              // Prévia (modo demo) montada da MESMA fonte das telas de lista.
              // Padrão: movimentações. O JS troca por tarefas/tickets ao mudar o filtro.
              var _relDemo = (typeof relatorioDemo !== 'undefined' && relatorioDemo) ? relatorioDemo : null;
              var _ds = _relDemo ? _relDemo.movimentacoes : null;
            %>
            <thead id="relatorio-head">
              <tr>
                <% (_ds ? _ds.colunas : ['Data','Retiro','Tipo','Qtd.','Status']).forEach(function (c) { %><th><%= c %></th><% }) %>
              </tr>
            </thead>
            <tbody id="relatorio-body">
              <% (_ds ? _ds.linhas : []).forEach(function (linha, i) { %>
              <tr<%- i % 2 === 1 ? ' class="tr--alt"' : '' %>>
                <td class="td--bold"><%= linha.celulas[0] %></td>
                <td><%= linha.celulas[1] %></td>
                <td><%= linha.celulas[2] %></td>
                <td><%= linha.celulas[3] %></td>
                <td><span class="badge <%= linha.status === 'Validado' ? 'badge--green' : 'badge--yellow' %>"><%= linha.status %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Coluna direita: Resumo + Exportar -->
      <aside class="relatorio-resumo" aria-labelledby="resumo-title">
        <h2 class="section__title" id="resumo-title">Resumo &amp; Exportar</h2>

        <div class="resumo-card">
          <p class="resumo-card__title">Resumo do período</p>
          <hr class="resumo-card__divider" />
          <dl class="resumo-list">
            <div class="resumo-list__row"><dt>Total de registros</dt><dd id="resumo-total"><%= _ds ? _ds.resumo.total : 0 %></dd></div>
            <div class="resumo-list__row"><dt>Registros validados</dt><dd id="resumo-validado"><%= _ds ? _ds.resumo.validados : 0 %></dd></div>
            <div class="resumo-list__row"><dt>Pendentes</dt><dd id="resumo-pendente"><%= _ds ? _ds.resumo.pendentes : 0 %></dd></div>
            <div class="resumo-list__row"><dt>Retiros incluídos</dt><dd id="resumo-retiros"><%= _ds ? _ds.resumo.retiros : 0 %></dd></div>
            <div class="resumo-list__row"><dt>Período</dt><dd id="resumo-periodo"><%= _ds ? _ds.resumo.periodo : '—' %></dd></div>
          </dl>
        </div>

        <button class="btn btn--primary btn--exportar-desktop" type="button">
          Baixar arquivo
        </button>

        <div class="formato-card">
          <p class="formato-card__title">Formatos .xlsx e .csv</p>
          <p class="formato-card__desc">Compatível com Excel, Google Sheets e outros editores</p>
          <p class="formato-card__desc">Apenas registros validados e sincronizados.</p>
        </div>
      </aside>

    </main>
  </div><!-- /desktop-main -->

</div><!-- /layout-desktop -->

<script>
  const el = document.getElementById('data-hoje-desktop');
  if (el) el.textContent = new Date().toLocaleDateString('pt-BR', {
    weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
  }).replace(/^\w/, c => c.toUpperCase());

  function getSession() {
    try {
      const token = localStorage.getItem('agroflow.token');
      const usuarioRaw = localStorage.getItem('agroflow.usuario');
      if (!token || !usuarioRaw) return null;
      return { token, usuario: JSON.parse(usuarioRaw) };
    } catch {
      return null;
    }
  }

  function mostrarFeedback(mensagem, tipo) {
    ['relatorio-feedback', 'relatorio-feedback-mobile'].forEach(id => {
      const feedback = document.getElementById(id);
      if (!feedback) return;
      feedback.textContent = mensagem;
      feedback.style.color = tipo === 'error' ? '#b42318' : '#146c43';
    });
  }

  // Quando logado, o filtro de retiro passa a oferecer só "Todos" + "Meu retiro"
  // (o backend filtra por UUID, e o usuário só enxerga o próprio retiro).
  function configurarFiltroRetiro(session) {
    if (!session?.usuario?.retiro_id) return;
    ['retiro-mobile', 'retiro-desktop'].forEach(id => {
      const container = document.getElementById(id);
      const panel = container?.querySelector('.multiselect__panel');
      if (!panel) return;
      panel.innerHTML = `
        <label class="multiselect__option multiselect__option--all">
          <input type="checkbox" class="multiselect__all" checked /> Todos os retiros
        </label>
        <label class="multiselect__option">
          <input type="checkbox" class="multiselect__item" value="${session.usuario.retiro_id}" data-rotulo="Meu retiro" /> Meu retiro
        </label>`;
    });
  }

  function mapearTitulo(tipo) {
    if (tipo === 'movimentacoes') return 'Movimentação';
    if (tipo === 'tarefas') return 'Tarefa';
    if (tipo === 'tickets') return 'Ticket';
    return 'Todos os relatórios';
  }

  function mapearColunas(tipo) {
    if (tipo === 'todos') return ['Data', 'Retiro', 'Registro', 'Detalhe', 'Status'];
    if (tipo === 'tarefas') return ['Data', 'Retiro', 'Descrição', 'Prioridade', 'Status'];
    if (tipo === 'tickets') return ['Data', 'Retiro', 'Categoria', 'Prioridade', 'Status'];
    return ['Data', 'Retiro', 'Tipo', 'Qtd.', 'Status'];
  }

  function formatarData(valor) {
    if (!valor) return '-';
    const data = new Date(valor);
    if (Number.isNaN(data.getTime())) return '-';
    return data.toLocaleDateString('pt-BR');
  }

  // Item bruto da API -> linha padronizada { celulas:[4], status }.
  function montarLinha(item, tipo) {
    if (tipo === 'tarefas') {
      return {
        celulas: [formatarData(item.data_criacao), `Retiro ${item.retiro_id}`, item.descricao || '-', item.prioridade || '-'],
        status: item.status === 'aprovado' ? 'Validado' : 'Pendente',
      };
    }
    if (tipo === 'tickets') {
      return {
        celulas: [formatarData(item.data_criacao), `Retiro ${item.retiro_id}`, item.categoria || '-', item.prioridade || '-'],
        status: item.status === 'aprovado' ? 'Validado' : 'Pendente',
      };
    }
    return {
      celulas: [formatarData(item.data_criacao), `Retiro ${item.retiro_id}`, item.tipo || '-', item.quantidade ?? '-'],
      status: item.sincronizado ? 'Validado' : 'Pendente',
    };
  }

  // Datasets de demonstração vindos do servidor — montados das MESMAS fontes
  // únicas das telas de lista (Tarefas, Tickets, Movimentações). Garante que a
  // prévia do relatório mostre exatamente os itens que aparecem nas páginas.
  const RELATORIO_DEMO = <%- JSON.stringify(typeof relatorioDemo !== 'undefined' ? relatorioDemo : {}) %>;

  function escaparRel(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, c =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  }

  function normalizarRel(s) {
    return String(s == null ? '' : s).toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  // Tipo "Todos": junta as linhas das três fontes numa tabela única.
  function datasetCombinado() {
    const linhas = [];
    ['movimentacoes', 'tarefas', 'tickets'].forEach(fonte => {
      const ds = RELATORIO_DEMO[fonte];
      if (ds) ds.linhas.forEach(l => linhas.push({ celulas: l.celulas, status: l.status }));
    });
    return { colunas: mapearColunas('todos'), linhas };
  }

  // Período: tenta achar uma data dd/mm/aaaa no texto da célula. Se não houver
  // (ex.: "Hoje, 08:24"), a linha é mantida — o filtro é "melhor esforço".
  function dentroDoPeriodo(texto, inicio, fim) {
    const m = String(texto || '').match(/(\d{2})\/(\d{2})\/(\d{4})/);
    if (!m) return true;
    const iso = `${m[3]}-${m[2]}-${m[1]}`;
    if (inicio && iso < inicio) return false;
    if (fim && iso > fim) return false;
    return true;
  }

  function filtrarLinhas(linhas, filtros) {
    return linhas.filter(l => {
      if (!filtros.retiro.todos && filtros.retiro.rotulos.length) {
        const alvo = normalizarRel(l.celulas[1]);
        if (!filtros.retiro.rotulos.some(r => alvo.includes(normalizarRel(r)))) return false;
      }
      return dentroDoPeriodo(l.celulas[0], filtros.dataInicio, filtros.dataFim);
    });
  }

  function textoPeriodo(filtros, fallback) {
    if (filtros.dataInicio && filtros.dataFim) {
      return `${formatarData(filtros.dataInicio)} – ${formatarData(filtros.dataFim)}`;
    }
    return fallback || '—';
  }

  // Renderiza a tabela + resumo a partir de linhas padronizadas.
  function renderTabela(colunas, linhas, periodoTexto) {
    const thead = document.getElementById('relatorio-head');
    const tbody = document.getElementById('relatorio-body');
    if (thead) thead.innerHTML = '<tr>' + colunas.map(c => `<th>${escaparRel(c)}</th>`).join('') + '</tr>';
    if (tbody) tbody.innerHTML = linhas.map((l, i) => {
      const badge = l.status === 'Validado'
        ? '<span class="badge badge--green">Validado</span>'
        : '<span class="badge badge--yellow">Pendente</span>';
      return `<tr class="${i % 2 === 1 ? 'tr--alt' : ''}">`
        + `<td class="td--bold">${escaparRel(l.celulas[0])}</td>`
        + `<td>${escaparRel(l.celulas[1])}</td>`
        + `<td>${escaparRel(l.celulas[2])}</td>`
        + `<td>${escaparRel(l.celulas[3])}</td>`
        + `<td>${badge}</td></tr>`;
    }).join('');

    const validados = linhas.filter(l => l.status === 'Validado').length;
    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = String(v); };
    set('resumo-total', linhas.length);
    set('resumo-validado', validados);
    set('resumo-pendente', linhas.length - validados);
    set('resumo-retiros', new Set(linhas.map(l => l.celulas[1])).size);
    set('resumo-periodo', periodoTexto);
  }

  // Lê os retiros marcados num multiselect. todos=true => sem filtro.
  function lerRetiros(containerId) {
    const container = document.getElementById(containerId);
    if (!container) return { todos: true, valores: [], rotulos: [] };
    const all = container.querySelector('.multiselect__all');
    const itens = [...container.querySelectorAll('.multiselect__item')].filter(i => i.checked);
    const todos = (all && all.checked) || itens.length === 0;
    return {
      todos,
      valores: todos ? [] : itens.map(i => i.value),
      rotulos: todos ? [] : itens.map(i => i.dataset.rotulo || i.value),
    };
  }

  function lerFiltros(sufixo) {
    return {
      tipo: document.getElementById(`tipo-${sufixo}`)?.value || 'todos',
      dataInicio: document.getElementById(`data-inicio-${sufixo}`)?.value || '',
      dataFim: document.getElementById(`data-fim-${sufixo}`)?.value || '',
      retiro: lerRetiros(`retiro-${sufixo}`),
    };
  }

  // Prévia de demonstração (sem login) aplicando tipo + retiro + período.
  function renderDemo(filtros) {
    const base = filtros.tipo === 'todos'
      ? datasetCombinado()
      : (RELATORIO_DEMO[filtros.tipo] || RELATORIO_DEMO.movimentacoes);
    if (!base) return;
    const linhas = filtrarLinhas(base.linhas, filtros);
    const fallback = base.resumo ? base.resumo.periodo : 'Todos os registros';
    renderTabela(base.colunas, linhas, textoPeriodo(filtros, fallback));
  }

  async function buscarDados(tipo, filtros, session) {
    const endpoint = tipo === 'tarefas'
      ? '/relatorios/tarefas/dados'
      : tipo === 'tickets'
        ? '/relatorios/tickets/dados'
        : '/relatorios/movimentacoes/dados';
    const url = new URL(endpoint, window.location.origin);
    if (filtros.dataInicio) url.searchParams.set('dataInicio', filtros.dataInicio);
    if (filtros.dataFim) url.searchParams.set('dataFim', filtros.dataFim);
    if (!filtros.retiro.todos && filtros.retiro.valores.length === 1) {
      url.searchParams.set('retiroId', filtros.retiro.valores[0]);
    }
    const response = await fetch(url.toString(), { headers: { Authorization: `Bearer ${session.token}` } });
    const dados = await response.json().catch(() => []);
    if (!response.ok || !Array.isArray(dados)) {
      throw new Error(dados?.error || 'Não foi possível carregar o relatório');
    }
    return dados.map(item => montarLinha(item, tipo));
  }

  async function carregarRelatorio() {
    const session = getSession();
    const filtros = lerFiltros('desktop');

    // Sem login: prévia de demonstração com os MESMOS itens das telas de lista.
    if (!session) {
      renderDemo(filtros);
      mostrarFeedback('Prévia de demonstração — faça login para dados reais e exportação.', 'success');
      return;
    }

    try {
      const tipos = filtros.tipo === 'todos' ? ['movimentacoes', 'tarefas', 'tickets'] : [filtros.tipo];
      const resultados = await Promise.all(tipos.map(t => buscarDados(t, filtros, session)));
      const linhas = resultados.flat();
      renderTabela(mapearColunas(filtros.tipo), linhas, textoPeriodo(filtros, 'Período selecionado'));
      mostrarFeedback(`Relatório de ${mapearTitulo(filtros.tipo).toLowerCase()} atualizado com sucesso.`, 'success');
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao carregar relatório', 'error');
    }
  }

  async function exportarRelatorio(contexto) {
    const session = getSession();
    if (!session) {
      mostrarFeedback('Faça login para exportar os relatórios.', 'error');
      return;
    }

    const sufixo = contexto === 'mobile' ? 'mobile' : 'desktop';
    const filtros = lerFiltros(sufixo);
    const formato = document.getElementById(`formato-${sufixo}`)?.value || 'xlsx';

    // O arquivo é por tipo (colunas diferentes); "Todos" não tem export único.
    if (filtros.tipo === 'todos') {
      mostrarFeedback('Para baixar, escolha um tipo específico: Movimentações, Tarefas ou Tickets.', 'error');
      return;
    }

    const url = new URL('/relatorios/exportar', window.location.origin);
    url.searchParams.set('tipo', filtros.tipo);
    url.searchParams.set('formato', formato);
    if (filtros.dataInicio) url.searchParams.set('dataInicio', filtros.dataInicio);
    if (filtros.dataFim) url.searchParams.set('dataFim', filtros.dataFim);
    if (!filtros.retiro.todos && filtros.retiro.valores.length === 1) {
      url.searchParams.set('retiroId', filtros.retiro.valores[0]);
    }

    mostrarFeedback('Gerando arquivo...', 'success');

    try {
      const response = await fetch(url.toString(), {
        headers: { Authorization: `Bearer ${session.token}` },
      });

      if (!response.ok) {
        const erro = await response.json().catch(() => ({}));
        throw new Error(erro.error || 'Não foi possível exportar o relatório');
      }

      const blob = await response.blob();
      const disposicao = response.headers.get('Content-Disposition') || '';
      const nome = disposicao.match(/filename="([^"]+)"/)?.[1]
        || `relatorio-${tipo}.${formato}`;
      const link = document.createElement('a');
      const objetoUrl = URL.createObjectURL(blob);

      link.href = objetoUrl;
      link.download = nome;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(objetoUrl);

      mostrarFeedback(`Arquivo ${nome} gerado com sucesso.`, 'success');
    } catch (error) {
      mostrarFeedback(error instanceof Error ? error.message : 'Erro ao exportar relatório', 'error');
    }
  }

  const formRelatorio = document.getElementById('form-relatorio');
  if (formRelatorio) {
    formRelatorio.addEventListener('submit', event => {
      event.preventDefault();
      exportarRelatorio('mobile');
    });
  }

  const botaoExportarDesktop = document.querySelector('.btn--exportar-desktop');
  if (botaoExportarDesktop) {
    botaoExportarDesktop.addEventListener('click', () => exportarRelatorio('desktop'));
  }

  // Liga um multiselect de retiro: abrir/fechar, marcar "Todos", resumo e change.
  function initMultiselect(containerId, onChange) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const toggle = container.querySelector('.multiselect__toggle');
    const panel = container.querySelector('.multiselect__panel');
    const summary = container.querySelector('.multiselect__summary');
    const all = container.querySelector('.multiselect__all');
    const itens = [...container.querySelectorAll('.multiselect__item')];

    function atualizarResumo() {
      const marcados = itens.filter(i => i.checked);
      if (!all || all.checked || marcados.length === 0) summary.textContent = 'Todos';
      else if (marcados.length === 1) summary.textContent = marcados[0].dataset.rotulo || marcados[0].value;
      else summary.textContent = `${marcados.length} retiros`;
    }

    function abrir(estado) {
      panel.hidden = !estado;
      toggle.setAttribute('aria-expanded', String(estado));
    }

    toggle.addEventListener('click', e => { e.stopPropagation(); abrir(panel.hidden); });

    if (all) all.addEventListener('change', () => {
      if (all.checked) itens.forEach(i => { i.checked = false; });
      else if (!itens.some(i => i.checked)) all.checked = true;
      atualizarResumo();
      onChange();
    });

    itens.forEach(item => item.addEventListener('change', () => {
      if (item.checked && all) all.checked = false;
      if (all && !itens.some(i => i.checked)) all.checked = true;
      atualizarResumo();
      onChange();
    }));

    document.addEventListener('click', e => { if (!container.contains(e.target)) abrir(false); });
    atualizarResumo();
  }

  const session = getSession();
  // Reconfigura as opções de retiro ANTES de ligar os multiselects.
  configurarFiltroRetiro(session);

  ['tipo-desktop', 'data-inicio-desktop', 'data-fim-desktop'].forEach(id => {
    const campo = document.getElementById(id);
    if (campo) campo.addEventListener('change', carregarRelatorio);
  });

  // O multiselect mobile não atualiza a prévia (mobile só exporta); o desktop sim.
  initMultiselect('retiro-mobile', () => {});
  initMultiselect('retiro-desktop', carregarRelatorio);

  carregarRelatorio();
</script>

</body>
</html>
