<aside class="sidebar" role="complementary" aria-label="Menu lateral">
  <div class="sidebar__top">
    <p class="sidebar__brand">BrPec</p>
    <p class="sidebar__sub">Agropecuária</p>
    <button class="sidebar__menu-btn" aria-label="Menu">
      <img src="/assets/icons/hamburguer.svg" alt="" aria-hidden="true" width="43" height="43" />
    </button>
  </div>

  <nav class="sidebar__nav" role="navigation" aria-label="Navegação lateral">
    <a href="/supervisor/home"      class="sidebar__link <%= paginaAtiva === 'home'      ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'home'      ? 'aria-current="page"' : '' %>>
      <img src="/assets/icons/home.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span>Início</span>
    </a>
    <a href="/supervisor/revisao"   class="sidebar__link <%= paginaAtiva === 'revisao'   ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'revisao'   ? 'aria-current="page"' : '' %>>
      <img src="/assets/icons/revisao.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span>Tarefas</span>
    </a>
    <a href="/supervisor/tickets"   class="sidebar__link <%= paginaAtiva === 'tickets'   ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'tickets'   ? 'aria-current="page"' : '' %>>
      <img src="/assets/icons/tickets.svg" alt="" aria-hidden="true" width="27" height="27" />
      <span>Tickets</span>
    </a>
    <a href="/supervisor/movimentacoes" class="sidebar__link <%= paginaAtiva === 'movimentacoes' ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'movimentacoes' ? 'aria-current="page"' : '' %>>
      <img src="/assets/icons/movimentacao.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span>Movimentações</span>
    </a>
    <a href="/supervisor/delegar"   class="sidebar__link <%= paginaAtiva === 'delegar'   ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'delegar'   ? 'aria-current="page"' : '' %>>
      <img src="/assets/icons/delegar.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span>Delegar</span>
    </a>
    <a href="/supervisor/relatorios" class="sidebar__link <%= paginaAtiva === 'relatorios' ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'relatorios' ? 'aria-current="page"' : '' %>>
      <img src="/assets/icons/relatorios.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span>Relatório</span>
    </a>
  </nav>

  <div class="sidebar__user">
    <div class="sidebar__avatar" aria-hidden="true">
      <%= usuario?.nome?.split(' ').map(n => n[0]).slice(0,2).join('').toUpperCase() || 'LF' %>
    </div>
    <div class="sidebar__user-info">
      <p class="sidebar__user-name"><%= usuario?.nome || 'Luiz Felipe' %></p>
      <p class="sidebar__user-role">Supervisor</p>
    </div>
    <button type="button" class="sidebar__logout" data-logout aria-label="Sair da conta">Sair</button>
  </div>
</aside>
<script src="/js/sidebar.js"></script>
