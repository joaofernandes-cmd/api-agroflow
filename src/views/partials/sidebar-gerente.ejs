<aside class="sidebar" role="complementary" aria-label="Menu lateral">
  <div class="sidebar__top">
    <p class="sidebar__brand">BrPec</p>
    <p class="sidebar__sub">Agropecuária</p>
    <button class="sidebar__menu-btn" aria-label="Menu">
      <img src="/assets/icons/hamburguer.svg" alt="" aria-hidden="true" width="43" height="43" />
    </button>
  </div>

  <nav class="sidebar__nav" role="navigation" aria-label="Navegação lateral">
    <a href="/gerente/home"       class="sidebar__link <%= paginaAtiva === 'home'       ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'home'       ? 'aria-current="page"' : '' %>>
      <img src="/assets/icons/home.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span>Início</span>
    </a>
    <a href="/gerente/relatorios" class="sidebar__link <%= paginaAtiva === 'relatorios' ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'relatorios' ? 'aria-current="page"' : '' %>>
      <img src="/assets/icons/relatorios.svg" alt="" aria-hidden="true" width="24" height="24" />
      <span>Relatório</span>
    </a>
  </nav>

  <div class="sidebar__user">
    <div class="sidebar__avatar" aria-hidden="true">
      <%= usuario?.nome?.split(' ').map(n => n[0]).slice(0,2).join('').toUpperCase() || 'MF' %>
    </div>
    <div class="sidebar__user-info">
      <p class="sidebar__user-name"><%= usuario?.nome || 'Marcos Ferreira' %></p>
      <p class="sidebar__user-role">Gerente</p>
    </div>
    <button type="button" class="sidebar__logout" data-logout aria-label="Sair da conta">Sair</button>
  </div>
</aside>
<script>
  const sidebar = document.querySelector('.sidebar');
  if (localStorage.getItem('sidebar-collapsed') === '1') {
    sidebar.classList.add('sidebar--collapsed');
  }
  document.querySelector('.sidebar__menu-btn').addEventListener('click', function () {
    sidebar.classList.toggle('sidebar--collapsed');
    localStorage.setItem('sidebar-collapsed', sidebar.classList.contains('sidebar--collapsed') ? '1' : '0');
  });

  document.querySelector('[data-logout]')?.addEventListener('click', function () {
    const token = localStorage.getItem('agroflow.token');

    if (token) {
      fetch('/usuarios/logout', {
        method: 'POST',
        headers: { Authorization: `Bearer ${token}` },
        keepalive: true
      }).catch(() => {});
    }

    localStorage.removeItem('agroflow.token');
    localStorage.removeItem('agroflow.usuario');
    window.location.assign('/auth/perfil');
  });
</script>
