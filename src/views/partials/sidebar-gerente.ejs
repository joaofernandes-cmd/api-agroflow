<aside class="sidebar" role="complementary" aria-label="Menu lateral">
  <div class="sidebar__top">
    <p class="sidebar__brand">BrPec</p>
    <p class="sidebar__sub">Agropecuária</p>
    <button class="sidebar__menu-btn" aria-label="Menu">
      <img src="https://www.figma.com/api/mcp/asset/7af5f5fc-0e97-4fd9-a074-1e84a3e6b18d" alt="" aria-hidden="true" width="43" height="43" />
    </button>
  </div>

  <nav class="sidebar__nav" role="navigation" aria-label="Navegação lateral">
    <a href="/gerente/home"       class="sidebar__link <%= paginaAtiva === 'home'       ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'home'       ? 'aria-current="page"' : '' %>>
      <img src="https://www.figma.com/api/mcp/asset/2781ffb2-c640-47f1-8e36-70e63df68b38" alt="" aria-hidden="true" width="24" height="24" />
      <span>Início</span>
    </a>
    <a href="/gerente/relatorios" class="sidebar__link <%= paginaAtiva === 'relatorios' ? 'sidebar__link--active' : '' %>" <%= paginaAtiva === 'relatorios' ? 'aria-current="page"' : '' %>>
      <img src="https://www.figma.com/api/mcp/asset/ca705510-0526-476c-a288-c3fe34d3951a" alt="" aria-hidden="true" width="24" height="24" />
      <span>Relatório</span>
    </a>
  </nav>

  <div class="sidebar__user">
    <div class="sidebar__avatar" aria-hidden="true">
      <%= usuario?.nome?.split(' ').map(n => n[0]).slice(0,2).join('').toUpperCase() || 'MF' %>
    </div>
    <div class="sidebar__user-info">
      <p class="sidebar__user-name"><%= usuario?.nome || 'Marcos Ferreira' %></p>
      <p class="sidebar__user-role">Gerente</p>
    </div>
  </div>
</aside>
